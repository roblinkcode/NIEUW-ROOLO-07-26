obile_content_alignment":"left"}},"7ead9d52-a3ce-4f63-9e00-e5fbe252c5a8":{"type":"image-with-text","blocks":{"heading_MTMm6N":{"type":"heading","settings":{"heading_size":"h2"}},"9bd8fb44-fa40-449d-be77-8f37af118496":{"type":"text","settings":{"text":"<p>Dit harnas verdeelt de druk gelijkmatig over het lichaam, waardoor <strong>de nek van je hond niet belast wordt.<\/strong> Ideaal voor honden die veel trekken, en veel comfortabeler dan een halsband, vooral tijdens lange wandelingen.<\/p>","text_style":"body"}}},"block_order":["heading_MTMm6N","9bd8fb44-fa40-449d-be77-8f37af118496"],"settings":{"image":"shopify:\/\/shop_images\/gif_2_e1cbb5d1-ba85-4469-b908-c5e0dc7344d1.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"2cb68c65-93ce-4030-a625-5bac24b42fe4":{"type":"image-with-text","blocks":{"2c2d5ff2-50f7-45b3-97a7-192755274d02":{"type":"text","disabled":true,"settings":{"text":"<h4>Maat Tabel<\/h4><p>De jas heeft een <strong>perfecte pasvorm<\/strong> en zit geweldig op je trouwe viervoeter!<\/p><p><strong>LET OP: <\/strong>Meet volgens de <strong>Maat Tabel<\/strong> om de juiste pasvorm voor jouw hond te krijgen.<\/p><p>Bij twijfel raden we aan een maat groter te kiezen!<br\/>Kom je er toch niet uit? Neem contact op met de klantenservice, dan helpen wij je graag verder!<\/p>","text_style":"body"}}},"block_order":["2c2d5ff2-50f7-45b3-97a7-192755274d02"],"settings":{"image":"shopify:\/\/shop_images\/WhatsApp_Image_2024-11-09_at_10.32.30.jpg","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"rich_text_TmJaEX":{"type":"rich-text","blocks":{"text_F46wQU":{"type":"text","settings":{"text":"<h4>Maat Tabel<\/h4><p>De jas heeft een <strong>perfecte pasvorm<\/strong> en zit geweldig op je trouwe viervoeter!<\/p><p><strong>LET OP: <\/strong>Meet volgens de afmetingen in de <strong>Maat Tabel<\/strong> om de juiste pasvorm voor jouw hond te krijgen.<\/p><p>Twijfel? Kies een maat groter.<br\/>Kom je er niet uit? Neem contact op met onze klantenservice!<\/p>"}}},"block_order":["text_F46wQU"],"settings":{"desktop_content_position":"center","content_alignment":"left","full_width":true,"color_scheme":"background-1","padding_top":0,"padding_bottom":16}},"9f8ed1f4-75b8-4974-842c-754126d14d2b":{"type":"image-with-text","blocks":{"heading_fMiFPa":{"type":"heading","settings":{"heading_size":"h2"}},"96069707-1f6a-4405-b46e-521e47f44ce0":{"type":"text","settings":{"text":"<p>Het harnas heeft een handig hendeltje waarmee je je hond makkelijk kunt vasthouden of corrigeren, <strong>zonder dat de hond ongemak ervaart.<\/strong> Perfect voor extra controle bij drukke momenten of trainingssessies.<\/p>","text_style":"body"}}},"block_order":["heading_fMiFPa","96069707-1f6a-4405-b46e-521e47f44ce0"],"settings":{"image":"shopify:\/\/shop_images\/gif_3.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"image_with_text_BxyJX8":{"type":"image-with-text","disabled":true,"settings":{"image":"shopify:\/\/shop_images\/DEENIGEWINTERJASDIEJETROUWEVIERVOETERNODIGHEEFT-ezgif.com-optimize_1.gif","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"e4394e38-3ec5-4b0f-ad44-21d3ebfbddb6":{"type":"image-with-text","blocks":{"heading_mfHC78":{"type":"heading","settings":{"heading_size":"h2"}},"template