gins":true}},"169477810286cbda2b":{"type":"apps","settings":{"include_margins":true}},"1694778916ae6d13bb":{"type":"apps","settings":{"include_margins":true}},"7ead9d52-a3ce-4f63-9e00-e5fbe252c5a8":{"type":"image-with-text","blocks":{"9bd8fb44-fa40-449d-be77-8f37af118496":{"type":"text","settings":{"text":"<h4>De perfecte oplossing<\/h4><p>Het donzige, zachte hondenbed van Roolo is in samenwerking met diertherapeuten ontwikkeld om de <strong>gewrichten<\/strong> van je viervoeter optimaal <strong>te<\/strong> <strong>ontlasten, angst te verminderen en je huisdier het best mogelijke slaapcomfort te bieden.<\/strong><\/p>","text_style":"body"}}},"block_order":["9bd8fb44-fa40-449d-be77-8f37af118496"],"disabled":true,"settings":{"image":"shopify:\/\/shop_images\/Scherm_afbeelding_2023-11-14_om_16.41.59.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"middle","desktop_content_alignment":"center","mobile_content_alignment":"left"}},"af19ca60-4102-40cc-8748-150b1134b815":{"type":"image-with-text","blocks":{"template--20144669000004__af19ca60-4102-40cc-8748-150b1134b815-text-1":{"type":"text","settings":{"text":"<p><strong>Maattabel<\/strong><\/p><p>Bekijk goed voor aankoop welke maat het beste geschikt is voor jouw hond, bij twijfel raden wij aan om eerder voor een grotere maat te kiezen, beter te groot dan te klein!<\/p>","text_style":"body"}}},"block_order":["template--20144669000004__af19ca60-4102-40cc-8748-150b1134b815-text-1"],"settings":{"image":"shopify:\/\/shop_images\/maattabel_2f589941-a46c-4f7f-8efd-b8b829fd3cf4.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"middle","desktop_content_alignment":"center","mobile_content_alignment":"left"}},"9f8ed1f4-75b8-4974-842c-754126d14d2b":{"type":"image-with-text","blocks":{"96069707-1f6a-4405-b46e-521e47f44ce0":{"type":"text","settings":{"text":"<h4><strong>Maximaal comfort zonder gewrichtspijn<\/strong><\/h4><p>De kalmerende mand past zich perfect aan de vorm van het lichaam van je hond aan, <strong>vermindert de spierspanning<\/strong> en <strong>kalmeert het zenuwstelsel.<\/strong><\/p>","text_style":"body"}}},"block_order":["96069707-1f6a-4405-b46e-521e47f44ce0"],"disabled":true,"settings":{"image":"shopify:\/\/shop_images\/Scherm_afbeelding_2023-11-14_om_16.42.43.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"middle","desktop_content_alignment":"center","mobile_content_alignment":"left"}},"e4394e38-3ec5-4b0f-ad44-21d3ebfbddb6":{"type":"image-with-text","blocks":{"template--20109320978756__e4394e38-3ec5-4b0f-ad44-21d3ebfbddb6-text-1":{"type":"text","settings":{"text":"<h4><strong>Dit is de reden waarom meer dan 4000 viervoeters dol zijn op het hondenbed:<\/strong><\/h4><p>✔️ Vermindert angst, stress en gewrichtspijn vanaf de eerste nacht<\/p><p>✔️ Het veilige toevluchtsoord biedt onmiddelijke ontspanning en comfort<\/p><p>✔️ Gemakkelijk schoon te maken in de wasmachine<\/p><p>✔️ Diervriendelijk premium materiaal.<\/p><p>✔️ Anti slip bodem<\/p><p>✔️ Waterafstotende bodem, voorkomt vlekken!<\/p>","text_style":"body"}}},"block_order":["template--20109320978756__e4394e38-3ec5-4b0f-ad44-21d3ebfbddb6-text-1"],"settings":{"image":"shopify:\/\/shop_images\/14.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"fc7f31b1-4af5-4037-bf99-12ffff6d102e":{"type":"collapsible-content","blocks":{"template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-1":{"type":"collapsible_row","settings":{"heading":"Kan de mand in de 