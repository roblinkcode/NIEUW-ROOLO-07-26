ts_overlay","trust_badge_position":"top-right","trust_badge_size":"medium"}},"3d07fd2e-22b5-4988-88fb-ca0b0e7cb741":{"type":"collapsible-content","blocks":{"collapsible_row_CLVtDX":{"type":"collapsible_row","settings":{"heading":"SPECIFICATIES","icon":"none","row_content":"<p><strong>Licht Type: <\/strong>LED<br\/><strong>Licht Kleur: <\/strong>Warm, wit, natuurlijk licht<br\/><strong>Voltage: <\/strong>5V<br\/><strong>Voeding: <\/strong>USB-C<\/p>","page":""}},"collapsible_row_UkfAwY":{"type":"collapsible_row","settings":{"heading":"HANDLEIDING","icon":"none","row_content":"<p><strong>Aansluiten<\/strong>: Verbind de USB-kabel met een voeding (laptop, monitor, of USB-oplader).<\/p><p><strong>Inschakelen<\/strong>: Tik kort op het touchpaneel om de lamp aan te zetten.<\/p><p><strong>Helderheid Aanpassen<\/strong>: Druk op het touchpaneel om de helderheid aan te passen.<\/p><p><strong>Kleurtemperatuur Wijzigen<\/strong>: Tik met je vinger op kleur verandering instelling om de kleurtemperatuur te selecteren.<\/p><p><strong>Uitschakelen<\/strong>: Tik opnieuw op het touchpaneel om de lamp uit te schakelen.<\/p>","page":""}}},"block_order":["collapsible_row_CLVtDX","collapsible_row_UkfAwY"],"settings":{"caption":"","heading_size":"h1","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":0,"padding_bottom":4}},"2be139f8-05a0-4790-a783-2a5f2a2daad0":{"type":"collapsible-content","blocks":{"template--19900162113860__2be139f8-05a0-4790-a783-2a5f2a2daad0-collapsible_row-1":{"type":"collapsible_row","settings":{"heading":"Links- of rechtshandig?","icon":"check_mark","row_content":"<p>Kies voor de rechtshandige versie als je de band op de rechterschouder wilt dragen en de tas aan de linkerkant <strong>(aanbevolen voor rechtshandigen)<\/strong><\/p><p>Kies voor de linkshandige versie als je de band op de linkerschouder en de tas aan de rechterkant wilt dragen <strong>(aanbevolen voor linkshandigen)<\/strong><\/p>","page":""}},"template--19900162113860__2be139f8-05a0-4790-a783-2a5f2a2daad0-collapsible_row-2":{"type":"collapsible_row","settings":{"heading":"Hoe het werkt","icon":"question_mark","row_content":"<p>Maak je je voortdurend zorgen over de veiligheid van jouw waardevolle spullen wanneer je je op drukke plaatsen bevindt of op reis bent?<br\/><br\/><strong>Betreed een zorgeloze wereld met de ROOLO Bag. Jouw bescherming tegen diefstal en zakkenrollen<\/strong><\/p><p><br\/>Dankzij de antidiefstal ritsen, het discrete, slanke ontwerp en de RFID-blokkerende vakken <strong>zijn je waardevolle spullen veilig<\/strong> .<\/p><p><br\/>Rits eenvoudig jouw waardevolle spullen dicht, gooi ze over je schouder en ga op verkenning, wetende dat jouw belangrijkste <strong>spullen veilig en binnen handbereik zijn<\/strong>.<\/p>","page":""}},"template--19900162113860__2be139f8-05a0-4790-a783-2a5f2a2daad0-collapsible_row-3":{"type":"collapsible_row","settings":{"heading":"Geen verzendkosten","icon":"truck","row_content":"<p>Bij ons hoef jij geen verzendkosten te betalen! <\/p>","page":""}},"template--19900162113860__2be139f8-05a0-4790-a783-2a5f2a2daad0-collapsible_row-4":{"type":"collapsible_row","settings":{"heading":"Garantie","icon":"lock","row_content":"<p>Wij hebben een 30 dagen geld-terug garantie. Als je niet tevreden bent kan je contact met ons opnemen en betalen wij het volledige bedrag terug.<br\/><br\/>*Het product moet zich in originele staat bevinden en geen gebruikssporen bevatten.<\/p>","page":""}}},"block_order":["template--19900162113860__2be139f8-05a0-4790-a783-2a5f2a2daad0-collapsible_row-1","template--19900162113860__2be139f8-05a0-4790-a783-2a5f2a2daad0-collapsible_row-2","template--19900162113860__2be139f8-05a0-4790-a783-2a5f2a2daad0-collapsible_row-3","template--19900162113860__2be139f8-05a0-4790-a783-2a5f2a2daad0-collapsible_row-4"],"disabled":true,"settings":{"caption":"","heading_size":"h1","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":36,"padding_bottom":36}},"related-products":{"type":"related-products","disabled":true,"settings":{"heading_size":"h2","products_to_show":4,"columns_desktop":4,"color_scheme":"background-1","image_ratio":"adapt","show_secondary_image":false,"show_vendor":false,"show_rating":false,"columns_mobile":"2","padding_top":36,"padding_bottom":24}},"testimonials_r3mFyt":{"type":"testimonials","blocks":{"column_4xJHke":{"type":"column","settings":{"title":"","text":"<p>Ideaal als je zoals ik in de avonden aan het werk bent, je bent volledig gefocust op je  werk.<\/p>","author":"Nina H."}},"column_eTYbN3":{"type":"column","settings":{"title":"","text":"<p>Perfect voor team meetings, het ziet er gelijk een stuk professioneler uit!<\/p>","author":"Frits B."}},"column_n7Bwz4":{"type":"column","settings":{"title":"","text":"<p>Super product, je ziet in donkere ruimtes je muis en toetsenbord veel beter, ook handig voor bij het gamen.<\/p>","author":"Mart N."}}},"block_order":["column_4xJHke","column_eTYbN3","column_n7Bwz4"],"settings":{"title":"Wat onze klanten zeggen","heading_size":"h2","text":"","color_scheme":"background-1","image_width":"full","image_ratio":"square","column_alignment":"center","show_stars":true,"show_quotes":true,"columns_desktop":3,"padding_top":36,"padding_bottom":16}},"icons_with_content_CzQhwB":{"type":"icons-with-content","blocks":{"heading_GKPQWp":{"type":"heading","settings":{"heading_size":"h2"}},"icon_ii3tGQ":{"type":"icon","settings":{"icon":"check_mark","image":"shopify:\/\/shop_images\/icons8-eye-100.png","title":"Oogvriendelijke Verlichting","text":"<p>Zachte verlichting om vermoeide ogen te voorkomen. Zonder hinderlijk licht in je ogen.<\/p>"}},"icon_HH7ERp":{"type":"icon","settings":{"icon":"check_mark","image":"shopify:\/\/shop_images\/icons8-brightness-100.png","title":"Helderheid Op Maat","text":"<p>Pas de helderheid en kleurtemperatuur aan voor optimale verlichting.<\/p>"}},"icon_yBxFtV":{"type":"icon","settings":{"icon":"check_mark","image":"shopify:\/\/shop_images\/icons8-box-100.png","title":"Ruimtebesparend","text":"<p>Slank en stijlvol, perfect voor kleine werkruimtes.<\/p>"}},"icon_c9FUhn":{"type":"icon","settings":{"icon":"check_mark","image":"shopify:\/\/shop_images\/icons8-installation-100_b5211629-3cfa-4490-a0bc-9b1ca42707a0.png","title":"Eenvoudige Installatie","text":"<p>Snel en eenvoudig te bevestigen zonder gereedschap, sluit aan via USB-C.<\/p>"}},"icon_3WqxpX":{"type":"icon","disabled":true,"settings":{"icon":"check_mark","image":"shopify:\/\/shop_images\/icons8-eye-96.png","title":"Eyecatcher","text":"<p>Trekt de aandacht en is een echte spraakmaker met jouw unieke creatie.<\/p>"}}},"block_order":["heading_GKPQWp","icon_ii3tGQ","icon_HH7ERp","icon_yBxFtV","icon_c9FUhn","icon_3WqxpX"],"settings":{"color_scheme":"background-1","icon_size":"xxl","icon_position":"above","icon_color":"accent-1","icon_heading_size":"h3","icon_text_alignment":"left","icons_desktop_layout":"2-columns","icons_mobile_layout":"2-columns","desktop_content_alignment":"left","layout":"text_first","mobile_layout":"text_first","hide_content_on_mobile":false,"padding_top":12,"padding_bottom":12}},"7c2381c3-1795-445b-91da-9765523b1638":{"type":"image-with-text","blocks":{"caption_kKeibh":{"type":"caption","settings":{"caption":"PRODUCTIVITY","text_style":"subtitle","text_size":"medium"}},"heading_pRnVDn":{"type":"heading","settings":{"heading_size":"h1"}},"template--19900162113860__7c2381c3-1795-445b-91da-9765523b1638-text-1":{"type":"text","settings":{"text":"<p>Verlicht je werkruimte direct en creëer een comfortabele werkomgeving. Met de juiste verlichting kun je je <strong>beter concentreren<\/strong>, zelfs in slecht verlichte omstandigheden, wat bijdraagt aan een <strong>hogere productiviteit en minder vermoeidheid.<\/strong><\/p>","text_style":"body"}}},"block_order":["caption_kKeibh","heading_pRnVDn","template--19900162113860__7c2381c3-1795-445b-91da-9765523b1638-text-1"],"settings":{"image":"shopify:\/\/shop_images\/Scherm_afbeelding_2024-08-28_om_07.04.36.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"16947789000e7c3be1":{"type":"apps","settings":{"include_margins":true}},"169477810286cbda2b":{"type":"apps","settings":{"include_margins":true}},"1694778916ae6d13bb":{"type":"apps","settings":{"include_margins":true}},"image_with_text_JL8T9N":{"type":"image-with-text","blocks":{"caption_7VEKFV":{"type":"caption","settings":{"caption":"BRIGHTNESS & TEMPERATURE","text_style":"subtitle","text_size":"medium"}},"heading_qt6VrE":{"type":"heading","settings":{"heading_size":"h1"}},"text_G4R9yi":{"type":"text","settings":{"text":"<p>Pas eenvoudig de <strong>helderheid en kleurtemperatuur<\/strong> aan voor de ideale verlichting, of je nu helder wit licht nodig hebt voor werk of een warme gloed voor ontspanning.<\/p>","text_style":"body"}}},"block_order":["caption_7VEKFV","heading_qt6VrE","text_G4R9yi"],"settings":{"image":"shopify:\/\/shop_images\/Ontwerp_zonder_titel_8.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"image_with_text_rbbW7Q":{"type":"image-with-text","blocks":{"caption_ebKfKi":{"type":"caption","settings":{"caption":"EYECARE","text_style":"subtitle","text_size":"medium"}},"heading_emRFr4":{"type":"heading","settings":{"heading_size":"h1"}},"text_zjB43b":{"type":"text","settings":{"text":"<p>Na afstelling biedt de lichtbron een asymme