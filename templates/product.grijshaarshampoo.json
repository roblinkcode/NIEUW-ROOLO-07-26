c","text_XVeWdm","icon_7GhkVN"],"settings":{"color_scheme":"background-1","icon_size":"xxl","icon_position":"above","icon_color":"accent-1","icon_heading_size":"h4","icon_text_alignment":"center","icons_desktop_layout":"2-columns","icons_mobile_layout":"2-columns","desktop_content_alignment":"center","layout":"text_first","mobile_layout":"text_first","hide_content_on_mobile":false,"padding_top":4,"padding_bottom":16}},"7c2381c3-1795-445b-91da-9765523b1638":{"type":"image-with-text","blocks":{"heading_aTPMEQ":{"type":"heading","settings":{"heading_size":"h2"}},"template--19900162113860__7c2381c3-1795-445b-91da-9765523b1638-text-1":{"type":"text","settings":{"text":"<p><strong>Herstelt de natuurlijke haarkleur<\/strong><br\/>Deze formule werkt door de natuurlijke haarkleurpigmenten te reactiveren, waardoor je haar zijn oorspronkelijke kleur terugkrijgt.<\/p><p><strong>Verwijdert grijs haar door haarkleurpigmenten te reactiveren<\/strong><br\/>Grijs haar wordt aangepakt door de pigmenten in het haar opnieuw tot leven te brengen, waardoor het weer zijn volle, rijke kleur krijgt.<\/p>","text_style":"body"}}},"block_order":["heading_aTPMEQ","template--19900162113860__7c2381c3-1795-445b-91da-9765523b1638-text-1"],"custom_css":[],"settings":{"image":"shopify:\/\/shop_images\/Scherm_afbeelding_2024-08-20_om_18.22.42.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"2cb68c65-93ce-4030-a625-5bac24b42fe4":{"type":"image-with-text","blocks":{"2c2d5ff2-50f7-45b3-97a7-192755274d02":{"type":"text","settings":{"text":"<h3>Wees zakkenrollers altijd een stap voor.<\/h3><p><br\/>Zorgen maken over zakkenrollers kan enorm vervelend zijn als je op reis bent, daarom beschikt de ROOLO Bag over geavanceerde antidiefstal functies<strong>, zodat je zorgeloos kunt reizen:<\/strong><\/p><p><br\/><strong>- Antidiefstal ritsen: <\/strong>Deze krijgen zakkenrollers niet eenvoudig open!<\/p><p><strong>- RFID-blokkeervakken: <\/strong>Deze vakken beschermen je auto sleutels, bankpassen, creditcards en zelfs paspoorten tegen elektronische diefstal!<\/p>","text_style":"body"}}},"block_order":["2c2d5ff2-50f7-45b3-97a7-192755274d02"],"disabled":true,"settings":{"image":"shopify:\/\/shop_images\/6g_2738a546-e8a1-4e00-9a55-f31c68fc7e6a.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"7ead9d52-a3ce-4f63-9e00-e5fbe252c5a8":{"type":"image-with-text","blocks":{"heading_tYUQWc":{"type":"heading","settings":{"heading_size":"h2"}},"9bd8fb44-fa40-449d-be77-8f37af118496":{"type":"text","settings":{"text":"<p>De ROOLO Bag is je kluis in een slank formaat met een hoop ruimte.<\/p><p>Het heeft een <strong>slank ontwerp<\/strong>, met gemakkelijke toegang, robuust en is<strong> 100% waterdicht. <\/strong><\/p><p>Alles wat u nodig heeft, <strong>altijd bij de hand<\/strong>, zonder zorgen.<br\/><\/p>","text_style":"body"}}},"block_order":["heading_tYUQWc","9bd8fb44-fa40-449d-be77-8f37af118496"],"disabled":true,"settings":{"image":"shopify:\/\/shop_images\/Tas1.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"comparison_table_qncmkq":{"type":"comparison-table","blocks":{"row_JrRBw6":{"type":"row","settings":{"benefit":"Stekkers & USB","us":true,"others":false}},"row_r6nHWV":{"type":"row","settings":{"benefit":"Efficiënt  Design","us":true,"others":false}},"row_aJHnEM":{"type":"row","settings":{"benefit":"Overbelastingsbeveiliging","us":true,"others":false}},"row_qmB7DE":{"type":"row","settings":{"benefit":"Kabelbende","us":false,"others":true}}},"block_order":["row_JrRBw6","row_r6nHWV","row_aJHnEM","row_qmB7DE"],"disabled":true,"custom_css":[],"settings":{"title":"Waarom deze stekkerdoos?","heading_size":"h2","text":"","button_label":"","link":"","button_style_secondary":false,"color_scheme":"background-1","layout":"table_second","us_label":"ROOLO","logo_width":90,"mobile_logo_width":60,"others_label":"Standaard","checkmark_color":"#53af01","padding_top":36,"padding_bottom":36}},"image_with_text_83VBKw":{"type":"image-with-text","blocks":{"heading_D76Azt":{"type":"heading","settings":{"heading_size":"h2"}},"text_Ai844A":{"type":"text","settings":{"text":"<p>Natuurlijke ingrediënten voeden en versterken je haar<strong> zonder schadelijke bijwerkingen.<\/strong> Ze bieden duurzame resultaten en zorgen voor gezonder, glanzender haar.<\/p>","text_style":"body"}}},"block_order":["heading_D76Azt","text_Ai844A"],"settings":{"image":"shopify:\/\/shop_images\/Zwart_Sesamzaad_Extract.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"comparison_slider_QPJKRK":{"type":"comparison-slider","settings":{"title":"Bewezen Resultaat","heading_size":"h1","text":"<p>Onze shampoo herstelt zichtbaar je natuurlijke haarkleur en vermindert grijs haar, allemaal zonder <strong>schadelijke chemische toevoegingen.<\/strong> Ervaar de kracht van natuurlijke ingrediënten voor gezond en glanzend haar.<\/p>","button_label":"","link":"","button_style_secondary":false,"color_scheme":"background-1","layout":"slider_second","before_label":"Voor GreyAway","after_label":"Na GreyAway","labels_color_scheme":"accent-1","line_color":"background-1","before_image":"shopify:\/\/shop_images\/voor_hd.png","after_image":"shopify:\/\/shop_images\/na_hd.png","padding_top":12,"padding_bottom":12}},"image_w