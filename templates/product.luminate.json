dding_bottom":8}},"testimonials_cfdjrq":{"type":"testimonials","blocks":{"column_jq9wpf":{"type":"column","settings":{"title":"","text":"<p><em>Perfect voor mijn zaak! De lamp heeft een lange levensduur en creëert een geweldige sfeer die mijn klanten echt waarderen.<\/em><\/p>","author":"Danny H."}},"column_KGQXyb":{"type":"column","settings":{"title":"","text":"<p><em>Deze lamp is een stijlvolle toevoeging aan mijn woonkamer. De touchbediening werkt soepel, en ik vind het geweldig dat ik kan schakelen tussen warm en helder licht.<\/em><\/p>","author":"Maria S."}},"column_YafX7J":{"type":"column","settings":{"title":"","text":"<p><em>Zeer tevreden met mijn aankoop. De lamp is eenvoudig te bedienen en past prachtig bij mijn moderne interieur. Echt een aanrader!<\/em><\/p>","author":"Sander V."}}},"block_order":["column_jq9wpf","column_KGQXyb","column_YafX7J"],"settings":{"title":"Wat onze klanten zeggen","heading_size":"h1","text":"","color_scheme":"background-1","image_width":"full","image_ratio":"square","column_alignment":"center","show_stars":true,"show_quotes":true,"columns_desktop":3,"padding_top":36,"padding_bottom":36}},"3d07fd2e-22b5-4988-88fb-ca0b0e7cb741":{"type":"collapsible-content","blocks":{"template--20404861862212__3d07fd2e-22b5-4988-88fb-ca0b0e7cb741-collapsible_row-1":{"type":"collapsible_row","settings":{"heading":"Product specificaties","icon":"none","row_content":"<p><strong>Dimbaar:<\/strong>Ja, in drie stappen<br\/><strong>Certificaat: <\/strong>CE<br\/><strong>Stroombron: <\/strong>LED<br\/><strong>Maximaal vermogen:<\/strong>5W<br\/><strong>Spanning:<\/strong>5V<br\/><strong>Grootte: <\/strong>21cm (hoogte) x 9cm (breedte)<\/p>","page":""}}},"block_order":["template--20404861862212__3d07fd2e-22b5-4988-88fb-ca0b0e7cb741-collapsible_row-1"],"disabled":true,"settings":{"caption":"","heading_size":"h1","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":f