ck.children.length;\n    const maxIndex = totalSlides - visibleSlides;\n\n    currentIndex += direction;\n    if (currentIndex < 0) currentIndex = 0;\n    if (currentIndex > maxIndex) currentIndex = maxIndex;\n\n    updateCarousel();\n  }\n\n  window.addEventListener('load', updateCarousel);\n  window.addEventListener('resize', updateCarousel);\n<\/script>","color_scheme":"background-1","padding_top":0,"padding_bottom":0}},"icons_with_content_JqtgNf":{"type":"icons-with-content","blocks":{"icon_Qp3x8K":{"type":"icon","settings":{"icon":"lock","image":"shopify:\/\/shop_images\/icons8-magnet-100_1.png","title":"Overal te Bevestigen","text":"<p>Dankzij de krachtige magneet klik je de speaker eenvoudig vast aan metaal – van telefoon tot fietsframe.<\/p>"}},"icon_ABhMG8":{"type":"icon","settings":{"icon":"check_mark","title":"Draadloze stereo pairing","text":"<p>Verbind twee speakers voor een echte stereo-ervaring zonder kabels.<\/p>"}},"icon_pJrNwr":{"type":"icon","settings":{"icon":"washing","title":"Compact & draagbaar","text":"<p>Klein formaat, groots geluid – past in elke tas of jaszak.<\/p>"}},"heading_NYGLtc":{"type":"heading","settings":{"heading_size":"h2"}},"text_XVeWdm":{"type":"text","settings":{"text":"","text_style":"body"}},"icon_7GhkVN":{"type":"icon","settings":{"icon":"box","image":"shopify:\/\/shop_images\/icons8-battery-100.png","title":"Lange batterijduur","text":"<p>Tot wel 6 uur afspeeltijd op één lading – neem ‘m overal mee zonder zorgen.<\/p>"}},"icon_LHwgNE":{"type":"icon","settings":{"icon":"box","image":"shopify:\/\/shop_images\/icons8-water-100_1.png","title":"Waterdicht design","text":"<p>Ideaal voor gebruik in de keuken, badkamer of buiten op het terras.<\/p>"}},"icon_eJbWDE":{"type":"icon","settings":{"icon":"box","image":"shopify:\/\/shop_images\/icons8-bluetooth-100.png","title":"Universele compatibiliteit","text":"<p>Werkt met alle Bluetooth-apparaten zoals smartphones, tablets, laptops en meer.<\/p>"}}},"block_order":["icon_Qp3x8K","ic