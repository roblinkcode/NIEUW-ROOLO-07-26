pagination":"dots_overlay","trust_badge":"shopify:\/\/shop_images\/SALE-removebg-preview.png","trust_badge_position":"top-right","trust_badge_size":"medium"}},"fb5ad6ac-1898-431f-b29d-f6d26831fba9":{"type":"collapsible-content","blocks":{"template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-1":{"type":"collapsible_row","settings":{"heading":"Specificaties","icon":"none","row_content":"<p><strong>Dimbaar:<\/strong>Ja, in drie stappen<br\/><strong>Stroombron: <\/strong>LED<br\/><strong>Maximaal vermogen:<\/strong>5W<br\/><strong>Oplaadbaar: <\/strong>USB-C (Meegeleverd)<br\/><strong>Grootte: <\/strong>21cm (hoogte) x 9cm (breedte)<\/p>","page":""}},"template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-2":{"type":"collapsible_row","settings":{"heading":"Handleiding","icon":"none","row_content":"<p>Zet de lamp aan met de knop aan de onderkant. Dim de lamp met de touchbediening bovenop. Houd de touchbediening ingedrukt om tussen warm, neutraal en wit licht te schakelen.<\/p>","page":""}},"collapsible_row_Rdpy6N":{"type":"collapsible_row","settings":{"heading":"Bulk Korting 📦","icon":"none","row_content":"<p>Profiteer van extra voordeel bij grotere bestellingen! Wanneer je <strong>10 of meer<\/strong> Lumino Tafellampen koopt, wordt automatisch een <strong>10% korting<\/strong> toegepast in je winkelmandje. Perfect voor restaurants, kantoren of grote ruimtes!<\/p>","page":""}},"template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-3":{"type":"collapsible_row","disabled":true,"settings":{"heading":"Opladen","icon":"lightning_bolt","row_content":"<p>Laad eenvoudig op via de meegeleverde USB-C-kabel voor ruim 48 uur ononderbroken verlichting. Bij de Karakter Lamp staat niet alleen het voortreffelijke ontwerp centraal, maar ook jouw veiligheid. Onze lampen worden aangedreven door een beveiligde batterij met geavanceerde overstroomtechnologie, wat voldoet aan explosieveilige en vlambestendige veiligheidsnormen<\/p>","page":""}}},"block_order":["template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-1","template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-2","collapsible_row_Rdpy6N","template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-3"],"settings":{"caption":"","heading_size":"h1","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":0,"padding_bottom":8}},"testimonials_cfdjrq":{"type":"testimonials","blocks":{"column_jq9wpf":{"type":"column","settings":{"title":"","text":"<p>De Lumino Tafellamp voegt een stijlvolle touch toe aan mijn restaurant en biedt een warme, uitnodigende verlichting. Het is precies wat we nodig hadden om de sfeer te verbeteren!<\/p>","author":"Tom S."}},"column_KGQXyb":{"type":"column","settings":{"title":"","text":"<p>De lamp is precies wat ik zocht. Het geeft een mooi, warm licht en de draadloze oplader werkt perfect. Zeker een aanrader voor elke kamer!<\/p>","author":"Mark B."}},"column_YafX7J":{"type":"column","settings":{"title":"","text":"<p>Deze lamp is fantastisch! Het moderne ontwerp voegt echt iets toe aan mijn interieur, en de draadloze oplader is een geweldige extra. Ik ben absoluut tevreden met mijn aankoop!<\/p>","author":"Laura V."}}},"block_order":["column_jq9wpf","column_KGQXyb","column_YafX7J"],"settings":{"title":"Wat onze klanten zeggen","heading_size":"h1","text":"","color_scheme":"background-1","image_width":"full","image_ratio":"square","column_alignment":"center","show_stars":true,"show_quotes":true,"columns_desktop":3,"padding_top":36,"padding_bottom":36}},"3d07fd2e-22b5-4988-88fb-ca0b0e7cb741":{"type":"collapsible-content","blocks":{"template--20404861862212__3d07fd2e-22b5-4988-88fb-ca0b0e7cb741-collapsible_row-1":{"type":"collapsible_row","settings":{"heading":"Product specificaties","icon":"none","row_content":"<p><strong>Dimbaar:<\/strong>Ja, in drie stappen<br\/><strong>Certificaat: <\/strong>CE<br\/><strong>Stroombron: <\/strong>LED<br\/><strong>Maximaal vermogen:<\/strong>5W<br\/><strong>Spanning:<\/strong>5V<br\/><strong>Grootte: <\/strong>21cm (hoogte) x 9cm (breedte)<\/p>","page":""}}},"block_order":["template--20404861862212__3d07fd2e-22b5-4988-88fb-ca0b0e7cb741-collapsible_row-1"],"disabled":true,"settings":{"caption":"","heading_size":"h1","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":0,"padding_bottom":4}},"related-products":{"type":"related-products","disabled":true,"settings":{"heading_size":"h2","products_to_show":4,"columns_desktop":4,"color_scheme":"background-1","image_ratio":"adapt","show_secondary_image":false,"show_vendor":false,"show_rating":false,"columns_mobile":"2","padding_top":36,"padding_bottom":24}},"7c2381c3-1795-445b-91da-9765523b1638":{"type":"image-with-text","blocks":{"caption_BRUVwh":{"type":"caption","settings":{"caption":"ALLROUND","text_style":"caption-with-letter-spacing","text_size":"medium"}},"heading_eQajNd":{"type":"heading","settings":{"heading_size":"h1"}},"template--19900162113860__7c2381c3-1795-445b-91da-9765523b1638-text-1":{"type":"text","settings":{"text":"<p>Of je nu je woning verfraait of sfeer wilt creëren in je restaurant of bar, deze lamp is een veelzijdig accessoire. Gebruik hem als <strong>tafellamp, nachtkastlampje of sfeervolle toevoeging<\/strong> in elke ruimte.<\/p>","text_style":"body"}}},"block_order":["caption_BRUVwh","heading_eQajNd","template--19900162113860__7c2381c3-1795-445b-91da-9765523b1638-text-1"],"settings":{"image":"shopify:\/\/shop_images\/gif_1_c91236b2-8666-46ad-b80a-cb4de1df92eb.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"7ead9d52-a3ce-4f63-9e00-e5fbe252c5a8":{"type":"image-with-text","blocks":{"caption_MeYD8U":{"type":"caption","settings":{"caption":"WHY LUMINO?","text_style":"caption-with-letter-spacing","text_size":"medium"}},"heading_JLkj7e":{"type":"heading","settings":{"heading_size":"h2"}},"9bd8fb44-fa40-449d-be77-8f37af118496":{"type":"text","settings":{"text":"<h3><\/h3><p><strong>Sfeervol Licht:<\/strong> Creëert een warme en gezellige ambiance.<\/p><p><strong>Warm & Wit Licht: <\/strong>Kies eenvoudig tussen warm & wit licht, brengt sfeer in elke ruimte.<\/p><p><strong>Dimbaar:<\/strong> Kies tussen 3 opties van zacht tot fel licht, eenvoudig met Touch-bediening<\/p><p><strong>Duurzaam Materiaal:<\/strong> Gemaakt van hoogwaardig en langdurig metaal.<\/p><p><strong>Draadloos:<\/strong> Voeg overal extra licht toe waar nodig.<\/p>","text_style":"body"}}},"block_order":["caption_MeYD8U","heading_JLkj7e","9bd8fb44-fa40-449d-be77-8f37af118496"],"settings":{"image":"shopify:\/\/shop_images\/gif_2_cd177472-f957-465d-811d-6fb7c9d80da6.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"2cb68c65-93ce-4030-a625-5bac24b42fe4":{"type":"image-with-text","blocks":{"caption_W9Mt9x":{"type":"caption","settings":{"caption":"SUSTAINABILITY","text_style":"caption-with-letter-spacing","text_size":"medium"}},"heading_gGLCbq":{"type":"heading","settings":{"heading_size":"h1"}},"f1d0c312-6e0a-443f-a521-b731697ad34f":{"type":"text","settings":{"text":"<p>De Lumino Tafellamp gebruikt zuinige<strong> <\/strong>LED-lampen, waardoor je <strong>geld bespaart<\/strong> op energiekosten en je steentje bijdraagt aan het milieu.<\/p>","text_style":"body"}}},"block_order":["caption_W9Mt9x","heading_gGLCbq","f1d0c312-6e0a-443f-a521-b731697ad34f"],"settings":{"image":"shopify:\/\/shop_images\/goud_gif_89c7974e-2371-4ce6-a9b8-c3b3c3ab452e.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"9f8ed1f4-75b8-4974-842c-754126d14d2b":{"type":"image-with-text","blocks":{"caption_CxKtjU":{"type":"caption","settings":{"caption":"DESIGN","text_style":"subtitle","text_size":"medium"}},"heading_HzfMpD":{"type":"heading","settings":{"heading_size":"h1"}},"17763526-3cb0-4bec-9275-ca6d59d9a612":{"type":"text","settings":{"text":"<h3><\/h3><p>De luxueuze Lumino Tafellamp kenmerkt zich door een elegant en opvallend ontwerp. Het strakke silhouet en de <strong>hoogwaardige materialen<\/strong> vormen een perfecte aanvulling voor elke woning, hotel of restaurant.<\/p>","text_style":"body"}}},"block_order":["caption_CxKtjU","heading_HzfMpD","17763526-3cb0-4bec-9275-ca6d59d9a612"],"settings":{"image":"shopify:\/\/shop_images\/zilver_igf_1bc2c7b2-8743-4cb9-8e2c-05b762853ac6.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"2648bdb5-948c-44fc-9d7c-2989165abaac":{"type":"multicolumn","blocks":{"template--20489622749508__2648bdb5-948c-44fc-9d7c-2989165abaac-column-1":{"type":"column","settings":{"title":"30 DAGEN RETOURGARANTIE","text":"<p>Wij bieden een retourgarantie van 30 dagen - Niet tevreden, geld terug!<\/p>","link_label":"","link":""}},"template--20489622749508__2648bdb5-948c-44fc-9d7c-2989165abaac-column-2":{"type":"column","disabled":true,"settings":{"title":"GRATIS VERZENDING VANAF €20","text":"<p>Bij een aankoop vanaf €20 nemen wij de verzendkosten voor onze rekening.<