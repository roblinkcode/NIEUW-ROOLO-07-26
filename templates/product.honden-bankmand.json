order":["template--18472096170313__03c08e95-f0ce-4379-bc05-787da4136202-1679864525e35c34e4-0","template--18472096170313__03c08e95-f0ce-4379-bc05-787da4136202-1679864525e35c34e4-1","template--18472096170313__03c08e95-f0ce-4379-bc05-787da4136202-1679864525e35c34e4-2"],"settings":{"speed":1.5,"color_scheme":"background-2","italic_text":false,"uppercase_text":false,"bold_text":false}},"related-products":{"type":"related-products","disabled":true,"settings":{"heading_size":"h2","products_to_show":4,"columns_desktop":4,"color_scheme":"background-1","image_ratio":"adapt","show_secondary_image":false,"show_vendor":false,"show_rating":false,"columns_mobile":"2","padding_top":36,"padding_bottom":24}},"7c2381c3-1795-445b-91da-9765523b1638":{"type":"image-with-text","blocks":{"template--19900162113860__7c2381c3-1795-445b-91da-9765523b1638-text-1":{"type":"text","settings":{"text":"<h1>Ben je de haren & vlekken op de bank zat?<\/h1><p>Onze Dog Bankbed. meubelbeschermer beschermt je bank, bed of auto en bied je viervoeter een comfortabele plek om uit te rusten en te slapen.<\/p><p>✅ Comfortabel en diervriendelijk materiaal<\/p><p>✅ Angstremmende eigenschappen kalmeren je viervoeter<\/p><p>✅ Opstaande rand - zorgt voor comfortabel gevoel en een veilig gevoel<\/p><p>✅ Afneembare en wasbare hoes<\/p><p>✅ Waterdichte basis - voorkomt vlekken<\/p><p>Honden slapen ongeveer 15-20 uur per dag en je kan het ze zo comfortabel mogelijk maken met onze bankbeschermers om ze een nog gelukkiger en mooier leven te geven<\/p>","text_style":"body"}}},"block_order":["template--19900162113860__7c2381c3-1795-445b-91da-9765523b1638-text-1"],"settings":{"image":"shopify:\/\/shop_images\/Hoofd_Neksteun.jpg","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"af19ca60-4102-40cc-8748-150b1134b815":{"type":"image-with-text","blocks":{"c1ca2190-fd6d-47af-9e42-242ff72be93e":{"type":"text","settings":{"text":"<h4><strong>Maat Tabel<\/strong><\/h4><h4><\/h4><p><strong>Zorg ervoor dat u goed de maattabel bekijkt, zodat je precies weet wat past in jouw huis!<\/strong><\/p>","text_style":"body"}}},"block_order":["c1ca2190-fd6d-47af-9e42-242ff72be93e"],"settings":{"image":"shopify:\/\/shop_images\/Scherm_afbeelding_2023-12-05_om_16.26.24.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"7ead9d52-a3ce-4f63-9e00-e5fbe252c5a8":{"type":"image-with-text","blocks":{"9bd8fb44-fa40-449d-be77-8f37af118496":{"type":"text","settings":{"text":"<p><strong>Ongelooflijk comfortabel:<\/strong> het zachte kunstbont doet denken aan de vacht van de hond zij\/haar moeder. Het helpt je​​hond te kalmeren en goed te slapen.<\/p><p><strong>Stijlvol:<\/strong> vergeleken met beddengoed of verouderde meubelbeschermers zijn onze bankbeschermers ontworpen met lichte of donkere kleuren, zodat ze in elke ruimte passen.<\/p><p><strong>Gemakkelijk schoon te maken:<\/strong> we hebben de meubelbeschermer zo ontworpen dat hij volledig afneembaar en machine wasbaar is. Gooi hem eenvoudig in de wasmachine om haren, vlekken en vuil te verwijderen.<\/p>","text_style":"body"}}},"block_order":["9bd8fb44-fa40-449d-be77-8f37af118496"],"settings":{"image":"shopify:\/\/shop_images\/gif_2_vertaald_eac57831-2069-4cda-887b-557d017500c9.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"9f8ed1f4-75b8-4974-842c-754126d14d2b":{"type":"image-with-text","blocks":{"96069707-1f6a-4405-b46e-521e47f44ce0":{"type":"text","settings":{"text":"","text_style":"body"}}},"block_order":["96069707-1f6a-4405-b46e-521e47f44ce0"],"settings":{"image":"shopify:\/\/shop_images\/gif_1_c084d45f-ff1d-4aec-8f1a-38b7aabfeed3.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"middle","desktop_content_alignment":"center","mobile_content_alignment":"left"}},"fc7f31b1-4af5-4037-bf99-12ffff6d102e":{"type":"collapsible-content","blocks":{"template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-1":{"type":"collapsible_row","settings":{"heading":"Eigenschappen","icon":"none","row_content":"<p><strong>Materiaal (hoes):<\/strong> nepbont<\/p><p><strong>Materiaal (vulling):<\/strong> PP\/katoen<\/p><p><strong>Maat:<\/strong> zie maattabel (+\/-10%)<\/p><p><strong>Kleur:<\/strong> grijswit, donkergrijs, beige, bruin\/wit (mix), grijs\/wit (mix), koebruin, koe zwart;<\/p><p><strong>Kleur onderkant:<\/strong> zwart of beige; vanaf 7 juni 2022 “grijs”<\/p><p><strong>Gebruik op leren bank:<\/strong> Controleer bij licht leer eerst of er verkleuring is voordat je het gebruikt - bij licht leer kan verkleuring optreden. Wij aanvaarden geen aansprakelijkheid voor verkleuringen op wit\/licht leer.<\/p>","page":""}},"template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-3":{"type":"collapsible_row","settings":{"heading":"Volledig waterdicht","icon":"none","row_content":"<p><\/p><p><strong>Volledig waterdicht:<\/strong> onze originele Dog Bankbed meubelbeschermer is uitgerust met een volledig waterdichte en antislipvoering, zodat je hem op elk oppervlak of materiaal kan plaatsen terwijl jij stressvrij blijft en weet dat je meubels beschermd zijn tegen mogelijke \"huisdierongelukken\".<\/p>","page":""}},"1d58c5a0-6e10-403f-8e06-43755aae506d":{"type":"collapsible_row","settings":{"heading":"Anti Angst","icon":"none","row_content":"<p><strong>Anti-angst eigenschappen:<\/strong> het goed gevulde buitenkussen zorgt ervoor dat je hond zich veilig en comfortabel voelt, waarbij het zachte bontmateriaal de aanraking van de moeder nabootst.<\/p><p>Deze rustgevende combinatie zorgt voor een gevoel van geborgenheid en ontspant het zenuwstelsel, met als resultaat een ontspannen, comfortabele en gezond slapende hond. En een blije hond betekent een blij, stressvrij baasje!<\/p>","page":""}},"template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-4":{"type":"collapsible_row","settings":{"heading":"Ongelofelijk Comfortabel","icon":"none","row_content":"<p>Het zachte imitatiebont doet denken aan de vacht van de moeder. Het helpt je hond te ontspannen en heerlijk te gaan slapen!<\/p>","page":""}},"f0e0fef8-d8ca-401a-a686-099a489e1c5a":{"type":"collapsible_row","settings":{"heading":"Makkelijk schoon te maken","icon":"none","row_content":"<p>We hebben de meubelbeschermer zo ontworpen dat hij volledig afneembaar en machine wasbaar is. Gooi hem eenvoudig in de wasmachine om haren, vlekken en vuil te verwijderen.<\/p>","page":""}}},"block_order":["template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-1","template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-3","1d58c5a0-6e10-403f-8e06-43755aae506d","template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-4","f0e0fef8-d8ca-401a-a686-099a489e1c5a"],"settings":{"caption":"","heading_size":"h2","heading_alignment":"left","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":36,"padding_bottom":36}},"66b6d233-ac90-40ab-87d7-9d5df4d7260c":{"type":"rich-text","blocks":{"template--19884972900676__66b6d233-ac90-40ab-87d7-9d5df4d7260c-text-1":{"type":"text","settings":{"text":"<h3>WAT KLANTEN OVER ONZE Dog Bankbed. ZEGGEN:<br\/><\/h3><p>Nog niet overtuigd? Roolo heeft inmiddels ruim  <strong>4200+ tevreden klanten<\/strong>  en dat aantal groeit elke dag! <strong>Dit is wat klanten schrijven over onze Bankbed:<\/strong>  <\/p><p><\/p>"}}},"block_order":["template--19884972900676__66b6d233-ac90-40ab-87d7-9d5df4d7260c-text-1"],"settings":{"desktop_content_position":"left","content_alignment":"left","full_width":true,"color_scheme":"background-1","padding_top":40,"padding_bottom":0}},"73c5de8e-7b83-4813-8812-d56eb3a987a3":{"type":"horizontal-ticker","blocks":{"template--18472096170313__73c5de8e-7b83-4813-8812-d56eb3a987a3-1679864525e35c34e4-0":{"type":"text","settings":{"title":"SALE"}},"template--18472096170313__73c5de8e-7b83-4813-8812-d56eb3a987a3-1679864525e35c34e4-1":{"type":"text","settings":{"title":"SALE"}},"template--18472096170313__73c5de8e-7b83-4813-8812-d56eb3a987a3-1679864525e35c34e4-2":{"type":"text","settings":{"title":"SALE"}}},"block_order":["template--18472096170313__73c5de8e-7b83-4813-8812-d56eb3a987a3-1679864525e35c34e4-0","template--18472096170313__73c5de8e-7b83-4813-8812-d56eb3a987a3-1679864525e35c34e4-1","template--18472096170313__73c5de8e-7b83-4813-8812-d56eb3a987a3-1679864525e35c34e4-2"],"disabled":true,"settings":{"speed":2,"color_scheme":"inverse","italic_text":false,"uppercase_text":false,"bold_text":false}},"1694520940915c1b12":{"type":"apps","blocks":{"0eb9aa84-d0ef-49a2-bc40-9002dcad3f09":{"type":"shopify:\/\/apps\/judge-me-reviews\/blocks\/review_widget\/61ccd3b1-a9f2-4160-9fe9-4fec8413e5d8","settings":{}}},"block_order":["0eb9aa84-d0ef-49a2-bc40-9002dcad3f09"],"settings":{"include_margins":true}},"6d7894b2-cf7c-4e79-a8dd-744468084387":{"type":"collapsible-content","blocks":{"template--20036883218756__6d7894b2-cf7c-4e79-a8dd-744468084387-collapsible_row-1":{"type":"collapsible_row","settings":{"heading":"Geweldige Klantenservice","icon":"question_mark","row_content":"<p>Onze klantenservice staat dag en nacht klaar om je te helpen met al je vragen en om te helpen met de bestelling.<\/p>","page":""}},"template--20036883218756__6d7894b2-c