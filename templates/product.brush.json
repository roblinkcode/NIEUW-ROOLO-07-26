_ALLE_OPPERVLAKKEN.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"00d179fe-24aa-4793-8c4a-66bc27ffb24b":{"type":"rich-text","blocks":{"template--19660118655300__00d179fe-24aa-4793-8c4a-66bc27ffb24b-text-1":{"type":"text","settings":{"text":"<h3>Meer tijd voor familie en vrienden!<\/h3><p>Onze Power-Brush maakt het <strong>huishoudelijk <\/strong>werk veel makkelijker en verwijderd <strong>zonder moeite het hardnekkigste vuil. <\/strong>Perfect voor in de <strong>keuken, badkamer of om je schoenen schoon te maken! <\/strong><br\/>Geleverd met <strong>diverse opzetstukken<\/strong> en een <strong>krachtige motor <\/strong>is het een betrouwbare hulp in huis en bespaard het u veel tijd! Dit zorgt voor meer tijd met vrienden en familie.<\/p>"}}},"block_order":["template--19660118655300__00d179fe-24aa-4793-8c4a-66bc27ffb24b-text-1"],"settings":{"desktop_content_position":"left","content_alignment":"left","full_width":true,"color_scheme":"background-1","padding_top":8,"padding_bottom":0}},"76b1ca4f-4638-4370-80da-21091c49cfd6":{"type":"image-with-text","settings":{"image":"shopify:\/\/shop_images\/gif_goed.gif","height":"medium","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"60b34cf8-6e04-4b5d-bbd8-82ccbf135e92":{"type":"rich-text","blocks":{"template--19660118655300__60b34cf8-6e04-4b5d-bbd8-82ccbf135e92-text-1":{"type":"text","settings":{"text":"<h3>Waterdicht!<\/h3><p>De Power-Brush is <strong>waterdicht <\/strong>en kan daarom zonder zorgen in de badkamer of keuken gebruikt worden. Met het <strong>veelzijdig assortiment van opzetstukken<\/strong> wordt het schoonmaken van plekken en voorwerpen ee