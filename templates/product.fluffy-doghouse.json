gs":{"include_margins":true}},"af19ca60-4102-40cc-8748-150b1134b815":{"type":"image-with-text","blocks":{"template--20144669000004__af19ca60-4102-40cc-8748-150b1134b815-text-1":{"type":"text","settings":{"text":"<p><strong>Wat maakt onze Pethouse bijzonder?<\/strong><\/p><p>🌡 <strong>Houdt je viervoeter warm<\/strong><br\/>Dankzij het zachte materiaal blijft jouw trouwe viervoeter warm bij koude temperaturen<\/p><p>🧼 <strong>Gemakkelijk schoon te maken<br\/><\/strong>Onze Pethouse kan eenvoudig worden gewasssen met de handwas of worden gestofzuigd en het kussen is wasbaar in de wasmachine!<\/p><p><strong>Waterafstotende Bodem<br\/><\/strong>Voorkomt vlekken op de vloer!<\/p><p><strong>Vermindert angst en stress<br\/><\/strong>Onze Pethouse is een veilig toevluchtsoord en vermindert angst en stress.<\/p>","text_style":"body"}}},"block_order":["template--20144669000004__af19ca60-4102-40cc-8748-150b1134b815-text-1"],"settings":{"image":"shopify:\/\/shop_images\/gif_2_caaa81bb-a027-4cb4-9d84-2969b23eaa4c.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"middle","desktop_content_alignment":"center","mobile_content_alignment":"left"}},"c7d24897-a474-4427-af59-cb907d3e6552":{"type":"image-with-text","blocks":{"template--20348838248772__c7d24897-a474-4427-af59-cb907d3e6552-text-1":{"type":"text","settings":{"text":"<p><strong>Maattabel<\/strong><\/p><p>Bekijk goed de afmetingen van onze Doghouse om er zeker van te zijn welke maat geschikt is voor jouw viervoeter!<\/p><p><strong>Bij twijfel tussen Medium en Large raden wij aan om voor de grotere maat te kiezen.<\/strong><\/p>","text_style":"body"}}},"block_order":["template--20348838248772__c7d24897-a474-4427-af59-cb907d3e6552-text-1"],"settings":{"image":"shopify:\/\/shop_images\/Fluffy_huis_voor.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"n