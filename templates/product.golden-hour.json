ible_row-1":{"type":"collapsible_row","settings":{"heading":"Product details","icon":"none","row_content":"<p>✔️ Maximale hoogte: 27cm (10.6\")<br\/>✔️ Diameter: 9cm (3,5\")<br\/>✔️ Aansluiting: USB kabel<\/p>","page":""}},"template--19824013181252__0d26c25c-0fbf-4001-bf7b-9d8158d6e8e2-collapsible_row-2":{"type":"collapsible_row","settings":{"heading":"Meegeleverd","icon":"none","row_content":"<p>- 1x Golden Hour<br\/>- 1x USB Kabel<\/p>","page":""}},"template--19824013181252__0d26c25c-0fbf-4001-bf7b-9d8158d6e8e2-collapsible_row-3":{"type":"collapsible_row","disabled":true,"settings":{"heading":"Collapsible row","icon":"check_mark","row_content":"","page":""}},"template--19824013181252__0d26c25c-0fbf-4001-bf7b-9d8158d6e8e2-collapsible_row-4":{"type":"collapsible_row","disabled":true,"settings":{"heading":"Collapsible row","icon":"check_mark","row_content":"","page":""}}},"block_order":["template--19824013181252__0d26c25c-0fbf-4001-bf7b-9d8158d6e8e2-collapsible_row-1","template--19824013181252__0d26c25c-0fbf-4001-bf7b-9d8158d6e8e2-collapsible_row-2","template--19824013181252__0d26c25c-0fbf-4001-bf7b-9d8158d6e8e2-collapsible_row-3","template--19824013181252__0d26c25c-0fbf-4001-bf7b-9d8158d6e8e2-collapsible_row-4"],"settings":{"caption":"","heading_size":"h1","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":16,"padding_bottom":36}},"1696256433d9623f43":{"type":"apps","settings":{"include_margins":true}},"2930a9b8-df01-422e-b4c9-bf2fdfdd6815":{"type":"image-with-text","blocks":{"92919f52-114b-494d-8ecd-111afb754bbe":{"type":"text","settings":{"text":"<h2>Transformeer jouw kamer in een stralend paradijs.<\/h2><p>Zonsondergangen zijn romantisch, inspirerend en geschikt voor Instagram, maar toch maken de meeste van ons alleen tijd voor deze bijzondere ervaring als we op vakantie zijn en natuurlijk op de perfecte plek zijn, maar goed nieuws! Je hoeft niet op een exotische plek te zijn om te genieten van de rustgevende, mooie en levens veranderende momenten van een zonsondergang met ons Roolo licht.<\/p>","text_style":"body"}}},"block_order":["92919f52-114b-494d-8ecd-111afb754bbe"],"settings":{"image":"shopify:\/\/shop_images\/gif_1_b2caf76e-41ed-4a59-b601-dc40c06be311.webp","height":"medium","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"middle","desktop_content_alignment":"center","mobile_content_alignment":"center"}},"3c54e43b-aa0d-41d4-af27-634d34fa8224":{"type":"image-with-text","blocks":{"02aa0b06-bc49-4ffa-8d26-bf5262b348b5":{"type":"text","settings":{"text":"<h2>Gewoon aansluiten en projecteren.<\/h2><p>Sluit gewoon de USB-kabel aan en het plezier kan beginnen. Aangedreven door <strong>energiebesparende LED's <\/strong>kunnen onze zonsonderganglampen overdag net zo helder schijnen. Of het nu gaat om een ​​romantische presentatie in de slaapkamer of een ​​unieke gloed in de woonkamer, één ding is zeker: het is een echte showstopper.<\/p>","text_style":"body"}}},"block_order":["02aa0b06-bc49-4ffa-8d26-bf5262b348b5"],"settings":{"image":"shopify:\/\/shop_images\/gif_2.webp","height":"medium","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"middle","desktop_content_alignment":"center","mobile_content_alignment":"center"}},"e11a888d-70bb-40bd-abc8-40d9de74cea1":{"type":"image-with-text","blocks":{"18e8c216-a1e6-441b-9d81-6ca0b4f13198":{"type":"text","settings":{"text":"<h2>Verhef je geest en ziel.<\/h2><p>Verbluffende momenten zoals adembenemende zonsondergangen kunnen je het gevoel geven dat je <strong> <\/strong>meer tijd beschikbaar hebt, geduldiger bent en minder materialistisch zal zijn. <\/p>","text_style":"body"}}},"block_order":["18e8c216-a1e6-441b-9d81-6ca0b4f13198"],"settings":{"image":"shopify:\/\/shop_images\/gif_3.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"middle","desktop_content_alignment":"center","mobile_content_alignment":"center"}},"5633097d-204b-480b-8722-cb766305cb5e":{"type":"image-with-text","blocks":{"template--19810270937412__5633097d-204b-480b-8722-cb766305cb5e-text-1":{"type":"text","settings":{"text":"<h2>Breng jouw selfies, foto's en video's naar een hoger niveau.<\/h2><p>Creëer oogverblindende <strong>licht, schaduw, en kleureffecten<\/strong> voor jouw selfies, foto's en <strong>video's<\/strong>. Creëer een uniek podium voor uw inhoud. De effecten die je kunt creëren zijn grenzeloos wanneer u ze projecteert op <strong>muren, kunst, tafels, voorwerpen, mensen of wat je ook maar kunt bedenken.<\/strong><\/p>","text_style":"body"}}},"block_order":["template--19810270937412__5633097d-204b-480b-8722-cb766305cb5e-text-1"],"settings":{"image":"shopify:\/\/shop_images\/gif_4.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"middle","desktop_content_alignment":"center","mobile_content_alignment":"center"}},"969936d0-0c09-42a2-9a74-0adca06f3c48":{"type":"image-with-text","blocks":{"b3420b38-1d89-493a-8967-9c693ba4b2c4":{"type":"text","settings":{"text":"<h2>Breng je creatieve ideeën tot leven.<\/h2><p>Breng je desktop, gaming-opstelling of werkruimte van nul naar 100! Laat de creatieve sappen stromen met de juiste sfeerverlichting. Sluit de USB-stekker aan en je bent klaar om te gaan!<\/p>","text_style":"body"}}},"block_order":["b3420b38-1d89-493a-8967-9c693ba4b2c4"],"settings":{"image":"shopify:\/\/shop_images\/gif_5.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"middle","desktop_content_alignment":"center","mobile_content_alignment":"center"}},"ac6e05ae-bd85-40ad-8581-06d878cb0ba1":{"type":"image-with-text","blocks":{"template--19824013181252__ac6e05ae-bd85-40ad-8581-06d878cb0ba1-text-1":{"type":"text","settings":{"text":"<h2>Eindeloze Mogelijkheden<\/h2><p>Gebruik het als een unieke nachtlamp, om je nachtkastjes op te fleuren, of plaats ze in de badkamer voor een gemakkelijk te gebruiken (en prettig voor de ogen) licht tijdens die late nachtelijke uitstapjes. Met de <strong>aanraak-aan\/uit<\/strong> en <strong>dimmerknop<\/strong> zul je niet hoeven te prutsen om de lamp aan te zetten. De mogelijkheden zijn werkelijk eindeloos. Jouw enkeltje naar de kosmos wacht op je...<\/p>","text_style":"body"}}},"block_order":["template--19824013181252__ac6e05ae-bd85-40ad-8581-06d878cb0ba1-text-1"],"settings":{"image":"shopify:\/\/shop_images\/geen_gif_6.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"middle","desktop_content_alignment":"center","mobile_content_alignment":"center"}},"2e31870a-4d21-4f80-9fe6-e8d92c878815":{"type":"image-with-text","blocks":{"template--19824013181252__2e31870a-4d21-4f80-9fe6-e8d92c878815-text-1":{"type":"text","settings":{"text":"<h2>Breng sfeer in elke ruimte<\/h2><p>Breng elke ruimte tot leven met l<strong>evendige<\/strong> en <strong>dynamische kleuren.<\/strong><br\/>Zet de toon voor een rustgevende sfeer tijdens filmavonden of voor een indrukwekkende en fotogenieke uitstraling op je volgende feest! De ruime keuze aan kleuren en  zorgt ervoor dat er voor elke stemming en gelegenheid een passend licht is. Je avondroutine is zojuist een stukje leuker geworden.<\/p>","text_style":"body"}}},"block_order":["template--19824013181252__2e31870a-4d21-4f80-9fe6-e8d92c878815-text-1"],"settings":{"image":"shopify:\/\/shop_images\/gif_7.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"middle","desktop_content_alignment":"center","mobile_content_alignment":"center"}},"9f8ed1f4-75b8-4974-842c-754126d14d2b":{"type":"image-with-text","blocks":{"template--19745443676484__9f8ed1f4-75b8-4974-842c-754126d14d2b-text-1":{"type":"text","settings":{"text":"<p>Met de optionele blaas-functie kan je  eenvoudig spullen schoonmaken zoals bijvoorbeeld je toetsenbord. Je kan alle kleine deeltjes waar je niet bij kan wegblazen en vervolgens wat over blijft opzuigen.<\/p>","text_style":"body"}}},"block_order":["template--19745443676484__9f8ed1f4-75b8-4974-842c-754126d14d2b-text-1"],"disabled":true,"settings":{"image":"shopify:\/\/shop_images\/Een_subtitel_toevoegen_1be3e9c1-b8a9-4ed4-a1fd-ee154ad820fd.gif","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"bed59982-8c6b-4d8a-b1e8-b0490305d5ff":{"type":"image-with-text","blocks":{"template--19745443676484__bed59982-8c6b-4d8a-b1e8-b0490305d5ff-text-1":{"type":"text","settings":{"text":"<p>Onze Handstofzuiger zorgt ervoor dat schoonmaken geen hele klus meer hoeft te zijn, je verwijdert kleine hoeveelheden rommel in een mum van tijd en houdt hiermee je ruimte schoon.<br\/>Naast dat het geweldig is om je auto schoon te houden is het ook perfect snel voor te bereiden op onverwachte gasten of voor het opruimen na het werk. Bespaar tijd en houd alles netjes.<\/p>","text_style":"body"}},"11d2abfa-af10-4557-bb88-ef9a4a875152":{"type":"button","disabled":true,"settings":{"button_label":"KOOP NU","button_link":"shopify:\/\/products\/roolo-handstofzuiger"}}},"block_order":["template--19745443676484__bed59982-8c6b-4d8a-b1e8-b0490305d5ff-text-1","11d2abfa-af10-4557-bb88-ef9a4a875152"],"disabled":true,"se