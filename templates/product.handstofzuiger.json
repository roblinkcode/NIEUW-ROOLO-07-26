tent_layout":"no-overlap","layout":"text_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"27bf48b5-b24a-4a61-a7c6-a8562da2644d":{"type":"rich-text","blocks":{"template--19745443676484__27bf48b5-b24a-4a61-a7c6-a8562da2644d-text-1":{"type":"text","settings":{"text":"<h3>Tijd om die rommel op te ruimen!<\/h3><p>✔️ Moeiteloos schoonmaken<\/p><p>🔌 Zonder kabels<\/p><p>🎯 Precisie op de krapste plekken<\/p><p>👍 Veelzijdige opzetstukken<\/p>"}}},"block_order":["template--19745443676484__27bf48b5-b24a-4a61-a7c6-a8562da2644d-text-1"],"disabled":true,"settings":{"desktop_content_position":"left","content_alignment":"left","full_width":true,"color_scheme":"background-1","padding_top":40,"padding_bottom":52}},"de24fb4a-6554-4965-90c1-7dcc066fc4e3":{"type":"image-with-text","blocks":{"template--19724287574340__de24fb4a-6554-4965-90c1-7dcc066fc4e3-text-1":{"type":"text","settings":{"text":"<h3>Tijd om die rommel op te ruimen!<\/h3><ul><li> Moeiteloos schoonmaken<\/li><li> Zonder kabels<\/li><li> Precisie op de krapste plekken<\/li><li> Veelzijdige opzetstukken<\/li><\/ul>","text_style":"body"}}},"block_order":["template--19724287574340__de24fb4a-6554-4965-90c1-7dcc066fc4e3-text-1"],"settings":{"image":"shopify:\/\/shop_images\/in_porsche.png","height":"medium","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"e11a888d-70bb-40bd-abc8-40d9de74cea1":{"type":"image-with-text","blocks":{"template--19724287574340__e11a888d-70bb-40bd-abc8-40d9de74cea1-text-1":{"type":"text","settings":{"text":"<h3><strong>Ontdek de kracht van ROOLO Handstofzuiger<\/strong><\/h3>","text_style":"body"}}},"block_order":["template--19724287574340__e11a888d-70bb-40bd-abc8-40d9de74cea1-text-1"],"settings":{"image":"shopify:\/\/shop_images\/Scherm_afbeelding_2023-09-22_om_13.59.48.png","height":"large","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"center","mobile_content_alignment":"center"}},"64750dde-6c31-486e-a24f-4c8fc1e07447":{"type":"collapsible-content","blocks":{"template--19660118655300__64750dde-6c31-486e-a24f-4c8fc1e07447-collapsible_row-1":{"type":"collapsible_row","settings":{"heading":"1. HEPA Filter","icon":"none","row_content":"<p>De filters die erbij geleverd worden zijn ontworpen volgens de HEPA-norm. HEPA-filters zijn krachtige filters die 99,9% van vrijwel alle zwevende deeltjes verwijderen, zoals stof, huisstofmijt, schimmels, pollen en bacteriën.<\/p>","page":""}},"template--19660118655300__64750dde-6c31-486e-a24f-4c8fc1e07447-collapsible_row-2":{"type":"collapsible_row","settings":{"heading":"2. Blaas-functie","icon":"none","row_content":"<p>Naast de sterke zuigkracht heeft de stofzuiger ook een krachtige <strong>blaasfunctie<\/strong>, hiermee blaas je op moeilijk bereikbare plekken het vuil weg. Dit maakt de stofzuiger perfect voor het reinigen van auto-interieurs en andere moeilijk bereikbare plekken.<\/p>","page":""}},"template--19660118655300__64750dde-6c31-486e-a24f-4c8fc1e07447-collapsible_row-3":{"type":"collapsible_row","settings":{"heading":"3. Stille Motor","icon":"none","row_content":"<p>In tegenstelling tot andere stofzuigers, werkt onze stofzuiger met <strong>zacht geluid. <\/strong>Dit betekent dat u de stofzuiger kunt gebruiken zonder andere ermee lastig te vallen. Perfect voor het gebruik in woningen, kantoren en andere ruimtes waar harde geluiden storend kan zijn.<\/p>","page":""}},"template--19660118655300__64750dde-6c31-486e-a24f-4c8fc1e07447-collapsible_row-4":{"type":"collapsible_row","settings":{"heading":"4. Zonder Kabels","icon":"none","row_content":"<p>Onze stofzuiger beschikt over een krachtige <strong>batterij<\/strong> die ervoor zorgt dat je zonder onhandige kabels overal bij kan. Je hoeft dus niet bang te zijn dat je over snoeren struikelt of geen stopcontact kan vinden.<\/p>","page":""}}},"block_order":["template--19660118655300__64750dde-6c31-486e-a24f-4c8fc1e07447-collapsible_row-1","template--19660118655300__64750dde-6c31-486e-a24f-4c8fc1e07447-collapsible_row-2","template--19660118655300__64750dde-6c31-486e-a24f-4c8fc1e07447-collapsible_row-3","template--19660118655300__64750dde-6c31-486e-a24f-4c8fc1e07447-collapsible_row-4"],"settings":{"caption":"","heading_size":"h1","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":0,"padding_bottom":36}},"72f2352c-ae66-4cc6-b552-6e6425e9f9d6":{"type":"rich-text","blocks":{"template--19745443676484__72f2352c-ae66-4cc6-b552-6e6425e9f9d6-heading-1":{"type":"heading","settings":{"heading_size":"h2"}}},"block_order":["template--19745443676484__72f2352c-ae66-4cc6-b552-6e6425e9f9d6-heading-1"],"settings":{"desktop_content_position":"center","content_alignment":"center","full_width":true,"color_scheme":"background-1","padding_top":40,"padding_bottom":0}},"9f8ed1f4-75b8-4974-842c-754126d14d2b":{"type":"image-with-text","blocks":{"template--19745443676484__9f8ed1f4-75b8-4974-842c-754126d14d2b-text-1":{"type":"text","settings":{"text":"<p>Met de optionele blaas-functie kan je  eenvoudig spullen schoonmaken zoals bijvoorbeeld je toetsenbord. Je kan alle kleine deeltjes waar je niet bij kan wegblazen en vervolgens wat over blijft opzuigen.<\/p>","text_style":"body"}}},"block_order":["template--19745443676484__9f8ed1f4-75b8-4974-842c-754126d14d2b-text-1"],"settings":{"image":"shopify:\/\/shop_images\/Een_subtitel_toevoegen_1be3e9c1-b8a9-4ed4-a1fd-ee154ad820fd.gif","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_