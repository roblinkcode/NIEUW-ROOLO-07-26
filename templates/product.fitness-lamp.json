en<\/strong><\/p><p><br\/>Dankzij de antidiefstal ritsen, het discrete, slanke ontwerp en de RFID-blokkerende vakken <strong>zijn je waardevolle spullen veilig<\/strong> .<\/p><p><br\/>Rits eenvoudig jouw waardevolle spullen dicht, gooi ze over je schouder en ga op verkenning, wetende dat jouw belangrijkste <strong>spullen veilig en binnen handbereik zijn<\/strong>.<\/p>","page":""}},"template--19900162113860__2be139f8-05a0-4790-a783-2a5f2a2daad0-collapsible_row-3":{"type":"collapsible_row","settings":{"heading":"Geen verzendkosten","icon":"truck","row_content":"<p>Bij ons hoef jij geen verzendkosten te betalen! <\/p>","page":""}},"template--19900162113860__2be139f8-05a0-4790-a783-2a5f2a2daad0-collapsible_row-4":{"type":"collapsible_row","settings":{"heading":"Garantie","icon":"lock","row_content":"<p>Wij hebben een 30 dagen geld-terug garantie. Als je niet tevreden bent kan je contact met ons opnemen en betalen wij het volledige bedrag terug.<br\/><br\/>*Het product moet zich in originele staat bevinden en geen gebruikssporen bevatten.<\/p>","page":""}}},"block_order":["template--19900162113860__2be139f8-05a0-4790-a783-2a5f2a2daad0-collapsible_row-1","template--19900162113860__2be139f8-05a0-4790-a783-2a5f2a2daad0-collapsible_row-2","template--19900162113860__2be139f8-05a0-4790-a783-2a5f2a2daad0-collapsible_row-3","template--19900162113860__2be139f8-05a0-4790-a783-2a5f2a2daad0-collapsible_row-4"],"disabled":true,"settings":{"caption":"","heading_size":"h1","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":36,"padding_bottom":36}},"related-products":{"type":"related-products","disabled":true,"settings":{"heading_size":"h2","products_to_show":4,"columns_desktop":4,"color_scheme":"background-1","image_ratio":"adapt","show_secondary_image":false,"show_vendor":false,"show_rating":false,"columns_mobile":"2"