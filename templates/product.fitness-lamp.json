mage_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"588f6a03-9251-48aa-a934-da38c979a83d":{"type":"collapsible-content","blocks":{"template--20385125597508__588f6a03-9251-48aa-a934-da38c979a83d-collapsible_row-2":{"type":"collapsible_row","settings":{"heading":"Hoe kan ik de lamp van stroom voorzien?","icon":"none","row_content":"<p>In tegenstelling tot conventionele lampen kan hij van stroom worden voorzien via de meegeleverde universele USB-kabel of via 3 x AA-batterijen (niet meegeleverd), waardoor hij er overzichtelijk uitziet en de flexibiliteit heeft om overal in huis geplaatst te worden.<\/p>","page":""}},"template--20385125597508__588f6a03-9251-48aa-a934-da38c979a83d-collapsible_row-4":{"type":"collapsible_row","settings":{"heading":"Kan ik mijn bestelling retourneren als ik niet tevreden ben?","icon":"none","row_content":"<p>Geen probleem! Neem binnen 30 dagen na ontvangst contact op met de klantenservice, dan helpen wij je verder!<\/p>","page":""}},"template--20385125597508__588f6a03-9251-48aa-a934-da38c979a83d-collapsible_row-3":{"type":"collapsible_row","settings":{"heading":"Hoe hoog is de lamp?","icon":"none","row_content":"<p>De Glow Tree is 45cm hoog<\/p>","page":""}}},"block_order":["template--20385125597508__588f6a03-9251-48aa-a934-da38c979a83d-collapsible_row-2","template--20385125597508__588f6a03-9251-48aa-a934-da38c979a83d-collapsible_row-4","template--20385125597508__588f6a03-9251-48aa-a934-da38c979a83d-collapsible_row-3"],"disabled":true,"settings":{"caption":"","heading_size":"h2","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":36,"padding_bottom":36}},"e4394e38-3ec5-4b0f-ad44-21d3ebfbddb6":{"type":"image-with-text","blocks":{"template--20109320978756__e4394e38-3ec5-4b0f-ad44-21d3ebfbddb6-text-1":{"type":"text","settings":{"text":"","text_style":"body"}}},"block_order":["template--20109320978756__e4394e38-3ec5-4b0f-ad44-21d3ebfbddb6-text-1"],"disabled":true,"settings":{"image":"shopify:\/\/shop_images\/afmetingen.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"1257f402-04b3-4e08-93b3-6d6dd0b5f272":{"type":"image-with-text","blocks":{"template--20109320978756__1257f402-04b3-4e08-93b3-6d6dd0b5f272-text-1":{"type":"text","settings":{"text":"<h4>Praktisch ingebouwd harnas voor optimale controle<\/h4><p>Met de Dog Jacket krijgt je hond niet alleen een <strong>warme winterjas<\/strong>, <strong>maar ook een ingebouwd tuigje.<\/strong> Geen aparte halsband meer nodig! Het geïntegreerde harnas biedt comfortabele en veilige controle tijdens het lopen. Jouw hond zit veilig en comfortabel in de jas. Praktisch en stijlvol voor de winter!<\/p>","text_style":"body"}}},"block_order":["template--20109320978756__1257f402-04b3-4e08-93b3-6d6dd0b5f272-text-1"],"disabled":true,"settings":{"image":"shopify:\/\/shop_images\/gif_4_0d76c123-6c4d-4065-9a4d-51e310d5797c.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"debb262c-7966-437e-9293-3d712dea0416":{"type":"image-with-text","blocks":{"template--20109320978756__debb262c-7966-437e-9293-3d712dea0416-text-1":{"type":"text","settings":{"text":"<h4>Gezellige hondenjas met een zachte fleecevoering<\/h4><p>Met onze knusse hondenjas, die een <strong>zachte fleecevoering<\/strong> heeft, kan jouw harige vriend het hele jaar door de natuur verkennen. De jas is speciaal ontworpen om jouw hond te beschermen tegen koude wind en lage temperaturen.<\/p>","text_style":"body"}}},"block_order":["template--20109320978756__debb262c-7966-437e-9293-3d712dea0416-text-1"],"disabled":true,"settings":{"image":"shopify:\/\/shop_images\/gif_5_63ed069c-2c54-48fa-8145-783b67e53542.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"fc7f31b1-4af5-4037-bf99-12ffff6d102e":{"type":"collapsible-content","blocks":{"template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-1":{"type":"collapsible_row","settings":{"heading":"Zijn de jassen waterdicht?","icon":"none","row_content":"<p>Onze jassen hebben een waterafstotende buitenlaag die lichte regen en sneeuw buiten houdt. Ze bieden een zeer goede bescherming tegen vocht.<\/p>","page":""}},"template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-2":{"type":"collapsible_row","settings":{"heading":"Kan de jas in de wasmachine?","icon":"none","row_content":"<p>Ja, je kan de jas wassen in de wasmachine. Volg de wasinstructies op het etiket om een optimale verzorging te garanderen.<\/p>","page":""}},"template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-3":{"type":"collapsible_row","settings":{"heading":"Zijn de jassen geschikt voor alle hondenrassen?","icon":"none","row_content":"<p>Onze jassen zijn verkrijgbaar in verschillende maten en passen op de meeste hondenrassen. Bekijk goed de maattabel om de juiste maat voor jouw hond te kiezen.<\/p>","page":""}},"43f6217f-909e-48c4-a956-cd3983c153ec":{"type":"collapsible_row","settings":{"heading":"Is de jas ook geschikt voor katten?","icon":"none","row_content":"<p>Ja zeker, de jas past ook bij katten, zolang het overeenkomt met de maattabel moet de jas goed passen!<\/p>","page":""}},"template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-4":{"type":"collapsible_row","settings":{"heading":"Kan ik mijn bestelling retourneren als ik niet tevreden ben?","icon":"none","row_content":"<p>Geen probleem! Neem binnen 30 dagen na ontvangst van de jas contact op met onze klantenservice.<\/p>","page":""}}},"block_order":["template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-1","template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-2","template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-3","43f6217f-909e-48c4-a956-cd3983c153ec","template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-4"],"disabled":true,"settings":{"caption":"","heading_size":"h2","heading_alignment":"left","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":36,"padding_bottom":36}},"multicolumn_fAACDz":{"type":"multicolumn","blocks":{"column_C847Qb":{"type":"column","settings":{"title":"Niet tevreden? Geld terug!","text":"<p>Wij staan volledig achter de kwaliteit van onze producten. Mocht je toch niet tevreden zijn, dan bieden we onze <strong>\"niet goed, geld terug garantie\" <\/strong>aan. Jouw tevredenheid is onze prioriteit!<\/p>","link_label":"","link":""}}},"block_order":["column_C847Qb"],"settings":{"title":"","heading_size":"h2","button_label":"","button_link":"","color_scheme":"background-1","image_width":"full","image_ratio":"adapt","column_alignment":"left","columns_desktop":3,"columns_mobile":"1","padding_top":16,"padding_bottom":36}},"collapsible_content_TH9RVB":{"type":"collapsible-content","blocks":{"collapsible_row_6cKHMf":{"type":"collapsible_row","disabled":true,"settings":{"heading":"Hoelang gaat de batterij mee?","icon":"none","row_content":"<p>De batterij van de Lumi-Design Tafellamp gaat ongeveer 8-12 uur mee.<\/p>","page":""}},"collapsible_row_hzDaFH":{"type":"collapsible_row","settings":{"heading":"Kan ik de PumpLight aan fitnessapparatuur bevestigen?","icon":"none","row_content":"<p>Ja, de sterke magnetische basis en de magnetische clip maken het eenvoudig om de PumpLight aan elk metalen oppervlak te bevestigen. Zo krijg je altijd de perfecte lichtinval voor je workouts en foto's.<\/p>","page":""}},"collapsible_row_p7ByyN":{"type":"collapsible_row","settings":{"heading":"Is de PumpLight geschikt voor gebruik buitenshuis?","icon":"none","row_content":"<p>Ja! De PumpLight is waterdicht en robuust, perfect voor outdoor workouts of fotoshoots. Het is bestand tegen zweet, spatwater en lichte regen, waardoor je altijd betrouwbare verlichting hebt, zowel binnen als buiten.<\/p>","page":""}},"collapsible_row_VpntPw":{"type":"collapsible_row","settings":{"heading":"Hoelang gaat de batterij van de PumpLight mee op een volle lading?","icon":"none","row_content":"<p>De ingebouwde 1200mAh batterij biedt 4 tot 6 uur gebruikstijd. Zo kun je ongestoord genieten van je workouts en fotosessies zonder je zorgen te maken over de batterijduur.<\/p>","page":""}}},"block_order":["collapsible_row_6cKHMf","collapsible_row_hzDaFH","collapsible_row_p7ByyN","collapsible_row_VpntPw"],"settings":{"caption":"","heading_size":"h1","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":16,"padding_bottom":16}},"66b6d233-ac90-40ab-87d7-9d5df4d7260c":{"type":"rich-text","blocks":{"template--19884972900676__66b6d233-ac90-40ab-87d7-9d5df4d7260c-text-1":{"type":"text","settings":{"text":"<h3>WAT KLANTEN OVER DE CANCAP ZEGGEN:<\/h3><p><\/p>"}}},"block_order":["template--19884972900676__66b6d233-ac90-40ab-87d7-9d5df4d7260c-text-1"],"disabled":true,"settings":{"desktop_content_position":"center","content_alignment":"left","full_width":true,"color_scheme":"background-1","padding_top":16,"padding_bottom":0}},"1694520940915c1b12":{"type":"apps","blocks":{"0eb9aa84-d