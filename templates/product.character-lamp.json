ay_id":false,"include_margins":true}},"7ead9d52-a3ce-4f63-9e00-e5fbe252c5a8":{"type":"image-with-text","blocks":{"9bd8fb44-fa40-449d-be77-8f37af118496":{"type":"text","settings":{"text":"<p><\/p><p>Karakter Lampen combineren niet alleen stijl met persoonlijkheid, maar zijn ook <strong>energiezuinig en gaan lang mee<\/strong>. Gemaakt van hoogwaardige materialen, garanderen deze lampen <strong>langdurige verlichting in jouw huis. <\/strong><\/p><p>Waarom wachten? Maak vandaag nog een statement met een Karakter Lamp en breng levendigheid in de ruimte! Bovendien is het ook een perfect cadeau voor je dierbaren.<\/p>","text_style":"body"}}},"block_order":["9bd8fb44-fa40-449d-be77-8f37af118496"],"settings":{"display_id":false,"visibility":"always-display","image":"shopify:\/\/shop_images\/800x800pompoen.png","video_autoplay":true,"video_loop":true,"height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","full_desktop_width":false,"content_layout":"no-overlap","desktop_media_width":50,"layout":"text_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_full_media_width":false,"mobile_direction":"normal","mobile_image_quanlity":"2","mobile_content_alignment":"left","mobile_padding_top":0,"mobile_padding_bottom":16,"desktop_padding_top":36,"desktop_padding_bottom":36,"custom_colors_background":"#2e2a39","custom_gradient_background":"","custom_colors_text":"#ffffff","custom_colors_solid_button_background":"#dd1d1d","custom_colors_solid_button_text":"#ffffff","custom_colors_outline_button":"#dd1d1d","custom_section_colors_background":"#ffffff","custom_section_gradient_background":""}},"2cb68c65-93ce-4030-a625-5bac24b42fe4":{"type":"image-with-text","blocks":{"f1d0c312-6e0a-443f-a521-b731697ad34f":{"type":"text","settings":{"text":"<h3>Dimbaar<\/h3><p>De Karakter Lampen<strong> bieden 3 diverse dimstanden, <\/strong>variërend van <strong>warm tot wit licht en van zacht tot fel.<\/strong> Pas eenvoudig de verlichting aan naar jouw voorkeur en creëer de perfecte sfeer voor elke gelegenheid.<\/p>","text_style":"body"}}},"block_order":["f1d0c312-6e0a-443f-a521-b731697ad34f"],"settings":{"display_id":false,"visibility":"always-display","image":"shopify:\/\/shop_images\/5silver.webp","video_autoplay":true,"video_loop":true,"height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","full_desktop_width":false,"content_layout":"no-overlap","desktop_media_width":50,"layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_full_media_width":false,"mobile_direction":"normal","mobile_image_quanlity":"2","mobile_content_alignment":"left","mobile_padding_top":0,"mobile_padding_bottom":16,"desktop_padding_top":36,"desktop_padding_bottom":36,"custom_colors_background":"#2e2a39","custom_gradient_background":"","custom_colors_text":"#ffffff","custom_colors_solid_button_background":"#dd1d1d","custom_colors_solid_button_text":"#ffffff","custom_colors_outline_button":"#dd1d1d","custom_section_colors_background":"#ffffff","custom_section_gradient_background":""}},"fb5ad6ac-1898-431f-b29d-f6d26831fba9":{"type":"collapsible-content","blocks":{"template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-1":{"type":"collapsible_row","settings":{"heading":"Eigenschappen & Details","icon":"clipboard","filled_icon":false,"row_content":"<p>Waar vakmanschap innovatie ontmoet.<br\/><br\/><strong>Behuizing<\/strong>: aluminiumlegering<br\/><strong>Gebruikstijd<\/strong>: 48 Uur<br\/><strong>Licht kleur<\/strong>: 3000K (warm licht) <br\/><strong>Schakelaar<\/strong>: Touch (aanraking) aan de bovenkant<br\/><strong>Oplaadbaar: <\/strong>USB (Meegeleverd)<\/p><p><br\/>Onze Karakter Lampen worden zorgvuldig vervaardigd uit hoogwaardige aluminiumlegering, wat een strak uiterlijk en robuuste duurzaamheid garandeert. Het lamplichaam is vakkundig gevuld met hars voor extra stevigheid, wat resulteert in een gepolijste glans en betrouwbare stabiliteit. Karakter Lampen bieden een unieke mix van stijl en kwaliteit. <\/p><p><strong>Let op:<\/strong> Mr. When wordt geleverd zonder standaard. Het wordt aanbevolen om deze op een steun, zoals een boek, te plaatsen met ondersteuning onder de poten. Zorg ervoor dat hij niet op de rand van een plank staat zonder beensteun.<\/p>","page":""}},"template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-2":{"type":"collapsible_row","settings":{"heading":"Afmetingen","icon":"ruler","filled_icon":false,"row_content":"<p>Mr. Why: 19 x 11 x 12 cm<br\/>Mr. What: 17 x 10 x 13 cm<br\/>Mr. When: 19 x 11 x 12 cm<br\/>Mr. Who: 19 x 11 x 12 cm<br\/>Mr. Where: 17 x 11 x 15 cm <\/p>","page":""}},"template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-3":{"type":"collapsible_row","settings":{"heading":"Opladen","icon":"lightning_bolt","filled_icon":false,"row_content":"<p>Laad eenvoudig op via de meegeleverde USB-C-kabel voor ruim 48 uur ononderbroken verlichting. Bij de Karakter Lamp staat niet alleen het voortreffelijke ontwerp centraal, maar ook jouw veiligheid. Onze lampen worden aangedreven door een beveiligde batterij met geavanceerde overstroomtechnologie, wat voldoet aan explosieveilige en vlambestendige veiligheidsnormen<\/p>","page":""}}},"block_order":["template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-1","template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-2","template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-3"],"settings":{"display_id":false,"visibility":"always-display","caption":"","title":"","title_highlight_color":"#6d388b","heading_size":"h1","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"video_muted_autoplay":true,"image_ratio":"adapt","desktop_layout":"image_second","row_heading_size":"medium","collapse_icon":"carret","display_top_border":true,"padding_top":8,"padding_bottom":8,"custom_colors_background":"#ffffff","custom_gradient_background":"","custom_colors_text":"#2e2a39","custom_contaner_colors_background":"#ffffff","custom_container_gradient_background":"","custom_contaner_colors_text":"#2e2a39"}},"9f8ed1f4-75b8-4974-842c-754126d14d2b":{"type":"image-with-text","blocks":{"96069707-1f6a-4405-b46e-521e47f44ce0":{"type":"text","settings":{"text":"<h4><strong>Onze tevredenheidsgarantie<\/strong><\/h4><p>Omdat we er zo zeker van zijn dat je absoluut dol bent op de<strong> K<\/strong>arakter Lamp, bieden wij een 30-dagen geld terug garantie. Als je om welke reden dan ook niet tevreden bent, kan je eenvoudig contact met ons opnemen en om een volledige terugbetaling vragen.<\/p>","text_style":"body"}}},"block_order":["96069707-1f6a-4405-b46e-521e47f44ce0"],"disabled":true,"settings":{"display_id":false,"visibility":"always-display","image":"shopify:\/\/shop_images\/4goud.webp","video_autoplay":true,"video_loop":true,"height":"medium","color_scheme":"background-1","section_color_scheme":"background-1","full_desktop_width":false,"content_layout":"no-overlap","desktop_media_width":50,"layout":"text_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_full_media_width":false,"mobile_direction":"normal","mobile_image_quanlity":"2","mobile_content_alignment":"left","mobile_padding_top":0,"mobile_padding_bottom":16,"desktop_padding_top":36,"desktop_padding_bottom":36,"custom_colors_background":"#2e2a39","custom_gradient_background":"","custom_colors_text":"#ffffff","custom_colors_solid_button_background":"#dd1d1d","custom_colors_solid_button_text":"#ffffff","custom_colors_outline_button":"#dd1d1d","custom_section_colors_background":"#ffffff","custom_section_gradient_background":""}},"588f6a03-9251-48aa-a934-da38c979a83d":{"type":"collapsible-content","blocks":{"template--20385125597508__588f6a03-9251-48aa-a934-da38c979a83d-collapsible_row-2":{"type":"collapsible_row","s