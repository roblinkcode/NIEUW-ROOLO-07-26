ssen op de meeste hondenrassen. Bekijk goed de maattabel om de juiste maat voor jouw hond te kiezen.<\/p>","page":""}},"43f6217f-909e-48c4-a956-cd3983c153ec":{"type":"collapsible_row","settings":{"heading":"Is de jas ook geschikt voor katten?","icon":"none","filled_icon":false,"row_content":"<p>Ja zeker, de jas past ook bij katten, zolang het overeenkomt met de maattabel moet de jas goed passen!<\/p>","page":""}},"template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-4":{"type":"collapsible_row","settings":{"heading":"Kan ik mijn bestelling retourneren als ik niet tevreden ben?","icon":"none","filled_icon":false,"row_content":"<p>Geen probleem! Neem binnen 30 dagen na ontvangst van de jas contact op met onze klantenservice.<\/p>","page":""}}},"block_order":["template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-1","template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-2","template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-3","43f6217f-909e-48c4-a956-cd3983c153ec","template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-4"],"disabled":true,"settings":{"display_id":false,"visibility":"always-display","caption":"","title":"Collapsible content","title_highlight_color":"#6d388b","heading_size":"h2","heading_alignment":"left","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"video_muted_autoplay":true,"image_ratio":"adapt","desktop_layout":"image_second","row_heading_size":"medium","collapse_icon":"carret","display_top_border":true,"padding_top":36,"padding_bottom":36,"custom_colors_background":"#ffffff","custom_gradient_background":"","custom_colors_text":"#2e2a39","custom_contaner_colors_background":"#ffffff","custom_container_gradient_background":"","custom_contaner_colors_text":"#2e2a39"}},"66b6d233-ac90-40ab-87d7-9d5df4d7260c":{"type":"rich-text","blocks":{"template--19884