    "custom_liquid_6cj8aD": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "{% liquid\n  assign show_lift_faq = false\n\n  if product\n    assign product_title_lower = product.title | downcase\n    assign product_vendor_lower = product.vendor | downcase\n\n    if product_title_lower contains 'lift' or product_vendor_lower contains 'lift'\n      assign show_lift_faq = true\n    endif\n\n    for product_collection in product.collections\n      if product_collection.handle contains 'lift'\n        assign show_lift_faq = true\n      endif\n    endfor\n  else\n    assign show_lift_faq = true\n  endif\n\n  assign support_email = 'info@roolo.nl'\n\n  if request.host contains 'roolo.de'\n    assign support_email = 'info@roolo.de'\n  elsif request.host contains 'getliftwear'\n    assign support_email = 'support@getliftwear.com'\n  endif\n\n  assign lift_faq_id = section.id | default: 'lift-faq'\n%}\n\n{% if show_lift_faq %}\n  <section\n    id=\"LiftFaq-{{ lift_faq_id }}\"\n    class=\"lift-faq\"\n    aria-labelledby=\"LiftFaqHeading-{{ lift_faq_id }}\"\n  >\n    <div class=\"lift-faq__inner\">\n\n      <header class=\"lift-faq__header\">\n        <span class=\"lift-faq__eyebrow\">ALLES OVER LIFT</span>\n\n        <h2 id=\"LiftFaqHeading-{{ lift_faq_id }}\">\n          Veelgestelde vragen\n        </h2>\n\n        <p class=\"lift-faq__intro\">\n          Alles wat je wilt weten over de pasvorm, ingebouwde verhoging,\n          verschillende hoogtes en het dagelijks dragen van LIFT schoenen.\n        </p>\n\n        <div class=\"lift-faq__benefits\" aria-label=\"Belangrijkste voordelen\">\n          <div class=\"lift-faq__benefit\">\n            <span class=\"lift-faq__benefit-icon\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\">\n                <path d=\"M12 19V5M7.5 9.5 12 5l4.5 4.5M7.5 14.5 12 19l4.5-4.5\"/>\n              </svg>\n            </span>\n            <span>Tot +10 cm</span>\n          </div>\n\n          <div class=\"lift-faq__benefit\">\n            <span class=\"lift-faq__benefit-icon\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\">\n                <path d=\"M3.5 15.5c4.2.2 7.1-.8 8.8-3.2l1.6-2.3c.4-.6 1.3-.6 1.7 0 1.2 1.8 2.7 3 4.9 3.7v3.1c0 1.2-1 2.2-2.2 2.2H5.7c-1.2 0-2.2-1-2.2-2.2v-1.3Z\"/>\n                <path d=\"M4 16.2h16\"/>\n              </svg>\n            </span>\n            <span>Ingebouwde lift</span>\n          </div>\n\n          <div class=\"lift-faq__benefit\">\n            <span class=\"lift-faq__benefit-icon\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\">\n                <path d=\"M2.5 12s3.5-5.5 9.5-5.5 9.5 5.5 9.5 5.5-3.5 5.5-9.5 5.5S2.5 12 2.5 12Z\"/>\n                <circle cx=\"12\" cy=\"12\" r=\"2.5\"/>\n              </svg>\n            </span>\n            <span>Natuurlijke look</span>\n          </div>\n\n          <div class=\"lift-faq__benefit\">\n            <span class=\"lift-faq__benefit-icon\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\">\n                <circle cx=\"9\" cy=\"8\" r=\"3\"/>\n                <circle cx=\"16.5\" cy=\"9\" r=\"2.5\"/>\n                <path d=\"M3.5 19c.4-3.6 2.3-5.5 5.5-5.5s5.1 1.9 5.5 5.5M14 14.5c.7-.7 1.6-1 2.7-1 2.4 0 3.8 1.7 4 4.5\"/>\n              </svg>\n            </span>\n            <span>Voor iedereen</span>\n          </div>\n        </div>\n      </header>\n\n      <div class=\"lift-faq__grid\">\n\n        <details class=\"lift-faq__item\" open>\n          <summary>\n            <span>Hoe werken LIFT schoenen?</span>\n            <span class=\"lift-faq__toggle\" aria-hidden=\"true\"></span>\n          </summary>\n\n          <div class=\"lift-faq__answer\">\n            <p>\n              In iedere LIFT schoen is een verhoogd binnenwerk verwerkt.\n              Hierdoor sta je, afhankelijk van de gekozen uitvoering,\n              ongeveer <strong>+4, +6, +8 of +10 cm langer</strong>.\n              De verhoging bevindt zich aan de binnenkant en is van buitenaf\n              niet zichtbaar.\n            </p>\n          </div>\n        </details>\n\n        <details class=\"lift-faq__item\">\n          <summary>\n            <span>Hoe lopen de schoenen?</span>\n            <span class=\"lift-faq__toggle\" aria-hidden=\"true\"></span>\n          </summary>\n\n          <div class=\"lift-faq__answer\">\n            <p>\n              LIFT schoenen lopen als normale sneakers. Het verhoogde\n              binnenwerk ondersteunt je voet en zorgt voor een stabiel gevoel.\n              Bij een hogere variant kan het de eerste paar keer even wennen\n              zijn, maar de meeste dragers raken hier snel aan gewend.\n            </p>\n          </div>\n        </details>\n\n        <details class=\"lift-faq__item\">\n          <summary>\n            <span>Voelt de ingebouwde verhoging hard aan?</span>\n            <span class=\"lift-faq__toggle\" aria-hidden=\"true\"></span>\n          </summary>\n\n          <div class=\"lift-faq__answer\">\n            <p>\n              Nee. De verhoging bestaat niet uit een los, hard blok.\n              Deze is geïntegreerd in het binnenwerk van de schoen en voorzien\n              van demping. Hierdoor voelt de overgang geleidelijker en zachter\n              aan dan bij veel losse verhogende zooltjes.\n            </p>\n          </div>\n        </details>\n\n        <details class=\"lift-faq__item\">\n          <summary>\n            <span>Is de verhoging aan de buitenkant zichtbaar?</span>\n            <span class=\"lift-faq__toggle\" aria-hidden=\"true\"></span>\n          </summary>\n\n          <div class=\"lift-faq__answer\">\n            <p>\n              De verhoging zit volledig aan de binnenkant van de schoen.\n              Van buiten ziet LIFT eruit als een moderne sneaker, zonder\n              zichtbare hak of opvallende platformconstructie.\n            </p>\n          </div>\n        </details>\n\n        <details class=\"lift-faq__item\">\n          <summary>\n            <span>Zit er een los verhogend zooltje in?</span>\n            <span class=\"lift-faq__toggle\" aria-hidden=\"true\"></span>\n          </summary>\n\n          <div class=\"lift-faq__answer\">\n            <p>\n              Nee. De lift is in de schoen gebouwd en verschuift daardoor niet\n              tijdens het lopen. Je hoeft dus geen losse verhogende zooltjes\n              toe te voegen.\n            </p>\n          </div>\n        </details>\n\n        <details class=\"lift-faq__item\">\n          <summary>\n            <span>Welke hoogte kan ik het beste kiezen?</span>\n            <span class=\"lift-faq__toggle\" aria-hidden=\"true\"></span>\n          </summary>\n\n          <div class=\"lift-faq__answer\">\n            <ul>\n              <li><strong>+4 cm:</strong> subtiel en gemakkelijk voor dagelijks gebruik.</li>\n              <li><strong>+6 cm:</strong> een duidelijke verhoging met een natuurlijke uitstraling.</li>\n              <li><strong>+8 cm:</strong> voor wie een groter verschil wil ervaren.</li>\n              <li><strong>+10 cm:</strong> de maximale hoogteboost.</li>\n            </ul>\n\n            <p>\n              Draag je nog nooit verhoogde schoenen? Dan is +4 of +6 cm vaak\n              een toegankelijke eerste keuze.\n            </p>\n          </div>\n        </details>\n\n        <details class=\"lift-faq__item\">\n          <summary>\n            <span>Welke schoenmaat moet ik bestellen?</span>\n            <span class=\"lift-faq__toggle\" aria-hidden=\"true\"></span>\n          </summary>\n\n          <div class=\"lift-faq__answer\">\n            <p>\n              Bekijk altijd de maattabel op de productpagina en vergelijk deze\n              met je voetlengte in centimeters. Zit je tussen twee maten in of\n              heb je brede voeten? Kies dan meestal de grotere maat.\n            </p>\n\n            <p>\n              Kom je er niet uit? Mail je normale schoenmaat en voetlengte naar\n              <a href=\"mailto:{{ support_email }}\">{{ support_email }}</a>.\n              We helpen je graag met kiezen.\n            </p>\n          </div>\n        </details>\n\n        <details class=\"lift-faq__item\">\n          <summary>\n            <span>Zijn LIFT schoenen voor mannen of vrouwen?</span>\n            <span class=\"lift-faq__toggle\" aria-hidden=\"true\"></span>\n          </summary>\n\n          <div class=\"lift-faq__answer\">\n            <p>\n              Alle LIFT schoenen kunnen door zowel mannen als vrouwen worden\n              gedragen. De modellen zijn niet uitsluitend voor één geslacht\n              ontworpen. Kies vooral het model, de kleur en de maat die het\n              beste bij jou passen.\n            </p>\n          </div>\n        </details>\n\n        <details class=\"lift-faq__item\">\n          <summary>\n            <span>Kan ik LIFT de hele dag dragen?</span>\n            <span class=\"lift-faq__toggle\" aria-hidden=\"true\"></span>\n          </summary>\n\n          <div class=\"lift-faq__answer\">\n            <p>\n              De schoenen zijn ontworpen voor dagelijks gebruik, zoals werk,\n              een dagje uit, winkelen of uitgaan. Bouw het dragen bij een hoge\n              variant eventueel rustig op, zodat je voeten en houding eraan\n              kunnen wennen.\n            </p>\n          </div>\n        </details>\n\n        <details class=\"lift-faq__item\">\n          <summary>\n            <span>Kan ik ermee sporten of hardlopen?</span>\n            <span class=\"lift-faq__toggle\" aria-hidden=\"true\"></span>\n          </summary>\n\n          <div class=\"lift-faq__answer\">\n            <p>\n              Sommige modellen hebben een sportieve uitstraling, maar LIFT\n              schoenen zijn bedoeld als lifestyle- en dagelijkse sneakers.\n              Voor hardlopen of intensieve training adviseren we speciale\n              sportschoenen.\n            </p>\n          </div>\n        </details>\n\n        <details class=\"lift-faq__item\">\n          <summary>\n            <span>Wat is het verschil tussen de LIFT modellen?</span>\n            <span class=\"lift-faq__toggle\" aria-hidden=\"true\"></span>\n          </summary>\n\n          <div class=\"lift-faq__answer\">\n            <p>\n              Elk model heeft een eigen design, materiaal en pasvorm. Zo zijn\n              er minimalistische, casual en sportievere modellen. De\n              beschikbare kleuren, maten en hoogtes vind je bij ieder product\n              op de productpagina.\n            </p>\n          </div>\n        </details>\n\n        <details class=\"lift-faq__item\">\n          <summary>\n            <span>Kan ik de schoenen thuis passen?</span>\n            <span class=\"lift-faq__toggle\" aria-hidden=\"true\"></span>\n          </summary>\n\n          <div class=\"lift-faq__answer\">\n            <p>\n              Ja. Pas de schoenen binnenshuis op een schone ondergrond en laat\n              labels en verpakking intact totdat je zeker weet dat de maat\n              goed is. Voor de actuele retourtermijn en voorwaarden kun je\n              ons retourbeleid bekijken.\n            </p>\n          </div>\n        </details>\n\n      </div>\n\n      <div class=\"lift-faq__contact\">\n        <div>\n          <span class=\"lift-faq__contact-label\">NOG EEN VRAAG?</span>\n          <h3>Wij helpen je met kiezen</h3>\n          <p>\n            Stuur ons je vraag, normale schoenmaat en eventueel je voetlengte\n            in centimeters.\n          </p>\n        </div>\n\n        <a class=\"lift-faq__contact-button\" href=\"mailto:{{ support_email }}\">\n          Mail {{ support_email }}\n          <svg viewBox=\"0 0 20 20\" fill=\"none\" aria-hidden=\"true\">\n            <path d=\"M4 10h12M11.5 5.5 16 10l-4.5 4.5\"/>\n          </svg>\n        </a>\n      </div>\n\n    </div>\n  </section>\n\n  <style>\n    #LiftFaq-{{ lift_faq_id }} {\n      --lift-faq-bg: #f5f2ec;\n      --lift-faq-card: #ffffff;\n      --lift-faq-text: #151515;\n      --lift-faq-muted: #686868;\n      --lift-faq-border: rgba(21, 21, 21, 0.13);\n      --lift-faq-accent: #426c57;\n      --lift-faq-accent-light: #e9f0ec;\n\n      background: var(--lift-faq-bg);\n      color: var(--lift-faq-text);\n      margin: 50px 0;\n      padding: 72px 20px;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} *,\n    #LiftFaq-{{ lift_faq_id }} *::before,\n    #LiftFaq-{{ lift_faq_id }} *::after {\n      box-sizing: border-box;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__inner {\n      width: 100%;\n      max-width: 1180px;\n      margin: 0 auto;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__header {\n      max-width: 800px;\n      margin: 0 auto 42px;\n      text-align: center;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__eyebrow {\n      display: inline-block;\n      margin-bottom: 12px;\n      color: var(--lift-faq-accent);\n      font-size: 12px;\n      font-weight: 750;\n      letter-spacing: 0.18em;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} h2 {\n      margin: 0;\n      color: var(--lift-faq-text);\n      font-family: inherit;\n      font-size: clamp(32px, 4vw, 52px);\n      font-weight: 750;\n      line-height: 1.05;\n      letter-spacing: -0.035em;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__intro {\n      max-width: 680px;\n      margin: 18px auto 0;\n      color: var(--lift-faq-muted);\n      font-size: 16px;\n      line-height: 1.65;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__benefits {\n      display: flex;\n      flex-wrap: wrap;\n      justify-content: center;\n      gap: 10px;\n      margin-top: 28px;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__benefit {\n      display: inline-flex;\n      align-items: center;\n      gap: 8px;\n      min-height: 42px;\n      padding: 8px 14px;\n      border: 1px solid rgba(66, 108, 87, 0.18);\n      border-radius: 999px;\n      background: var(--lift-faq-accent-light);\n      color: #294b3a;\n      font-size: 13px;\n      font-weight: 650;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__benefit-icon {\n      display: inline-flex;\n      width: 20px;\n      height: 20px;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__benefit-icon svg {\n      width: 100%;\n      height: 100%;\n      stroke: currentColor;\n      stroke-width: 1.65;\n      stroke-linecap: round;\n      stroke-linejoin: round;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__grid {\n      display: grid;\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      align-items: start;\n      gap: 12px;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__item {\n      overflow: hidden;\n      border: 1px solid var(--lift-faq-border);\n      border-radius: 12px;\n      background: var(--lift-faq-card);\n      transition:\n        border-color 180ms ease,\n        box-shadow 180ms ease;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__item:hover,\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__item[open] {\n      border-color: rgba(66, 108, 87, 0.42);\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__item[open] {\n      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.055);\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__item summary {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 20px;\n      min-height: 72px;\n      padding: 19px 22px;\n      cursor: pointer;\n      list-style: none;\n      color: var(--lift-faq-text);\n      font-size: 16px;\n      font-weight: 680;\n      line-height: 1.4;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__item summary::-webkit-details-marker {\n      display: none;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__item summary:focus-visible {\n      outline: 2px solid var(--lift-faq-accent);\n      outline-offset: -4px;\n      border-radius: 10px;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__toggle {\n      position: relative;\n      flex: 0 0 30px;\n      width: 30px;\n      height: 30px;\n      border-radius: 50%;\n      background: var(--lift-faq-bg);\n      transition:\n        background 180ms ease,\n        transform 180ms ease;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__toggle::before,\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__toggle::after {\n      content: \"\";\n      position: absolute;\n      top: 50%;\n      left: 50%;\n      width: 12px;\n      height: 1.5px;\n      border-radius: 2px;\n      background: var(--lift-faq-text);\n      transform: translate(-50%, -50%);\n      transition: transform 180ms ease;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__toggle::after {\n      transform: translate(-50%, -50%) rotate(90deg);\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__item[open] .lift-faq__toggle {\n      background: var(--lift-faq-accent);\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__item[open] .lift-faq__toggle::before,\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__item[open] .lift-faq__toggle::after {\n      background: #ffffff;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__item[open] .lift-faq__toggle::after {\n      transform: translate(-50%, -50%) rotate(0deg);\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__answer {\n      padding: 0 22px 22px;\n      color: var(--lift-faq-muted);\n      font-size: 14.5px;\n      line-height: 1.7;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__answer p {\n      margin: 0;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__answer p + p {\n      margin-top: 12px;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__answer ul {\n      margin: 0 0 12px;\n      padding-left: 19px;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__answer li + li {\n      margin-top: 5px;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__answer strong {\n      color: var(--lift-faq-text);\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__answer a {\n      color: var(--lift-faq-text);\n      font-weight: 650;\n      text-decoration: underline;\n      text-underline-offset: 3px;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__contact {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 30px;\n      margin-top: 32px;\n      padding: 30px 32px;\n      border-radius: 14px;\n      background: #171717;\n      color: #ffffff;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__contact-label {\n      display: block;\n      margin-bottom: 5px;\n      color: #aebfb6;\n      font-size: 11px;\n      font-weight: 750;\n      letter-spacing: 0.16em;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__contact h3 {\n      margin: 0;\n      color: #ffffff;\n      font-family: inherit;\n      font-size: 24px;\n      font-weight: 700;\n      line-height: 1.2;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__contact p {\n      margin: 8px 0 0;\n      color: rgba(255, 255, 255, 0.72);\n      font-size: 14px;\n      line-height: 1.55;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__contact-button {\n      display: inline-flex;\n      flex: 0 0 auto;\n      align-items: center;\n      justify-content: center;\n      gap: 10px;\n      min-height: 50px;\n      padding: 13px 20px;\n      border: 1px solid rgba(255, 255, 255, 0.22);\n      border-radius: 8px;\n      background: #ffffff;\n      color: #151515;\n      font-size: 14px;\n      font-weight: 700;\n      line-height: 1.2;\n      text-decoration: none;\n      transition:\n        transform 180ms ease,\n        background 180ms ease;\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__contact-button:hover {\n      background: #e9f0ec;\n      transform: translateY(-1px);\n    }\n\n    #LiftFaq-{{ lift_faq_id }} .lift-faq__contact-button svg {\n      width: 18px;\n      height: 18px;\n      stroke: currentColor;\n      stroke-width: 1.7;\n      stroke-linecap: round;\n      stroke-linejoin: round;\n    }\n\n    @media screen and (max-width: 749px) {\n      #LiftFaq-{{ lift_faq_id }} {\n        margin: 34px 0;\n        padding: 48px 14px;\n      }\n\n      #LiftFaq-{{ lift_faq_id }} .lift-faq__header {\n        margin-bottom: 30px;\n      }\n\n      #LiftFaq-{{ lift_faq_id }} .lift-faq__intro {\n        font-size: 14.5px;\n      }\n\n      #LiftFaq-{{ lift_faq_id }} .lift-faq__benefits {\n        display: grid;\n        grid-template-columns: repeat(2, minmax(0, 1fr));\n        gap: 8px;\n      }\n\n      #LiftFaq-{{ lift_faq_id }} .lift-faq__benefit {\n        justify-content: flex-start;\n        width: 100%;\n        padding: 8px 11px;\n        font-size: 12px;\n      }\n\n      #LiftFaq-{{ lift_faq_id }} .lift-faq__grid {\n        grid-template-columns: 1fr;\n        gap: 9px;\n      }\n\n      #LiftFaq-{{ lift_faq_id }} .lift-faq__item summary {\n        min-height: 64px;\n        padding: 17px 16px;\n        font-size: 14.5px;\n      }\n\n      #LiftFaq-{{ lift_faq_id }} .lift-faq__answer {\n        padding: 0 16px 18px;\n        font-size: 13.5px;\n      }\n\n      #LiftFaq-{{ lift_faq_id }} .lift-faq__contact {\n        flex-direction: column;\n        align-items: stretch;\n        margin-top: 24px;\n        padding: 24px 20px;\n        text-align: center;\n      }\n\n      #LiftFaq-{{ lift_faq_id }} .lift-faq__contact h3 {\n        font-size: 21px;\n      }\n\n      #LiftFaq-{{ lift_faq_id }} .lift-faq__contact-button {\n        width: 100%;\n      }\n    }\n\n    @media (prefers-reduced-motion: reduce) {\n      #LiftFaq-{{ lift_faq_id }} *,\n      #LiftFaq-{{ lift_faq_id }} *::before,\n      #LiftFaq-{{ lift_faq_id }} *::after {\n        scroll-behavior: auto !important;\n        transition: none !important;\n      }\n    }\n  </style>\n{% endif %}",
