      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<style>\n  .carousel-wrapper {\n    position: relative;\n    overflow: hidden;\n    margin: 40px auto 20px;\n    max-width: 1300px;\n    padding: 0 20px;\n  }\n\n  .carousel-track {\n    display: flex;\n    gap: 16px;\n    align-items: flex-start;\n    transition: transform 0.3s ease-in-out;\n    will-change: transform;\n    overflow-x: auto;\n    scroll-behavior: smooth;\n  }\n\n  .carousel-track::-webkit-scrollbar {\n    display: none;\n  }\n\n  .carousel-slide {\n    flex: 0 0 auto;\n    width: 140px;\n    text-align: center;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: flex-start;\n  }\n\n  .carousel-slide img {\n    width: 80px;\n    height: 80px;\n    object-fit: contain;\n    margin-bottom: 8px;\n  }\n\n  .carousel-slide p {\n    margin: 0;\n    line-height: 1.4;\n  }\n\n  .carousel-slide p:nth-of-type(1) {\n    font-size: 13px;\n    font-weight: bold;\n  }\n\n  .carousel-slide p:nth-of-type(2) {\n    font-size: 12px;\n    color: #555;\n    margin-top: 4px;\n  }\n\n  .carousel-arrow {\n    position: absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    background: #fff;\n    border: 1px solid #ddd;\n    border-radius: 50%;\n    width: 36px;\n    height: 36px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    z-index: 10;\n    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);\n  }\n\n  .carousel-arrow-left {\n    left: 10px;\n  }\n\n  .carousel-arrow-right {\n    right: 10px;\n  }\n\n  @media (min-width: 1024px) {\n    .carousel-wrapper {\n      padding: 0 40px;\n    }\n\n    .carousel-track {\n      overflow: visible;\n      transform: none !important;\n      flex-wrap: nowrap;\n      justify-content: space-between;\n      gap: 32px;\n    }\n\n    .carousel-slide {\n      width: 160px;\n    }\n\n    .carousel-slide img {\n      width: 90px;\n      height: 90px;\n    }\n\n    .carousel-arrow {\n      display: none !important;\n    }\n  }\n</style>\n\n<div class=\"carousel-wrapper\">\n  <div class=\"carousel-arrow carousel-arrow-left\" onclick=\"moveCarousel(-1)\" id=\"arrow-left\">&#10094;</div>\n  <div class=\"carousel-arrow carousel-arrow-right\" onclick=\"moveCarousel(1)\" id=\"arrow-right\">&#10095;</div>\n\n  <div class=\"carousel-track\" id=\"carousel-track\">\n    <div class=\"carousel-slide\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0773/7458/7204/files/ChatGPT_Image_9_mei_2025__07_49_45-removebg-preview.png?v=1746769821\" alt=\"Anti-Diefstal Rits\">\n      <p>Anti-Diefstal Rits</p>\n      <p>Rits die moeilijk te openen is voor zakkenrollers.</p>\n    </div>\n    <div class=\"carousel-slide\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0773/7458/7204/files/ChatGPT_Image_9_mei_2025__08_11_03-removebg-preview.png?v=1746771094\" alt=\"RFID-Vakken\">\n      <p>RFID-Vakken</p>\n      <p>Beschermt pasjes en sleutels tegen elektronische diefstal.</p>\n    </div>\n    <div class=\"carousel-slide\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0773/7458/7204/files/ChatGPT_Image_9_mei_2025__08_19_33-removebg-preview.png?v=1746771596\" alt=\"Waterdicht\">\n      <p>Waterdicht</p>\n      <p>Beschermt de inhoud tegen regen en vocht.</p>\n    </div>\n    <div class=\"carousel-slide\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0773/7458/7204/files/ChatGPT_Image_9_mei_2025__08_21_53-removebg-preview.png?v=1746771734\">\n      <p>Veel Ruimte</p>\n      <p>Genoeg plaats voor al je dagelijkse spullen.</p>\n    </div>\n    <div class=\"carousel-slide\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0773/7458/7204/files/ChatGPT_Image_9_mei_2025__08_24_11-removebg-preview.png?v=1746771870\" alt=\"Snijbestendig\">\n      <p>Snijbestendig</p>\n      <p>Extra veilig door verstevigd snijvast materiaal.</p>\n    </div>\n    <div class=\"carousel-slide\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0773/7458/7204/files/ChatGPT_Image_9_mei_2025__08_27_16-removebg-preview.png?v=1746772063\">\n      <p>Links & Rechtshandig</p>\n      <p>Comfortabel te dragen voor iedereen.</p>\n    </div>\n  </div>\n\n  <p style=\"text-align: center; font-size: 14px; color: #777; margin-top: 16px;\">Swipe naar rechts voor meer</p>\n</div>\n\n<script>\n  let currentIndex = 0;\n  const track = document.getElementById('carousel-track');\n  const arrowLeft = document.getElementById('arrow-left');\n  const arrowRight = document.getElementById('arrow-right');\n\n  function updateCarousel() {\n    const wrapperWidth = document.querySelector('.carousel-wrapper').offsetWidth;\n    const slideWidth = document.querySelector('.carousel-slide').offsetWidth + 16;\n    const visibleSlides = Math.floor(wrapperWidth / slideWidth);\n    const totalSlides = track.children.length;\n    const maxIndex = totalSlides - visibleSlides;\n\n    arrowLeft.style.display = currentIndex > 0 ? 'flex' : 'none';\n    arrowRight.style.display = currentIndex < maxIndex ? 'flex' : 'none';\n\n    const scrollAmount = currentIndex * slideWidth;\n    track.scrollTo({ left: scrollAmount, behavior: 'smooth' });\n  }\n\n  function moveCarousel(direction) {\n    const wrapperWidth = document.querySelector('.carousel-wrapper').offsetWidth;\n    const slideWidth = document.querySelector('.carousel-slide').offsetWidth + 16;\n    const visibleSlides = Math.floor(wrapperWidth / slideWidth);\n    const totalSlides = track.children.length;\n    const maxIndex = totalSlides - visibleSlides;\n\n    currentIndex += direction;\n    if (currentIndex < 0) currentIndex = 0;\n    if (currentIndex > maxIndex) currentIndex = maxIndex;\n\n    updateCarousel();\n  }\n\n  window.addEventListener('load', updateCarousel);\n  window.addEventListener('resize', updateCarousel);\n</script>",
