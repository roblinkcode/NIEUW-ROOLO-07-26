olor: #0E0E0E;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 10px;\n  font-weight: 900;\n  line-height: 1;\n  flex-shrink: 0;\n  box-shadow: 0 2px 6px rgba(255,184,0,0.22);\n}\n\n@media screen and (max-width: 480px) {\n  .purchase-bubble {\n    padding: 7px 10px;\n    font-size: 11px;\n  }\n\n  .photo {\n    width: 21px;\n    height: 21px;\n  }\n\n  .photo-group {\n    margin-inline-end: 9px;\n  }\n}\n</style>"
