ift-se-table__normal\">×</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<style>\n.lift-se-comparison {\n  background: #F5F0E8;\n  padding: 90px 20px;\n}\n\n.lift-se-comparison__inner {\n  max-width: 1280px;\n  margin: 0 auto;\n  display: grid;\n  grid-template-columns: 0.95fr 1.05fr;\n  gap: 70px;\n  align-items: center;\n}\n\n.lift-se-comparison__content {\n  position: relative;\n  z-index: 1;\n}\n\n.lift-se-comparison__eyebrow {\n  font-size: 12px;\n  letter-spacing: 0.22em;\n  font-weight: 900;\n  color: #B86A2C;\n  margin-bottom: 18px;\n}\n\n.lift-se-comparison h2 {\n  margin: 0;\n  font-size: clamp(42px, 5vw, 76px);\n  line-height: 0.98;\n  letter-spacing: -0.055em;\n  font-weight: 900;\n  color: #0E0E0E;\n}\n\n.lift-se-comparison h2 span {\n  color: #0E0E0E;\n  position: relative;\n  display: inline-block;\n  z-index: 1;\n}\n\n.lift-se-comparison h2 span::after {\n  content: \"\";\n  position: absolute;\n  left: 4px;\n  right: 8px;\n  bottom: 5px;\n  height: 11px;\n  background: #D07A32;\n  opacity: 0.28;\n  z-index: -1;\n  border-radius: 999px;\n}\n\n.lift-se-comparison p {\n  margin: 24px 0 0;\n  max-width: 560px;\n  font-size: 18px;\n  line-height: 1.6;\n  color: #4B4741;\n}\n\n.lift-se-table {\n  background: #FAF8F4;\n  border: 1px solid #E6DED2;\n  border-radius: 28px;\n  overflow: hidden;\n  box-shadow: 0 20px 45px rgba(14,14,14,0.08);\n}\n\n.lift-se-table__head,\n.lift-se-table__row {\n  display: grid;\n  grid-template-columns: minmax(220px, 1fr) 120px 120px;\n}\n\n.lift-se-table__head {\n  min-height: 78px;\n  align-items: stretch;\n}\n\n.lift-se-table__spacer {\n  grid-column: 1;\n  background: #FAF8F4;\n}\n\n.lift-se-table__lift-head {\n  grid-column: 2;\n  background: linear-gradient(180deg, #1C1C1C 0%, #0E0E0E 100%);\n  color: #FFFFFF;\n  font-size: 22px;\n  font-weight: 900;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  border-radius: 18px 18px 0 0;\n  letter-spacing: 0.04em;\n}\n\n.lift-se-table__normal-head {\n  grid-column: 3;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 15px;\n  font-weight: 800;\n  color: #111111;\n  text-align: center;\n  padding: 0 12px;\n  background: #FFFFFF;\n}\n\n.lift-se-table__row {\n  min-height: 74px;\n  align-items: stretch;\n}\n\n.lift-se-table__row + .lift-se-table__row,\n.lift-se-table__row:first-of-type {\n  border-top: 1px solid #E6DED2;\n}\n\n.lift-se-table__feature {\n  grid-column: 1;\n  display: flex;\n  align-items: center;\n  padding: 0 24px;\n  font-size: 16px;\n  font-weight: 800;\n  color: #111111;\n  background: #FAF8F4;\n}\n\n.lift-se-table__lift {\n  grid-column: 2;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: linear-gradient(180deg, #1C1C1C 0%, #0E0E0E 100%);\n}\n\n.lift-se-table__lift span {\n  width: 32px;\n  height: 32px;\n  border-radius: 999px;\n  background: #FFB800;\n  color: #0E0E0E;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 20px;\n  font-weight: 900;\n  line-height: 1;\n  box-shadow: 0 3px 10px rgba(255,184,0,0.18);\n}\n\n.lift-se-table__normal {\n  grid-column: 3;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 34px;\n  font-weight: 400;\n  color: #8A8177;\n  background: #FFFFFF;\n}\n\n@media screen and (max-width: 989px) {\n  .lift-se-comparison {\n    padding: 70px 16px;\n  }\n\n  .lift-se-comparison__inner {\n    grid-template-columns: 1fr;\n    gap: 36px;\n  }\n\n  .lift-se-comparison__content {\n    max-width: 760px;\n  }\n\n  .lift-se-table {\n    max-width: 760px;\n  }\n}\n\n@media screen and (max-width: 749px) {\n  .lift-se-comparison {\n    padding: 54px 14px;\n  }\n\n  .lift-se-comparison__eyebrow {\n    font-size: 11px;\n    margin-bottom: 12px;\n  }\n\n  .lift-se-comparison h2 {\n    font-size: 34px;\n    line-height: 1.03;\n    letter-spacing: -0.04em;\n  }\n\n  .lift-se-comparison h2 span::after {\n    bottom: 3px;\n    height: 8px;\n    left: 