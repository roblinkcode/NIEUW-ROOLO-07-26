    "custom_liquid_pniHEi": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<section class=\"lift-why-section\">\n  <div class=\"lift-why-inner\">\n    <div class=\"lift-why-header\">\n      <span>WAAROM KLANTEN VOOR LIFT KIEZEN</span>\n      <h2>Meer lengte. Dezelfde natuurlijke look.</h2>\n    </div>\n\n    <div class=\"lift-why-grid\">\n      <div class=\"lift-why-card\">\n        <div class=\"lift-why-icon lift-icon-arrow-up\"></div>\n        <h3>Tot +10 cm extra lengte</h3>\n        <p>Kies de hoogte die het beste bij jou past: +4, +6, +8 of +10 cm.</p>\n      </div>\n\n      <div class=\"lift-why-card\">\n        <div class=\"lift-why-icon lift-icon-hidden\"></div>\n        <h3>Onzichtbare verhoging</h3>\n        <p>De verhoging is subtiel verwerkt aan de binnenkant van de schoen en is van buitenaf niet zichtbaar.</p>\n      </div>\n\n      <div class=\"lift-why-card\">\n        <div class=\"lift-why-icon lift-icon-check\"></div>\n        <h3>Comfortabel voor dagelijks gebruik</h3>\n        <p>Ontworpen voor dagelijks gebruik, met een zachte pasvorm en een stabiel gevoel.</p>\n      </div>\n\n      <div class=\"lift-why-card\">\n        <div class=\"lift-why-icon lift-icon-return\"></div>\n        <h3>30 dagen retourgarantie</h3>\n        <p>Probeer ze rustig thuis. Niet tevreden? Je kunt ze binnen 30 dagen retourneren.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<style>\n  .lift-why-section {\n    background: #FFFFFF;\n    padding: 58px 20px;\n  }\n\n  .lift-why-inner {\n    max-width: 1120px;\n    margin: 0 auto;\n  }\n\n  .lift-why-header {\n    text-align: center;\n    margin-bottom: 32px;\n  }\n\n  .lift-why-header span {\n    display: inline-block;\n    margin-bottom: 11px;\n    font-size: 11px;\n    line-height: 1;\n    letter-spacing: 0.18em;\n    font-weight: 900;\n    color: #B86A2C;\n  }\n\n  .lift-why-header h2 {\n    margin: 0;\n    color: #0E0E0E;\n    font-size: clamp(28px, 3.2vw, 44px);\n    line-height: 1.08;\n    letter-spacing: -0.045em;\n    font-weight: 900;\n  }\n\n  .lift-why-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 14px;\n  }\n\n  .lift-why-card {\n    background: #FAF8F4;\n    border: 1px solid #E6DED2;\n    border-radius: 18px;\n    padding: 22px 18px;\n    min-height: 190px;\n    box-shadow: 0 8px 22px rgba(14,14,14,0.04);\n    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;\n  }\n\n  .lift-why-card:hover {\n    transform: translateY(-2px);\n    border-color: #D8CBB8;\n    box-shadow: 0 14px 30px rgba(14,14,14,0.07);\n  }\n\n  .lift-why-icon {\n    width: 38px;\n    height: 38px;\n    border-radius: 999px;\n    background: linear-gradient(180deg, #1C1C1C 0%, #0E0E0E 100%);\n    color: #fff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin-bottom: 16px;\n    position: relative;\n    flex: 0 0 38px;\n    box-shadow: 0 5px 14px rgba(14,14,14,0.18);\n  }\n\n  .lift-why-icon::marker {\n    display: none;\n  }\n\n  .lift-icon-arrow-up::before {\n    content: \"\";\n    width: 12px;\n    height: 12px;\n    border-top: 3px solid #FFB800;\n    border-right: 3px solid #FFB800;\n    transform: rotate(-45deg);\n    position: absolute;\n    top: 12px;\n  }\n\n  .lift-icon-arrow-up::after {\n    content: \"\";\n    width: 3px;\n    height: 15px;\n    background: #FFB800;\n    position: absolute;\n    top: 13px;\n    border-radius: 99px;\n  }\n\n  .lift-icon-hidden::before {\n    content: \"\";\n    width: 16px;\n    height: 16px;\n    border: 3px solid #FFB800;\n    border-radius: 999px;\n    position: absolute;\n  }\n\n  .lift-icon-hidden::after {\n    content: \"\";\n    width: 8px;\n    height: 18px;\n    background: #0E0E0E;\n    position: absolute;\n    right: 8px;\n  }\n\n  .lift-icon-check::before {\n    content: \"\";\n    width: 15px;\n    height: 8px;\n    border-left: 3px solid #FFB800;\n    border-bottom: 3px solid #FFB800;\n    transform: rotate(-45deg);\n    position: absolute;\n    top: 13px;\n  }\n\n  .lift-icon-return::before {\n    content: \"\";\n    width: 17px;\n    height: 13px;\n    border-top: 3px solid #FFB800;\n    border-left: 3px solid #FFB800;\n    border-radius: 8px 0 0 0;\n    position: absolute;\n    top: 13px;\n    left: 12px;\n  }\n\n  .lift-icon-return::after {\n    content: \"\";\n    width: 9px;\n    height: 9px;\n    border-left: 3px solid #FFB800;\n    border-bottom: 3px solid #FFB800;\n    transform: rotate(45deg);\n    position: absolute;\n    top: 11px;\n    left: 10px;\n  }\n\n  .lift-why-card h3 {\n    margin: 0;\n    color: #0E0E0E;\n    font-size: 16px;\n    line-height: 1.25;\n    font-weight: 900;\n    letter-spacing: -0.02em;\n  }\n\n  .lift-why-card p {\n    margin: 9px 0 0;\n    color: #4B4741;\n    font-size: 13.5px;\n    line-height: 1.45;\n    font-weight: 500;\n  }\n\n  @media screen and (max-width: 989px) {\n    .lift-why-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n\n  @media screen and (max-width: 749px) {\n    .lift-why-section {\n      padding: 44px 16px;\n    }\n\n    .lift-why-header {\n      text-align: left;\n      margin-bottom: 22px;\n    }\n\n    .lift-why-header span {\n      font-size: 10px;\n      letter-spacing: 0.16em;\n      margin-bottom: 10px;\n    }\n\n    .lift-why-header h2 {\n      font-size: 30px;\n      line-height: 1.05;\n      letter-spacing: -0.04em;\n    }\n\n    .lift-why-grid {\n      grid-template-columns: 1fr;\n      gap: 10px;\n    }\n\n    .lift-why-card {\n      min-height: auto;\n      padding: 18px 16px;\n      border-radius: 15px;\n      display: block;\n    }\n\n    .lift-why-card:hover {\n      transform: none;\n    }\n\n    .lift-why-icon {\n      width: 36px;\n      height: 36px;\n      flex: 0 0 36px;\n      margin-bottom: 12px;\n    }\n\n    .lift-why-card h3 {\n      font-size: 16px;\n      line-height: 1.2;\n      margin: 0;\n      letter-spacing: -0.02em;\n    }\n\n    .lift-why-card p {\n      font-size: 13.5px;\n      line-height: 1.45;\n      margin-top: 8px;\n    }\n\n    .lift-icon-arrow-up::before {\n      width: 11px;\n      height: 11px;\n      top: 11px;\n    }\n\n    .lift-icon-arrow-up::after {\n      height: 14px;\n      top: 13px;\n    }\n\n    .lift-icon-hidden::before {\n      width: 15px;\n      height: 15px;\n    }\n\n    .lift-icon-hidden::after {\n      height: 17px;\n      right: 8px;\n    }\n\n    .lift-icon-check::before {\n      width: 14px;\n      height: 8px;\n      top: 12px;\n    }\n\n    .lift-icon-return::before {\n      width: 16px;\n      height: 12px;\n      top: 13px;\n      left: 11px;\n    }\n\n    .lift-icon-return::after {\n      top: 11px;\n      left: 9px;\n    }\n  }\n</style>",
        "color_scheme": "background-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
