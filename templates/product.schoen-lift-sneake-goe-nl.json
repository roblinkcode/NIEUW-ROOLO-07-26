    "ss_simple_faq_w4p4Vr": {
      "type": "ss-simple-faq",
      "blocks": {
        "text_w4RX6p": {
          "type": "text",
          "settings": {
            "question": "Blijft de BoostUp Bra goed zitten, ook als ik zweet?",
            "answer": "<p>Ja! De BoostUp Bra™ is gemaakt met zweetbestendige, huidvriendelijke lijm die ook bij warmte of beweging goed blijft zitten.<br/><br/></p>"
          }
        },
        "text_U4Qbar": {
          "type": "text",
          "settings": {
            "question": "Kan ik de BoostUp Bra meerdere keren gebruiken?",
            "answer": "<p>Zeker! Spoel de cups na gebruik even af met water en laat ze drogen aan de lucht. Zo kun je ze keer op keer opnieuw gebruiken.<br/><br/></p>"
          }
        },
        "text_tzea9U": {
          "type": "text",
          "settings": {
            "question": "Is de BoostUp Bra geschikt voor alle cupmaten?",
            "answer": "<p>Ja, de BoostUp Bra™ is ontworpen om zich aan te passen aan verschillende vormen en maten — van A tot zelfs E cup. Kies de maat die het beste bij jouw borstvorm past.<br/><br/></p>"
          }
        },
        "text_4b6DXY": {
          "type": "text",
          "settings": {
            "question": "Doet het pijn bij het verwijderen?",
            "answer": "<p>Nee, de zachte, huidvriendelijke lijm is speciaal ontwikkeld om comfortabel los te laten zonder te trekken of te irriteren.</p>"
          }
        },
        "text_UnMqBJ": {
          "type": "text",
          "settings": {
            "question": "Kan ik het dragen onder strakke kleding?",
            "answer": "<p>Absoluut. De BoostUp Bra™ is volledig onzichtbaar onder elk type outfit — ideaal voor jurken, tops en open ruggen.<br/><br/></p>"
          }
        },
        "text_b7jhyH": {
          "type": "text",
          "settings": {
            "question": "Hoe lang blijft de plaklaag goed?",
            "answer": "<p>Bij juist gebruik (reinigen en luchtdrogen) gaat de plaklaag gemiddeld 20–30 keer mee.<br/><br/></p>"
          }
        },
        "text_4qmdNy": {
          "type": "text",
          "settings": {
            "question": "Kan ik de BoostUp Bra dragen met een gevoelige huid?",
            "answer": "<p>Ja, de lijm is dermatologisch getest en vrij van irriterende stoffen. Perfect voor de gevoelige huid.<br/><br/></p>"
          }
        }
      },
      "block_order": [
        "text_w4RX6p",
