pt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"16947789000e7c3be1":{"type":"apps","settings":{"include_margins":true}},"169477810286cbda2b":{"type":"apps","settings":{"include_margins":true}},"1694778916ae6d13bb":{"type":"apps","settings":{"include_margins":true}},"7ead9d52-a3ce-4f63-9e00-e5fbe252c5a8":{"type":"image-with-text","blocks":{"9bd8fb44-fa40-449d-be77-8f37af118496":{"type":"text","settings":{"text":"<h4>16 Kleur Opties<\/h4><p>Met 16 levendige kleuropties transformeert de Moonlight Lamp elke ruimte in een handomdraai. Of je nu de perfecte sfeer wilt creëren voor een ontspannen avond thuis of een leuke en educatieve ervaring wilt bieden voor kinderen, deze lamp past zich moeiteloos aan aan de behoeften jou!<\/p>","text_style":"body"}}},"block_order":["9bd8fb44-fa40-449d-be77-8f37af118496"],"settings":{"image":"shopify:\/\/shop_images\/16_KLEUREN.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"2cb68c65-93ce-4030-a625-5bac24b42fe4":{"type":"image-with-text","blocks":{"f1d0c312-6e0a-443f-a521-b731697ad34f":{"type":"text","settings":{"text":"","text_style":"body"}}},"block_order":["f1d0c312-6e0a-443f-a521-b731697ad34f"],"settings":{"image":"shopify:\/\/shop_images\/oplaad.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"9f8ed1f4-75b8-4974-842c-754126d14d2b":{"type":"image-with-text","blocks":{"17763526-3cb0-4bec-9275-ca6d59d9a612":{"type":"text","settings":{"text":"","text_style":"body"}}},"block_order":["17763526-3cb0-4bec-9275-ca6d59d9a612"],"settings":{"image":"shopify:\/\/shop_images\/kind_met_mlamp.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"fb5ad6ac-1898-431f-b29d-f6d26831fba9":{"type":"collapsible-content","blocks":{"template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-1":{"type":"collapsible_row","settings":{"heading":"Product Specificaties","icon":"none","row_content":"<p><strong>Dimbaar:<\/strong>Ja, ook meerdere kleuren<br\/><strong>Certificaat: <\/strong>CE<br\/><strong>Stroombron: <\/strong>LED<br\/><strong>Maximaal vermogen:<\/strong>5W<br\/><strong>Gebruiksduur: <\/strong>Tot 30 uur<br\/><strong>Oplaadtijd: <\/strong>6-8 uur<br\/><strong>Grootte (Diameter): <\/strong>8cm, 12cm en 15cm<\/p>","page":""}},"template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-3":{"type":"collapsible_row","disabled":true,"settings":{"heading":"Opladen","icon":"lightning_bolt","row_content":"<p>Laad eenvoudig op via de meegeleverde USB-C-kabel voor ruim 48 uur ononderbroken verlichting. Bij de Karakter Lamp staat niet alleen het voortreffelijke ontwerp centraal, maar ook jouw veiligheid. Onze lampen worden aangedreven door een beveiligde batterij met geavanceerde overstroomtechnologie, wat voldoet aan explosieveilige en vlambestendige veiligheidsnormen<\/p>","page":""}}},"block_order":["template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-1","template--20404861862212__fb5ad6ac-1898-431f-b29d-f6d26831fba9-collapsible_row-3"],"settings":{"caption":"","heading_size":"h1","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":8,"padding_bottom":8}},"588f6a03-9251-48aa-a934-da38c979a83d":{"type":"collapsible-content","blocks":{"template--20385125597508__588f6a03-9251-48aa-a934-da38c979a83d-collapsible_row-2":{"type":"collapsible_row","settings":{"heading":"Hoe kan ik de lamp van stroom voorzien?","icon":"none","row_content":"<p>In tegenstelling tot conventionele lampen kan hij van stroom worden voorzien via de meegeleverde universele USB-kabel of via 3 x AA-batterijen (niet meegeleverd), waardoor hij er overzichtelijk uitziet en de flexibiliteit heeft om overal in huis geplaatst te worden.<\/p>","page":""}},"template--20385125597508__588f6a03-9251-48aa-a934-da38c979a83d-collapsible_row-4":{"type":"collapsible_row","settings":{"heading":"Kan ik mijn bestelling retourneren als ik niet tevreden ben?","icon":"none","row_content":"<p>Geen probleem! Neem binnen 30 dagen na ontvangst contact op met de klantenservice, dan helpen wij je verder!<\/p>","page":""}},"template--20385125597508__588f6a03-9251-48aa-a934-da38c979a83d-collapsible_row-3":{"type":"collapsible_row","settings":{"heading":"Hoe hoog is de lamp?","icon":"none","row_content":"<p>De Glow Tree is 45cm hoog<\/p>","page":""}}},"block_order":["template--20385125597508__588f6a03-9251-48aa-a934-da38c979a83d-collapsible_row-2","template--20385125597508__588f6a03-9251-48aa-a934-da38c979a83d-collapsible_row-4","template--20385125597508__588f6a03-9251-48aa-a934-da38c979a83d-collapsible_row-3"],"disabled":true,"settings":{"caption":"","heading_size":"h2","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":36,"padding_bottom":36}},"1257f402-04b3-4e08-93b3-6d6dd0b5f272":{"type":"image-with-text","blocks":{"template--20109320978756__1257f402-04b3-4e08-93b3-6d6dd0b5f272-text-1":{"type":"text","settings":{"text":"<h4>Praktisch ingebouwd harnas voor optimale controle<\/h4><p>Met de Dog Jacket krijgt je hond niet alleen een <strong>warme winterjas<\/strong>, <strong>maar ook een ingebouwd tuigje.<\/strong> Geen aparte halsband meer nodig! Het geïntegreerde harnas biedt comfortabele en veilige controle tijdens het lopen. Jouw hond zit veilig en comfortabel in de jas. Praktisch en stijlvol voor de winter!<\/p>","text_style":"body"}}},"block_order":["template--20109320978756__1257f402-04b3-4e08-93b3-6d6dd0b5f272-text-1"],"disabled":true,"settings":{"image":"shopify:\/\/shop_images\/gif_4_0d76c123-6c4d-4065-9a4d-51e310d5797c.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"debb262c-7966-437e-9293-3d712dea0416":{"type":"image-with-text","blocks":{"template--20109320978756__debb262c-7966-437e-9293-3d712dea0416-text-1":{"type":"text","settings":{"text":"<h4>Gezellige hondenjas met een zachte fleecevoering<\/h4><p>Met onze knusse hondenjas, die een <strong>zachte fleecevoering<\/strong> heeft, kan jouw harige vriend het hele jaar door de natuur verkennen. De jas is speciaal ontworpen om jouw hond te beschermen tegen koude wind en lage temperaturen.<\/p>","text_style":"body"}}},"block_order":["template--20109320978756__debb262c-7966-437e-9293-3d712dea0416-text-1"],"disabled":true,"settings":{"image":"shopify:\/\/shop_images\/gif_5_63ed069c-2c54-48fa-8145-783b67e53542.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"fc7f31b1-4af5-4037-bf99-12ffff6d102e":{"type":"collapsible-content","blocks":{"template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-1":{"type":"collapsible_row","settings":{"heading":"Zijn de jassen waterdicht?","icon":"none","row_content":"<p>Onze jassen hebben een waterafstotende buitenlaag die lichte regen en sneeuw buiten houdt. Ze bieden een zeer goede bescherming tegen vocht.<\/p>","page":""}},"template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-2":{"type":"collapsible_row","settings":{"heading":"Kan de jas in de wasmachine?","icon":"none","row_content":"<p>Ja, je kan de jas wassen in de wasmachine. Volg de wasinstructies op het etiket om een optimale verzorging te garanderen.<\/p>","page":""}},"template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-3":{"type":"collapsible_row","settings":{"heading":"Zijn de jassen geschikt voor alle hondenrassen?","icon":"none","row_content":"<p>Onze jassen zijn verkrijgbaar in verschillende maten en passen op de meeste hondenrassen. Bekijk goed de maattabel om de juiste maat voor jouw hond te kiezen.<\/p>","page":""}},"43f6217f-909e-48c4-a956-cd3983c153ec":{"type":"collapsible_row","settings":{"heading":"Is de jas ook geschikt voor katten?","icon":"none","row_content":"<p>Ja zeker, de jas past ook bij katten, zolang het overeenkomt met de maattabel moet de jas goed passen!<\/p>","page":""}},"template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-4":{"type":"collapsible_row","settings":{"heading":"Kan ik mijn bestelling retourneren als ik niet tevreden ben?","icon":"none","row_content":"<p>Geen probleem! Neem binnen 30 dagen na ontvangst van de jas contact op met onze klantenservice.<\/p>","page":""}}},"block_order":["template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-1","template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-2","template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-3","43f6217f-909e-48c4-a956-cd3983c153ec","template--20109320978756__fc7f31b1-4af5-4037-bf99-12ffff6d102e-collapsible_row-4"],"disabled":true,"settings":{"caption":"","heading_size":"h2","heading_alignment":"left","layout