e.display = currentIndex < maxIndex ? 'flex' : 'none';\n\n    \/\/ Scroll\n    const scrollAmount = currentIndex * slideWidth;\n    track.style.transform = `translateX(-${scrollAmount}px)`;\n  }\n\n  function moveCarousel(direction) {\n    const wrapperWidth = document.querySelector('.carousel-wrapper').offsetWidth;\n    const slideWidth = document.querySelector('.carousel-slide').offsetWidth + 12;\n    const visibleSlides = Math.floor(wrapperWidth \/ slideWidth);\n    const totalSlides = track.children.length;\n    const maxIndex = totalSlides - visibleSlides;\n\n    currentIndex += direction;\n    if (currentIndex < 0) currentIndex = 0;\n    if (currentIndex > maxIndex) currentIndex = maxIndex;\n\n    updateCarousel();\n  }\n\n  window.addEventListener('load', updateCarousel);\n  window.addEventListener('resize', updateCarousel);\n<\/script>","color_scheme":"background-1","padding_top":0,"padding_bottom":0}},"comparison_slider_9X6ctA":{"type":"comparison-slider","disabled":true,"settings":{"title":"Hittevrij Stylen","heading_size":"h2","text":"<p>Zeg vaarwel tegen hitteschade met onze innovatieve hittevrije blowout rods. In tegenstelling tot krultangen of föhns bieden deze rods een zachte, hittevrije manier om je haar te stylen. Zo blijft je haar gezond en glanzend, terwijl je moeiteloos de perfecte look creëert.<\/p>","button_label":"","link":"","button_style_secondary":false,"color_scheme":"background-1","layout":"slider_first","before_label":"VOOR","after_label":"NA","labels_color_scheme":"accent-1","line_color":"background-1","before_image":"shopify:\/\/shop_images\/voor.png","after_image":"shopify:\/\/shop_images\/na.png","padding_top":0,"padding_bottom":0}},"custom_liquid_LjiL7A":{"type":"custom-liquid","disabled":true,"settings":{"custom_liquid":"<style>\n  .custom-section {\n    display: flex;\n    flex-wrap: wrap;\n    align-items: center;\n    justify-content: space-between;\n    padding: 40px;\n    background-color: #f8f8f8;\n    border-radius: 10px;\n    margin-top: 40px;\n  }\n\n  .custom-section .text,\n  .custom-section .image {\n    flex: 1 1 100%;\n    margin-bottom: 20px;\n  }\n\n  .custom-section .text {\n    padding-right: 20px;\n  }\n\n  .custom-section img {\n    width: 100%;\n    border-radius: 8px;\n  }\n\n  @media (min-width: 768px) {\n    .custom-section .text,\n    .custom-section .image {\n      flex: 1 1 48%;\n      margin-bottom: 0;\n    }\n  }\n<\/style>\n\n<div class=\"custom-section\">\n  <div class=\"text\">\n  <div class=\"section-label\">Body Positivity<\/div>\n    <h2 style=\"margin-bottom: 10px;\">Wij vieren iedere vrouw<\/h2>\n    <p>Elke vrouw verdient het om zich mooi, zelfverzekerd en krachtig te voelen – precies zoals ze is. Deze shapewear is ontworpen om jouw natuurlijke vormen te omarmen en subtiel te ondersteunen. Geen maskering, geen verstoppen – alleen jij, op je best.<\/p>\n  <\/div>\n  <div class=\"image\">\n    <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0773\/7458\/7204\/files\/Ontwerp_zonder_titel_1_9a8eb63c-dab5-44cf-b043-b2cfdd750c16.png?v=1744794447\" alt=\"Vrouwen vieren hun lichaam\">\n  <\/div>\n<\/div>","color_scheme":"background-1","padding_top":0,"padding_bottom":0}},"custom_liquid_mG8qfQ":{"type":"custom-liquid","disabled":true,"name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<div class=\"roolo-complaints-section\">\n  <h2 class=\"roolo-complaints-title\">Nog steeds gedoe met overvolle, onhandige tassen? Wij snappen je.<\/h2>\n  <div class=\"roolo-complaints-grid\">\n    <div class=\"roolo-complaint-card\">\n      <p>Rondslepen van een <strong>zware koffer<\/strong>? Geen pretje.<\/p>\n      <span class=\"roolo-complaint-icon\">✖<\/span>\n    <\/div>\n    <div class=\"roolo-complaint-card\">\n      <p>Je <strong>favoriete outfits<\/strong> moeten thuislaten? Herkenbaar.<\/p>\n      <span class=\"roolo-complaint-icon\">✖<\/span>\n    <\/div>\n    <div class=\"roolo-complaint-card\">\n      <p>Niets zegt vakantie-ready als een gestreken outfit… behalve als je die <strong>niet hebt<\/strong>.<\/p>\n      <span class=\"roolo-complaint-icon\">✖<\/span>\n    <\/div>\n    <div class=\"roolo-complaint-card\">\n      <p><strong>Extra betalen voor bagage?<\/strong> Dat geld kan naar cocktails!<\/p>\n      <span class=\"roolo-complaint-icon\">✖<\/span>\n    <\/div>\n  <\/div>\n<\/div>","color_scheme":"background-1","padding_top":28,"padding_bottom":24}},"image_with_text_tUKeGL":{"type":"image-with-text","blocks":{"heading_mkRif7":{"type":"heading","settings":{"heading_size":"h2"}},"text_ChzkbY":{"type":"text","settings":{"text":"<p>Of je nu op weg bent naar werk of een lange rit maakt: deze slimme cup <strong>houdt je koffie heerlijk warm of koelt je frisdrank juist razendsnel af.<\/strong> Altijd de juiste temperatuur, waar je ook bent.<\/p>","text_style":"body"}}},"block_order":["heading_mkRif7","text_ChzkbY"],"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/ChatGPT_Image_22_mei_2025_17_00_06.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"image_with_text_CbC9LC":{"type":"image-with-text","blocks":{"heading_G7LTpW":{"type":"heading","settings":{"heading_size":"h1"}},"text_DA9dF6":{"type":"text","settings":{"text":"<p>Verwarm babyflesjes tot precies 37°C, ideaal voor veilige en comfortabele voeding tijdens autoritten. Geen gedoe meer met thermoskannen of koude melk: gewoon aansluiten en klaar.<\/p>","text_style":"body"}}},"block_order":["heading_G7LTpW","text_DA9dF6"],"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/ChatGPT_Image_22_mei_2025_16_55_23.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"custom_liquid_N4FeHh":{"type":"custom-liquid","disabled":true,"name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<h2 style=\"text-align:center; font-size:26px; margin-bottom:30px;\">In 3 Stappen Geregeld<\/h2>\n\n<div class=\"roolo-feature-carousel\">\n  <div class=\"roolo-feature-track\">\n\n    <div class=\"roolo-feature-card\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0773\/7458\/7204\/files\/Scherm_afbeelding_2025-05-02_om_07.56.30.png?v=1746165463\" alt=\"Stap 1\" class=\"roolo-feature-image\">\n      <h3>Stap 1<\/h3>\n      <p>Gebruik de meegeleverde micro USB-kabel om het apparaat op te laden. Tijdens het opladen brandt het LED-lampje rood, en zodra volledig opgeladen wordt het groen.<\/p>\n    <\/div>\n\n    <div class=\"roolo-feature-card\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0773\/7458\/7204\/files\/Scherm_afbeelding_2025-05-02_om_07.57.06.png?v=1746165462\" alt=\"Stap 2\" class=\"roolo-feature-image\">\n      <h3>Stap 2<\/h3>\n      <p>Druk op de knop bovenop het apparaat. Je hoort een klik en de LED-verlichting gaat aan.<\/p>\n    <\/div>\n\n    <div class=\"roolo-feature-card\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0773\/7458\/7204\/files\/Scherm_afbeelding_2025-05-02_om_07.57.17.png?v=1746165463\" alt=\"Stap 3\" class=\"roolo-feature-image\">\n      <h3>Stap 3<\/h3>\n      <p>Plaats het apparaat in een donkere ruimte, bijvoorbeeld bij een vuilnisbak of etenswaren, en laat de BugBuster™ zijn werk doen.<\/p>\n    <\/div>\n\n  <\/div>\n<\/div>\n<p class=\"roolo-swipe-tip\">Swipe naar rechts voor meer ➡️<\/p>","color_scheme":"background-1","padding_top":0,"padding_bottom":0}},"image_with_text_icRBhw":{"type":"image-with-text","blocks":{"heading_RqXKyN":{"type":"heading","settings":{"heading_size":"h1"}},"text_QMj3gp":{"type":"text","settings":{"text":"<p><strong>Binnen<\/strong> – Houd vliegen uit je keuken, slaapkamer en woonkamer.<br\/> <strong>Bij eten<\/strong> – Bescherm je eettafel, BBQ of buitenmaaltijd.<br\/><strong>Buiten<\/strong> – Ideaal voor kamperen, vissen en picknicks.<br\/><strong>Tuin & Balkon<\/strong> – Geniet van een insectvrije buitenruimte.<br\/><strong>Draagbaar & Lichtgewicht<\/strong> – Neem 'm overal mee naartoe!<\/p>","text_style":"body"}}},"block_order":["heading_RqXKyN","text_QMj3gp"],"disabled":true,"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/gif_3_44ead5c8-fe64-4cf5-8f1f-40ee7b78f601.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"custom_liquid_DixGzg":{"type":"custom-liquid","disabled":true,"name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<div style=\"background-color:#111; color:white; padding:0; text-align:center; overflow:hidden;\">\n\n \n  <p style=\"margin-bottom:20px;\">Lees wat andere zeggen over de BugBuster™: <\/p>\n\n  <div style=\"display:flex; justify-content:center;\">\n    <div style=\"display:flex; gap:20px; overflow-x:auto; scroll-snap-type:x mandatory; padding:0 20px; max-width:100%; margin:0 auto;\">\n      \n      <div style=\"flex:0 0 auto; width:300px; scroll-snap-align:start;\">\n        <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0773\/7458\/7204\/files\/Schermafbeelding_2025-05-02_154851.png?v=1746193762\" style=\"width:100%; border-radius:10px; margin-bottom:10px;\">\n        <div style=\"font-size:20px; margin-bottom:5px;\">⭐️⭐️⭐️⭐️⭐️<\/div>\n        <h3 style=\"margin:0 0 10px 0;\">Zapt alles!<\/h3>\n        <p style=\"margin:0;\">Vangt muggen, motten, fruitvliegjes en meer. Werkt enorm goed!<\/p>\n        <p style=\"font-style:italic; margin-top:10px;\">– Laura M.<\/p>\n      <\/div>\n\n      <div style=\"flex:0 0 auto; width:300px; scroll-snap-align:start;\">\n        <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0773\/7458\/7204\/files\/Schermafbeelding_2025-05-02_154907.png?v=1746193761\" style=\"width:100%; border-radius:10px; margin-bottom:10px;\">\n        <div style=\"font-size:20px; margin-bottom:5px;\">⭐️⭐️⭐️⭐️⭐️<\/div>\n        <h3 style=\"margin:0 0 10px 0;\">Beter dan sprays<\/h3>\n        <p style=\"margin:0;\">Sprays maken alles vies. Deze lokt en doodt alles op één plek. Makkelijk schoon te maken!<\/p>\n        <p style=\"font-style:italic; margin-top:10px;\">– Erik D.<\/p>\n      <\/div>\n\n      <div style=\"flex:0 0 auto; width:300px; scroll-snap-align:start;\">\n        <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0773\/7458\/7204\/files\/Schermafbeelding_2025-05-02_154841.png?v=1746193762\" style=\"width:100%; border-radius:10px; margin-bottom:10px;\">\n        <div style=\"font-size:20px; margin-bottom:5px;\">⭐️⭐️⭐️⭐️⭐️<\/div>\n        <h3 style=\"margin:0 0 10px 0;\">Naast mijn prullenbak<\/h3>\n        <p style=\"margin:0;\">Ik zet ’m naast mijn fruitschaal en prullenbak – sindsdien geen last meer. Topding!<\/p>\n        <p style=\"font-style:italic; margin-top:10px;\">– Sanne V.<\/p>\n      <\/div>\n\n    <\/div>\n  <\/div>\n\n  <p style=\"margin-top:15px; font-size:14px;\">Swipe naar links of rechts om meer te zien ➡️<\/p>\n<\/div>","color_scheme":"background-1","padding_top":0,"padding_bottom":0}},"image_with_text_QYxAc9":{"type":"image-with-text","blocks":{"heading_LwaWQH":{"type":"heading","settings":{"heading_size":"h1"}},"text_8NDpGT":{"type":"text","settings":{"text":"<p>Het schuine roosterontwerp beschermt <strong>vingers en pootjes<\/strong> tegen onbedoeld contact met het stroomrooster.<\/p>","text_style":"body"}}},"block_order":["heading_LwaWQH","text_8NDpGT"],"disabled":true,"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/100_Veilig_Voor_Kinderen_Dieren.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"image_with_text_ym3ke9":{"type":"image-with-text","disabled":true,"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/ChatGPT_Image_2_mei_2025_16_13_59.png","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"text_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"multicolumn_fAACDz":{"type":"multicolumn","blocks":{"column_C847Qb":{"type":"column","settings":{"title":"Niet tevreden? Geld terug!","text":"<p>Wij staan volledig achter de kwaliteit van onze producten. Mocht je toch niet tevreden zijn, dan bieden we onze <strong>\"niet goed, geld terug garantie\" <\/strong>aan. Jouw tevredenheid is onze prioriteit!<\/p>","link_label":"","link":""}}},"block_order":["column_C847Qb"],"settings":{"title":"","heading_size":"h2","button_label":"","button_link":"","color_scheme":"background-1","image_width":"full","image_ratio":"adapt","column_alignment":"left","columns_desktop":3,"columns_mobile":"1","padding_top":16,"padding_bottom":36}},"collapsible_content_TH9RVB":{"type":"collapsible-content","blocks":{"collapsible_row_hzDaFH":{"type":"collapsible_row","settings":{"heading":"Werkt de ThermoCup in elke auto?","icon":"none","row_content":"<p>Ja, de ThermoCup werkt via de 12V aansluiting (sigarettenaansteker) en past in vrijwel alle standaard bekerhouders.<\/p>","page":""}},"collapsible_row_p7ByyN":{"type":"collapsible_row","settings":{"heading":"Hoe lang duurt het voordat mijn drankje op temperatuur is?","icon":"none","row_content":"<p>Koelen kan binnen 10-15 minuten tot circa -5°C. Verwarmen duurt gemiddeld 15-25 minuten tot maximaal 65°C, afhankelijk van het startpunt.<\/p>","page":""}},"collapsible_row_VpntPw":{"type":"collapsible_row","settings":{"heading":"Kan ik er ook babyflesjes mee verwarmen?","icon":"none","row_content":"<p>Ja, de ThermoCup is perfect voor het opwarmen van melk tot 37°C – ideaal voor babyvoeding onderweg.<\/p>","page":""}},"collapsible_row_xemFKw":{"type":"collapsible_row","settings":{"heading":"Kan ik de ThermoCup ook gebruiken voor blikjes en koffiebekers?","icon":"none","row_content":"<p>Zeker! De cup is geschikt voor blikjes, flesjes, kartonnen bekers en babyflesjes – zolang ze in de houder passen.<\/p>","page":""}},"collapsible_row_aAVrhJ":{"type":"collapsible_row","settings":{"heading":"Is het veilig om de ThermoCup in de auto te laten zitten?","icon":"none","row_content":"<p>Voor de veiligheid raden we aan om de stekker uit de ThermoCup te halen wanneer je de auto verlaat. Zo voorkom je onnodig energieverbruik en mogelijke oververhitting.<\/p>","page":""}},"collapsible_row_Mwg64M":{"type":"collapsible_row","settings":{"heading":"Hoe maak ik de ThermoCup schoon?","icon":"none","row_content":"<p>De binnenzijde is voorzien van een aluminium binnenwand. Gebruik een vochtige doek – dompel het apparaat nooit onder in water.<\/p>","page":""}}},"block_order":["collapsible_row_hzDaFH","collapsible_row_p7ByyN","collapsible_row_VpntPw","collapsible_row_xemFKw","collapsible_row_aAVrhJ","collapsible_row_Mwg64M"],"settings":{"caption":"","heading_size":"h1","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"image_ratio":"adapt","desktop_layout":"image_second","padding_top":16,"padding_bottom":16}},"66b6d233-ac90-40ab-87d7-9d5df4d7260c":{"type":"rich-text","blocks":{"template--19884972900676__66b6d233-ac90-40ab-87d7-9d5df4d7260c-text-1":{"type":"text","settings":{"text":""}}},"block_order":["template--19884972900676__66b6d233-ac90-40ab-87d7-9d5df4d7260c-text-1"],"settings":{"desktop_content_position":"center","content_alignment":