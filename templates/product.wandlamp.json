template--18472096170313__03c08e95-f0ce-4379-bc05-787da4136202-1679864525e35c34e4-1","template--18472096170313__03c08e95-f0ce-4379-bc05-787da4136202-1679864525e35c34e4-2"],"settings":{"speed":1.5,"color_scheme":"background-2","italic_text":false,"uppercase_text":false,"bold_text":false}},"related-products":{"type":"related-products","disabled":true,"settings":{"heading_size":"h2","products_to_show":4,"columns_desktop":4,"color_scheme":"background-1","image_ratio":"adapt","show_secondary_image":false,"show_vendor":false,"show_rating":false,"columns_mobile":"2","padding_top":36,"padding_bottom":24}},"d7112918-a6ed-4119-8565-5d4b7041284a":{"type":"rich-text","settings":{"desktop_content_position":"center","content_alignment":"center","full_width":true,"color_scheme":"background-1","padding_top":12,"padding_bottom":12}},"16947789000e7c3be1":{"type":"apps","settings":{"include_margins":true}},"169477810286cbda2b":{"type":"apps","settings":{"include_margins":true}},"1694778916ae6d13bb":{"type":"apps","settings":{"include_margins":true}},"27bf48b5-b24a-4a61-a7c6-a8562da2644d":{"type":"rich-text","blocks":{"template--19745443676484__27bf48b5-b24a-4a61-a7c6-a8562da2644d-text-1":{"type":"text","settings":{"text":"<h5>De hoogtepunten op een rij: <\/h5><p>💡 Oplaadbare Draadloze LED-Wandlamp <\/p><p>☀️ 3 Helderheidsniveaus & 3 kleur opties<\/p><p>🔄 360° Rotatiefunctie<\/p><p>🧲 Magnetische houder met afneembare lichtkop<\/p><p>👆 Bediening via Touch-Control<\/p><p>❌ Moeiteloos bevestigen zonder gereedschap of schroeven<\/p><p>🔋 Ingebouwde duurzame Batterij<\/p>"}}},"block_order":["template--19745443676484__27bf48b5-b24a-4a61-a7c6-a8562da2644d-text-1"],"settings":{"desktop_content_position":"left","content_alignment":"left","full_width":true,"color_scheme":"background-1","padding_top":4,"padding_bottom":100}},"64d896ba-f34c-49f3-b877-d32f6f28649c":{"type":"rich-text","blocks":{"template--19810270937412__64d896ba-f34c-49f3-b877-d32f6f28649c-text-1":{"type":"text","settings":{"text":"<h4><strong>COMPACT ONTWERP EN OVERAL TE PLAATSEN<\/strong><\/h4><p>Met de LED-wandlamp biedt u <strong>draadloze verlichting<\/strong> die opvalt door een tijdloos design, veelzijdige helderheid mogelijkheden en verschillende kleur opties. <\/p><p>Gebruik hem...<br\/>✔️ om te lezen en te leren als bureau- of bedlampje<br\/>✔️ als verlichting voor de keuken of werkplaats<br\/>✔️ voor het verlichten van foto's in de gang of spiegels in de badkamer<br\/>✔️ tijdens het reizen in de caravan<br\/>✔️ of als lichtbron in het geval van een stroomstoring. Bijzonder praktisch is het magnetische draaischarnier, waarvan u de lampkop eenvoudig kunt verwijderen en als <strong>draagbare lamp<\/strong> kunt gebruiken.<br\/><\/p>"}}},"block_order":["template--19810270937412__64d896ba-f34c-49f3-b877-d32f6f28649c-text-1"],"settings":{"desktop_content_position":"left","content_alignment":"left","full_width":true,"color_scheme":"background-1","padding_top":100,"padding_bottom":52}},"2930a9b8-df01-422e-b4c9-bf2fdfdd6815":{"type":"image-with-text","blocks":{"92919f52-114b-494d-8ecd-111afb754bbe":{"type":"text","settings":{"text":"","text_style":"body"}}},"block_order":["92919f52-114b-494d-8ecd-111afb754bbe"],"settings":{"image":"shopify:\/\/shop_images\/Ontwerp_zonder_titel_1.png","height":"medium","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"b8013f7d-a303-4143-9f5f-cf8659dcce10":{"type":"rich-text","blocks":{"template--19810270937412__b8013f7d-a303-4143-9f5f-cf8659dcce10-text-1":{"type":"text","settings":{"text":"<h3><strong>CREËER VERSCHILLENDE LICHTSFEREN DANKZIJ 360° ROTATIE<\/strong><\/h3><p>Dankzij de draaibare kop met 360° draaifunctie kun je verschillende lichtsferen in de kamer creëren en de wandlamp als <strong>spot<\/strong> of als achtergrond <strong>licht<\/strong> gebruiken. <strong>Door de lamp naar boven te draaien, kun je je muren stijlvol verlichten met zacht, indirect licht en meteen een knusse sfeer <\/strong>creëren, bijvoorbeeld tijdens het eten of relaxen op de bank. <\/p><p>Gebruik de rotatie van de LED-Wandlamp om <strong>meubels, foto's of decoratieve spullen op indrukwekkende wijze in de spotlight <\/strong>te zetten. Ook voor een perfecte <strong>verlichting van uw werkomgeving<\/strong><br\/><br\/>De Infinity wandlamp kan ook uitstekend gebruikt worden voor bijvoorbeeld op kantoor of in de keuken.<br\/><\/p>"}}},"block_order":["template--19810270937412__b8013f7d-a303-4143-9f5f-cf8659dcce10-text-1"],"settings":{"desktop_content_position":"left","content_alignment":"left","full_width":true,"color_scheme":"background-1","padding_top":0,"padding_bottom":52}},"3c54e43b-aa0d-41d4-af27-634d34fa8224":{"type":"image-with-text","settings":{"image":"shopify:\/\/shop_images\/verschillende_plekkern_lamp.webp","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left"}},"72f2352c-ae66-4cc6-b552-6e6425e9f9d6":{"type":"rich-text","blocks":{"template--19745443676484__72f2352c-ae66-4cc6-b552-6e6425e9f9d6-heading-1":{"type":"heading","settings":{"heading_size":"h2"}}},"block_order":["template--19745443676484__72f2352c-ae66-4cc6-b552-6e6425e9f9d6-heading-1"],"settings":{"desktop_content_position":"left","content_alignment":"left","full_width":true,"color_scheme":"background-1","padding_top":24,"padding_bottom":12}},"e11a888d-70bb-40bd-abc8-40d9de74cea1":{"type":"image-with-text","settings":{"image":"shopify:\/\/shop_images\/3_Verschillende_Licht-Opties.gif","height":"adapt","color_scheme":"background-1","section_color_scheme":"background-1","content_layout":"no-overlap","layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"center","mobile_content_alig