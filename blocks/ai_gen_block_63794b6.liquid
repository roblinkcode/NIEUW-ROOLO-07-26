{% doc %}
  @prompt
    Before and after slider, with text next to it (on phone above it), clean look, Option that i can choose that the text is left from the slider or right, and a circle with an arrow left and right so its more obvious that u can swipe the middle to before and after, also that i am able to put the before and after label on the left and right upper corner and an option to make the label background smaller, i also want an option to make the slider background transparant, Now i have the before and after label background transparant, also good! But i want the slider it's background (the middle circle thing where i can slide from left to right) also transparant (option)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-before-after-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-before-after-container-{{ ai_gen_id }} {
    display: flex;
    gap: 40px;
    align-items: center;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    {% if block.settings.text_position == 'right' %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .ai-before-after-slider-wrapper-{{ ai_gen_id }} {
    flex: 1;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-before-after-images-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.aspect_ratio }};
  }

  .ai-before-after-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-before-after-after-{{ ai_gen_id }} {
    clip-path: inset(0 0 0 50%);
  }

  .ai-before-after-divider-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 50%;
    width: {{ block.settings.divider_width }}px;
    height: 100%;
    background-color: {{ block.settings.divider_color }};
    transform: translateX(-50%);
    cursor: ew-resize;
    z-index: 2;
  }

  .ai-before-after-handle-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    width: {{ block.settings.handle_size }}px;
    height: {{ block.settings.handle_size }}px;
    {% if block.settings.transparent_handle_bg %}
      background-color: transparent;
    {% else %}
      background-color: {{ block.settings.handle_color }};
    {% endif %}
    border: {{ block.settings.handle_border_width }}px solid {{ block.settings.handle_border_color }};
    border-radius: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    {% unless block.settings.transparent_handle_bg %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    {% endunless %}
  }

  .ai-before-after-arrow-{{ ai_gen_id }} {
    position: absolute;
    width: 0;
    height: 0;
    border-style: solid;
  }

  .ai-before-after-arrow-left-{{ ai_gen_id }} {
    left: 28%;
    border-width: 7px 10px 7px 0;
    border-color: transparent {{ block.settings.arrow_color }} transparent transparent;
  }

  .ai-before-after-arrow-right-{{ ai_gen_id }} {
    right: 28%;
    border-width: 7px 0 7px 10px;
    border-color: transparent transparent transparent {{ block.settings.arrow_color }};
  }

  .ai-before-after-label-{{ ai_gen_id }} {
    position: absolute;
    padding: {{ block.settings.label_padding_y }}px {{ block.settings.label_padding_x }}px;
    {% if block.settings.transparent_label_bg %}
      background-color: transparent;
    {% else %}
      background-color: {{ block.settings.label_bg_color }};
    {% endif %}
    color: {{ block.settings.label_text_color }};
    font-size: {{ block.settings.label_font_size }}px;
    font-weight: 600;
    border-radius: 4px;
    pointer-events: none;
    z-index: 1;
  }

  {% if block.settings.label_position == 'top_corners' %}
    .ai-before-after-label-before-{{ ai_gen_id }} {
      top: {{ block.settings.label_position_y }}%;
      left: {{ block.settings.label_position_x }}%;
    }

    .ai-before-after-label-after-{{ ai_gen_id }} {
      top: {{ block.settings.label_position_y }}%;
      right: {{ block.settings.label_position_x }}%;
    }
  {% else %}
    .ai-before-after-label-before-{{ ai_gen_id }} {
      bottom: {{ block.settings.label_position_y }}%;
      left: {{ block.settings.label_position_x }}%;
    }

    .ai-before-after-label-after-{{ ai_gen_id }} {
      bottom: {{ block.settings.label_position_y }}%;
      right: {{ block.settings.label_position_x }}%;
    }
  {% endif %}

  .ai-before-after-content-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-before-after-heading-{{ ai_gen_id }} {
    margin: 0 0 16px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.3;
  }

  .ai-before-after-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-before-after-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-before-after-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-before-after-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-before-after-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 24px;
    }

    .ai-before-after-slider-wrapper-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-before-after-content-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<before-after-slider-{{ ai_gen_id }}
  class="ai-before-after-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-before-after-container-{{ ai_gen_id }}">
    <div class="ai-before-after-slider-wrapper-{{ ai_gen_id }}">
      <div class="ai-before-after-images-{{ ai_gen_id }}">
        {% if block.settings.before_image %}
          <img
            src="{{ block.settings.before_image | image_url: width: 1200 }}"
            alt="{{ block.settings.before_label | escape }}"
            loading="lazy"
            width="{{ block.settings.before_image.width }}"
            height="{{ block.settings.before_image.height }}"
            class="ai-before-after-image-{{ ai_gen_id }} ai-before-after-before-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-before-after-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-before-after-empty-state-{{ ai_gen_id }}">
              Add before image
            </div>
          </div>
        {% endif %}

        {% if block.settings.after_image %}
          <img
            src="{{ block.settings.after_image | image_url: width: 1200 }}"
            alt="{{ block.settings.after_label | escape }}"
            loading="lazy"
            width="{{ block.settings.after_image.width }}"
            height="{{ block.settings.after_image.height }}"
            class="ai-before-after-image-{{ ai_gen_id }} ai-before-after-after-{{ ai_gen_id }}"
            data-after-image
          >
        {% else %}
          <div class="ai-before-after-placeholder-{{ ai_gen_id }} ai-before-after-after-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-before-after-empty-state-{{ ai_gen_id }}">
              Add after image
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_labels %}
          {% if block.settings.before_label != blank %}
            <div class="ai-before-after-label-{{ ai_gen_id }} ai-before-after-label-before-{{ ai_gen_id }}">
              {{ block.settings.before_label }}
            </div>
          {% endif %}

          {% if block.settings.after_label != blank %}
            <div class="ai-before-after-label-{{ ai_gen_id }} ai-before-after-label-after-{{ ai_gen_id }}">
              {{ block.settings.after_label }}
            </div>
          {% endif %}
        {% endif %}

        <div class="ai-before-after-divider-{{ ai_gen_id }}" data-divider>
          <div class="ai-before-after-handle-{{ ai_gen_id }}">
            <span class="ai-before-after-arrow-{{ ai_gen_id }} ai-before-after-arrow-left-{{ ai_gen_id }}"></span>
            <span class="ai-before-after-arrow-{{ ai_gen_id }} ai-before-after-arrow-right-{{ ai_gen_id }}"></span>
          </div>
        </div>
      </div>
    </div>

    {% if block.settings.heading != blank or block.settings.text != blank %}
      <div class="ai-before-after-content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-before-after-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="ai-before-after-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</before-after-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class BeforeAfterSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.isDragging = false;
      }

      connectedCallback() {
        this.divider = this.querySelector('[data-divider]');
        this.afterImage = this.querySelector('[data-after-image]');
        this.container = this.querySelector('.ai-before-after-images-{{ ai_gen_id }}');

        if (!this.divider || !this.afterImage || !this.container) return;

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.divider.addEventListener('mousedown', this.startDrag.bind(this));
        this.divider.addEventListener('touchstart', this.startDrag.bind(this), { passive: true });

        document.addEventListener('mousemove', this.onDrag.bind(this));
        document.addEventListener('touchmove', this.onDrag.bind(this), { passive: false });

        document.addEventListener('mouseup', this.stopDrag.bind(this));
        document.addEventListener('touchend', this.stopDrag.bind(this));
      }

      startDrag(e) {
        this.isDragging = true;
        this.divider.style.transition = 'none';
        this.afterImage.style.transition = 'none';
      }

      stopDrag() {
        this.isDragging = false;
      }

      onDrag(e) {
        if (!this.isDragging) return;

        e.preventDefault();

        const rect = this.container.getBoundingClientRect();
        const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
        let x = clientX - rect.left;

        x = Math.max(0, Math.min(x, rect.width));

        const percentage = (x / rect.width) * 100;

        this.divider.style.left = percentage + '%';
        this.afterImage.style.clipPath = `inset(0 0 0 ${percentage}%)`;
      }
    }

    customElements.define('before-after-slider-{{ ai_gen_id }}', BeforeAfterSlider{{ ai_gen_id }});
  })();
</script>

