{% doc %}
  @prompt
    Before and after slider, with text next to it (on phone above it), clean look, Option that i can choose that the text is left from the slider or right, and a circle with an arrow left and right so its more obvious that u can swipe the middle to before and after, also that i am able to put the before and after label on the left and right upper corner and an option to make the label background smaller, i also want an option to make the slider background transparant, Now i have the before and after label background transparant, also good! But i want the slider it's background (the middle circle thing where i can slide from left to right) also transparant (option)
    
    Also an option seperate for phone and desktop, the option for text alignment, text size, size of the before after slider it self. , Also an arrow (left) and arrow (right) in the middle of the slider, so u can see easily that u can slide left and right, also an option to make the middle stripe of the slider thinner.
    
    Also an option to make the spacing between the text and the slider less.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-before-after-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-before-after-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.layout_desktop }};
    gap: {{ block.settings.spacing_desktop }}px;
    align-items: center;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  @media screen and (max-width: 749px) {
    .ai-before-after-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.spacing_mobile }}px;
    }
  }

  .ai-before-after-text-{{ ai_gen_id }} {
    flex: 1;
    text-align: {{ block.settings.text_alignment_desktop }};
  }

  @media screen and (max-width: 749px) {
    .ai-before-after-text-{{ ai_gen_id }} {
      text-align: {{ block.settings.text_alignment_mobile }};
    }
  }

  .ai-before-after-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size_desktop }}px;
    margin: 0 0 16px;
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-before-after-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }
  }

  .ai-before-after-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size_desktop }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-before-after-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }
  }

  .ai-before-after-slider-container-{{ ai_gen_id }} {
    flex: 1;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.slider_border_radius }}px;
    width: 100%;
    max-width: {{ block.settings.slider_width_desktop }}%;
  }

  @media screen and (max-width: 749px) {
    .ai-before-after-slider-container-{{ ai_gen_id }} {
      max-width: {{ block.settings.slider_width_mobile }}%;
    }
  }

  .ai-before-after-slider-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.aspect_ratio }};
    user-select: none;
  }

  .ai-before-after-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-before-after-after-{{ ai_gen_id }} {
    clip-path: inset(0 0 0 50%);
  }

  .ai-before-after-divider-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 50%;
    width: {{ block.settings.divider_width }}px;
    height: 100%;
    background-color: {{ block.settings.divider_color }};
    transform: translateX(-50%);
    cursor: ew-resize;
    z-index: 2;
  }

  .ai-before-after-handle-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ block.settings.handle_size }}px;
    height: {{ block.settings.handle_size }}px;
    border-radius: 50%;
    background-color: {% if block.settings.handle_transparent %}transparent{% else %}{{ block.settings.handle_color }}{% endif %};
    border: 3px solid {{ block.settings.divider_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: ew-resize;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .ai-before-after-arrows-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .ai-before-after-arrow-{{ ai_gen_id }} {
    width: 0;
    height: 0;
    border-style: solid;
  }

  .ai-before-after-arrow-left-{{ ai_gen_id }} {
    border-width: {{ block.settings.arrow_size }}px {{ block.settings.arrow_size | times: 1.3 }}px {{ block.settings.arrow_size }}px 0;
    border-color: transparent {{ block.settings.arrow_color }} transparent transparent;
  }

  .ai-before-after-arrow-right-{{ ai_gen_id }} {
    border-width: {{ block.settings.arrow_size }}px 0 {{ block.settings.arrow_size }}px {{ block.settings.arrow_size | times: 1.3 }}px;
    border-color: transparent transparent transparent {{ block.settings.arrow_color }};
  }

  .ai-before-after-side-arrows-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
    pointer-events: none;
  }

  .ai-before-after-side-arrow-left-{{ ai_gen_id }} {
    left: {{ block.settings.side_arrow_position }}px;
  }

  .ai-before-after-side-arrow-right-{{ ai_gen_id }} {
    right: {{ block.settings.side_arrow_position }}px;
  }

  .ai-before-after-side-arrow-icon-{{ ai_gen_id }} {
    width: 0;
    height: 0;
    border-style: solid;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
  }

  .ai-before-after-side-arrow-icon-left-{{ ai_gen_id }} {
    border-width: {{ block.settings.side_arrow_size }}px {{ block.settings.side_arrow_size | times: 1.3 }}px {{ block.settings.side_arrow_size }}px 0;
    border-color: transparent {{ block.settings.side_arrow_color }} transparent transparent;
  }

  .ai-before-after-side-arrow-icon-right-{{ ai_gen_id }} {
    border-width: {{ block.settings.side_arrow_size }}px 0 {{ block.settings.side_arrow_size }}px {{ block.settings.side_arrow_size | times: 1.3 }}px;
    border-color: transparent transparent transparent {{ block.settings.side_arrow_color }};
  }

  .ai-before-after-label-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.label_position_vertical }}px;
    padding: {{ block.settings.label_padding_vertical }}px {{ block.settings.label_padding_horizontal }}px;
    background-color: {% if block.settings.label_transparent %}transparent{% else %}{{ block.settings.label_background }}{% endif %};
    color: {{ block.settings.label_text_color }};
    font-size: {{ block.settings.label_font_size }}px;
    font-weight: 600;
    border-radius: 4px;
    z-index: 1;
    pointer-events: none;
  }

  .ai-before-after-label-before-{{ ai_gen_id }} {
    left: {{ block.settings.label_position_horizontal }}px;
  }

  .ai-before-after-label-after-{{ ai_gen_id }} {
    right: {{ block.settings.label_position_horizontal }}px;
  }

  .ai-before-after-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.slider_border_radius }}px;
    position: relative;
  }

  .ai-before-after-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-before-after-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }
{% endstyle %}

<before-after-slider-{{ ai_gen_id }}
  class="ai-before-after-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-before-after-wrapper-{{ ai_gen_id }}">
    {% if block.settings.layout_desktop == 'row' %}
      <div class="ai-before-after-text-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-before-after-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-before-after-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-before-after-slider-container-{{ ai_gen_id }}">
      {% if block.settings.before_image and block.settings.after_image %}
        <div class="ai-before-after-slider-{{ ai_gen_id }}" data-slider>
          <img
            src="{{ block.settings.before_image | image_url: width: 1200 }}"
            alt="{{ block.settings.before_label }}"
            class="ai-before-after-image-{{ ai_gen_id }}"
            loading="lazy"
          >
          <img
            src="{{ block.settings.after_image | image_url: width: 1200 }}"
            alt="{{ block.settings.after_label }}"
            class="ai-before-after-image-{{ ai_gen_id }} ai-before-after-after-{{ ai_gen_id }}"
            loading="lazy"
            data-after-image
          >

          {% if block.settings.show_labels %}
            <div class="ai-before-after-label-{{ ai_gen_id }} ai-before-after-label-before-{{ ai_gen_id }}">
              {{ block.settings.before_label }}
            </div>
            <div class="ai-before-after-label-{{ ai_gen_id }} ai-before-after-label-after-{{ ai_gen_id }}">
              {{ block.settings.after_label }}
            </div>
          {% endif %}

          {% if block.settings.show_side_arrows %}
            <div class="ai-before-after-side-arrows-{{ ai_gen_id }} ai-before-after-side-arrow-left-{{ ai_gen_id }}">
              <div class="ai-before-after-side-arrow-icon-{{ ai_gen_id }} ai-before-after-side-arrow-icon-left-{{ ai_gen_id }}"></div>
            </div>
            <div class="ai-before-after-side-arrows-{{ ai_gen_id }} ai-before-after-side-arrow-right-{{ ai_gen_id }}">
              <div class="ai-before-after-side-arrow-icon-{{ ai_gen_id }} ai-before-after-side-arrow-icon-right-{{ ai_gen_id }}"></div>
            </div>
          {% endif %}

          <div class="ai-before-after-divider-{{ ai_gen_id }}" data-divider>
            <div class="ai-before-after-handle-{{ ai_gen_id }}">
              <div class="ai-before-after-arrows-{{ ai_gen_id }}">
                <div class="ai-before-after-arrow-{{ ai_gen_id }} ai-before-after-arrow-left-{{ ai_gen_id }}"></div>
                <div class="ai-before-after-arrow-{{ ai_gen_id }} ai-before-after-arrow-right-{{ ai_gen_id }}"></div>
              </div>
            </div>
          </div>
        </div>
      {% else %}
        <div class="ai-before-after-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-before-after-empty-state-{{ ai_gen_id }}">
            Next, add before and after images
          </div>
        </div>
      {% endif %}
    </div>

    {% if block.settings.layout_desktop == 'row-reverse' %}
      <div class="ai-before-after-text-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-before-after-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-before-after-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</before-after-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class BeforeAfterSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.slider = this.querySelector('[data-slider]');
        this.divider = this.querySelector('[data-divider]');
        this.afterImage = this.querySelector('[data-after-image]');
        this.isDragging = false;
      }

      connectedCallback() {
        if (!this.slider || !this.divider || !this.afterImage) return;

        this.divider.addEventListener('mousedown', this.startDrag.bind(this));
        this.divider.addEventListener('touchstart', this.startDrag.bind(this));
        document.addEventListener('mousemove', this.onDrag.bind(this));
        document.addEventListener('touchmove', this.onDrag.bind(this));
        document.addEventListener('mouseup', this.stopDrag.bind(this));
        document.addEventListener('touchend', this.stopDrag.bind(this));

        this.slider.addEventListener('click', this.handleClick.bind(this));
      }

      startDrag(e) {
        this.isDragging = true;
        e.preventDefault();
      }

      stopDrag() {
        this.isDragging = false;
      }

      onDrag(e) {
        if (!this.isDragging) return;
        this.updatePosition(e);
      }

      handleClick(e) {
        if (e.target === this.divider || this.divider.contains(e.target)) return;
        this.updatePosition(e);
      }

      updatePosition(e) {
        const rect = this.slider.getBoundingClientRect();
        const x = (e.type.includes('touch') ? e.touches[0].clientX : e.clientX) - rect.left;
        const percentage = Math.max(0, Math.min(100, (x / rect.width) * 100));

        this.divider.style.left = percentage + '%';
        this.afterImage.style.clipPath = `inset(0 0 0 ${percentage}%)`;
      }

      disconnectedCallback() {
        document.removeEventListener('mousemove', this.onDrag.bind(this));
        document.removeEventListener('touchmove', this.onDrag.bind(this));
        document.removeEventListener('mouseup', this.stopDrag.bind(this));
        document.removeEventListener('touchend', this.stopDrag.bind(this));
      }
    }

    customElements.define('before-after-slider-{{ ai_gen_id }}', BeforeAfterSlider{{ ai_gen_id }});
  })();
</script>

