{% comment %}
  Renders cart drawer

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}

{% liquid
  assign lift_collection_handle = 'lift-shoewear'
  assign lift_collection = collections[lift_collection_handle]
  assign shipping_protection_product_handle = 'shipping-insurance'
  assign shipping_protection_titles = '|verzekerde verzending|verzekerd verzenden|versicherter versand|versicherter versandschutz|shipping protection|insured shipping|shipping insurance|'
  assign cart_has_lift = false
  assign cart_product_ids = '|'
  assign preferred_upsell_size = blank
  assign preferred_upsell_height = blank
  assign visible_cart_item_count = 0
  assign non_upsell_count = 0

  for item in cart.items
    assign is_shipping_protection_item = false
    assign item_title_downcase = item.product.title | downcase | strip
    assign item_handle_downcase = item.product.handle | downcase | strip
    assign item_vendor_downcase = item.product.vendor | downcase | strip
    assign item_type_downcase = item.product.type | downcase | strip
    assign item_title_token = item_title_downcase | prepend: '|' | append: '|'

    if shipping_protection_titles contains item_title_token
      assign is_shipping_protection_item = true
    elsif item_handle_downcase == shipping_protection_product_handle or item_handle_downcase contains 'shipping-protection' or item_handle_downcase contains 'shipping-protect' or item_handle_downcase contains 'insured-shipping' or item_handle_downcase contains 'shipping-insurance' or item_handle_downcase contains 'shipping_insurance' or item_handle_downcase contains 'sam-shipping'
      assign is_shipping_protection_item = true
    elsif item_vendor_downcase == 'shopwill' and item_type_downcase == 'shopwill'
      assign is_shipping_protection_item = true
    elsif item_vendor_downcase == 'sam' or item_vendor_downcase contains 'sam shipping' or item_vendor_downcase contains 'shipping protect' or item_vendor_downcase contains 'shipping insurance' or item_vendor_downcase contains 'insured shipping'
      assign is_shipping_protection_item = true
    elsif item_type_downcase == 'sam' or item_type_downcase contains 'sam shipping' or item_type_downcase contains 'shipping protect' or item_type_downcase contains 'shipping insurance' or item_type_downcase contains 'insured shipping'
      assign is_shipping_protection_item = true
    endif

    if is_shipping_protection_item
      continue
    endif

    assign visible_cart_item_count = visible_cart_item_count | plus: item.quantity
    unless item.product.tags contains 'cart-hidden'
      assign non_upsell_count = non_upsell_count | plus: item.quantity
    endunless

    assign cart_product_ids = cart_product_ids | append: item.product.id | append: '|'
    assign item_is_lift = false

    for item_collection in item.product.collections
      if item_collection.handle == lift_collection_handle
        assign cart_has_lift = true
        assign item_is_lift = true
      endif
    endfor

    if item_is_lift and preferred_upsell_size == blank and preferred_upsell_height == blank
      for option in item.options_with_values
        assign option_name_downcase = option.name | downcase
        if option_name_downcase contains 'schoenmaat' or option_name_downcase contains 'maat' or option_name_downcase contains 'size' or option_name_downcase contains 'größe' or option_name_downcase contains 'groesse'
          assign preferred_upsell_size = option.value
        elsif option_name_downcase contains 'hoogte' or option_name_downcase contains 'height' or option_name_downcase contains 'lengte' or option_name_downcase contains 'zunahme'
          assign preferred_upsell_height = option.value
        endif
      endfor
    endif
  endfor
%}

<style>
  .drawer {
    visibility: hidden;
  }
  {% if section.settings.enable_header_bg %}
    .cart-drawer .drawer__header {
      background: {{ section.settings.header_bg_color }};
    }
  {% endif %}
  {% if section.settings.enable_body_bg %}
    .cart-drawer__body, .cart-drawer-item {
      background: {{ section.settings.body_bg_color }};
    }
  {% endif %}
  {% if section.settings.enable_footer_bg %}
    .cart-drawer .drawer__footer {
      background: {{ section.settings.footer_bg_color }};
    }
  {% endif %}
</style>

<cart-drawer
  class="drawer cart-drawer-premium{% if visible_cart_item_count == 0 %} is-empty{% endif %}{% if section.settings.test_mode %} active{% endif %} cart-drawer--desktop-width-{{ section.settings.desktop_width }} cart-drawer--mobile-width-{{ section.settings.mobile_width }}"
  data-type="modal"
  data-premium-stylesheet="{{ 'cart-drawer-premium.css' | asset_url }}"
>
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="drawer__inner"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      <div class="drawer__header" style='--alignment:{{ section.settings.heading_alignment }}'>
        <h2 class="drawer__heading">
          {{ 'cart_drawer.premium.title' | t: count: non_upsell_count }}
        </h2>
        <button
          class="drawer__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {% render 'icon-close' %}
        </button>
      </div>
      {% if visible_cart_item_count == 0 %}
        <div class="drawer__inner-empty cart-drawer-premium__empty">
          <div class="cart-drawer__warnings center">
            <div class="cart-drawer__empty-content">
              <h2 class="cart-drawer-premium__empty-title">{{ 'cart_drawer.premium.empty_title' | t }}</h2>
              <a href="{{ routes.root_url }}" class="button cart-drawer-premium__empty-link">
                {{ 'cart_drawer.premium.return_to_shop' | t }}
              </a>
            </div>
          </div>
        </div>
      {% else %}
      {% if cart.total_price > 2000 %}
        <div class="cart-drawer-premium__shipping" role="status">
          <span class="cart-drawer-premium__shipping-check" aria-hidden="true">✓</span>
          <span>{{ 'cart_drawer.premium.free_shipping_active' | t }}</span>
        </div>
      {% endif %}
      <div class="cart-drawer__body">
        {% if section.blocks.size == 0 %}
          <h3 class='h3 center'>To customize the cart, add blocks to the Cart drawer section (under the Header group)</h3>
        {% endif %}
        {% assign total_compare_price = 0 %}
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'progress_bar' %}
              {% render 'cart-progress-bar', block: block, items_count: non_upsell_count %}
            {% when 'checkpoints_bar' %}
              {% render 'cart-checkpoints-bar', block: block, items_count: non_upsell_count %}
            {% when 'countdown_timer' %}
              {% capture timer %}
                <countdown-timer data-duration="{{ block.settings.timer_duration }}"></countdown-timer>
              {% endcapture %}
              <div class='cart-timer color-{{ block.settings.color_scheme }}' style="--font-size:{{ block.settings.font_size }}rem;--margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;--margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;" {{ block.shopify_attributes }}>
                {{ block.settings.timer_text | replace: '[timer]', timer }}
              </div>
            {% when 'cart_items' %}
              <cart-drawer-items
                {% if visible_cart_item_count == 0 %}
                  class=" is-empty"
                {% endif %}
                style="--image-size: {{ block.settings.image_size }}%;--title-size:{{ block.settings.title_size }}rem;--margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;--margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;" 
                {{ block.shopify_attributes }}
              >
                <form
                  action="{{ routes.cart_url }}"
                  id="CartDrawer-Form"
                  class="cart__contents cart-drawer__form"
                  method="post"
                >
                  <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
                    {%- if visible_cart_item_count > 0 -%}
                      <div class="drawer__cart-items-wrapper">
                        <ul class="cart-items list-unstyled">
                          {%- for item in cart.items -%}
                            {% liquid
                              assign is_shipping_protection_item = false
                              assign item_title_downcase = item.product.title | downcase | strip
                              assign item_handle_downcase = item.product.handle | downcase | strip
                              assign item_vendor_downcase = item.product.vendor | downcase | strip
                              assign item_type_downcase = item.product.type | downcase | strip
                              assign item_title_token = item_title_downcase | prepend: '|' | append: '|'

                              if shipping_protection_titles contains item_title_token
                                assign is_shipping_protection_item = true
                              elsif item_handle_downcase == shipping_protection_product_handle or item_handle_downcase contains 'shipping-protection' or item_handle_downcase contains 'shipping-protect' or item_handle_downcase contains 'insured-shipping' or item_handle_downcase contains 'shipping-insurance' or item_handle_downcase contains 'shipping_insurance' or item_handle_downcase contains 'sam-shipping'
                                assign is_shipping_protection_item = true
                              elsif item_vendor_downcase == 'shopwill' and item_type_downcase == 'shopwill'
                                assign is_shipping_protection_item = true
                              elsif item_vendor_downcase == 'sam' or item_vendor_downcase contains 'sam shipping' or item_vendor_downcase contains 'shipping protect' or item_vendor_downcase contains 'shipping insurance' or item_vendor_downcase contains 'insured shipping'
                                assign is_shipping_protection_item = true
                              elsif item_type_downcase == 'sam' or item_type_downcase contains 'sam shipping' or item_type_downcase contains 'shipping protect' or item_type_downcase contains 'shipping insurance' or item_type_downcase contains 'insured shipping'
                                assign is_shipping_protection_item = true
                              endif
                            %}
                            {% if is_shipping_protection_item %}
                              {% assign total_compare_price = total_compare_price | plus: item.original_line_price %}
                            {% endif %}
                            {% unless is_shipping_protection_item %}
                            <li 
                              id="CartDrawer-Item-{{ item.index | plus: 1 }}" 
                              class="cart-drawer-item cart-item cart-item--product-{{ item.product.handle }}" 
                              role="row" data-index="{{ item.index | plus: 1 }}"
                              data-quantity="{{ item.quantity }}"
                            >
                              <div class="loading-overlay hidden">
                                <div class="loading-overlay__spinner">
                                  <svg
                                    aria-hidden="true"
                                    focusable="false"
                                    class="spinner"
                                    viewBox="0 0 66 66"
                                    xmlns="http://www.w3.org/2000/svg"
                                  >
                                    <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                                  </svg>
                                </div>
                              </div>
                              <div class="cart-item__media" role="cell">
                                {% if item.image %}
                                  {% comment %} Leave empty space due to a:empty CSS display: none rule {% endcomment %}
                                  {% if block.settings.image_link %}<a href="{{ item.url }}" class="cart-item__link" tabindex="-1" aria-hidden="true"> </a>{% endif %}
                                  <img
                                    class="cart-item__image"
                                    src="{{ item.image | image_url: width: 300 }}"
                                    alt="{{ item.image.alt | escape }}"
                                    loading="lazy"
                                    width="150"
                                    height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}"
                                  >
                                {% endif %}
                              </div>

                              <div class='cart-drawer-item__right'>
                                {% liquid 
                                  assign display_compare = false
                                  assign compare_price = 0
                                  assign has_props = false
                                  for variant in item.product.variants
                                    if variant.id == item.id 
                                      assign current_variant = variant
                                    endif
                                  endfor
                                  
                                  if block.settings.displayed_compare_prices == 'automatic'
                                    if item.original_line_price != item.final_line_price 
                                      assign display_compare = true
                                      assign compare_price = item.original_line_price
                                    elsif current_variant.compare_at_price > item.final_price
                                      assign display_compare = true
                                      assign compare_price = current_variant.compare_at_price | times: item.quantity
                                    endif
                                  elsif block.settings.displayed_compare_prices == 'product' and current_variant.compare_at_price > item.final_price
                                    assign display_compare = true
                                    assign compare_price = current_variant.compare_at_price | times: item.quantity
                                  elsif item.original_line_price != item.final_line_price
                                    assign display_compare = true
                                    assign compare_price = item.original_line_price
                                  endif
                                %}
                                <div class='cart-drawer-item__details-and-delete-btn'>
                                  <div class="cart-item__details" role="cell" headers="CartDrawer-ColumnProduct">
                                    {%- if settings.show_vendor -%}
                                      <p class="caption-with-letter-spacing light">{{ item.product.vendor }}</p>
                                    {%- endif -%}
        
                                    <{% if block.settings.title_link %}a href="{{ item.url }}"{% else %}h4{% endif %} class="cart-item__name h4">
                                      {{- item.product.title | escape -}}
                                    </{% if block.settings.title_link %}a{% else %}h4{% endif %}>

                                    {%- if item.discounts.size > 0 -%}
                                      <div class="cart-drawer__discounts cart-drawer-premium__item-discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                                        {%- for discount in item.discounts -%}
                                          <div class="badge">
                                            {%- render 'icon-discount' -%}
                                            <span>{{ discount.title }}</span>
                                          </div>
                                        {%- endfor -%}
                                      </div>
                                    {%- endif -%}
        
                                    {%- capture premium_variant_options -%}
                                      {%- assign premium_color_shown = false -%}
                                      {%- assign premium_height_shown = false -%}
                                      {%- assign premium_size_shown = false -%}
                                      {%- for option in item.options_with_values -%}
                                        {%- liquid
                                          assign option_name_downcase = option.name | downcase | strip
                                          assign premium_option_type = blank
                                          assign premium_option_label = blank

                                          if option_name_downcase contains 'kleur' or option_name_downcase contains 'farbe' or option_name_downcase contains 'color'
                                            assign premium_option_type = 'color'
                                            assign premium_option_label = 'cart_drawer.premium.color' | t
                                          elsif option_name_downcase contains 'hoogte' or option_name_downcase contains 'lengte toename' or option_name_downcase contains 'zusätzliche höhe' or option_name_downcase contains 'zusatzliche hohe' or option_name_downcase contains 'zusaetzliche hoehe' or option_name_downcase contains 'zunahme' or option_name_downcase contains 'height'
                                            assign premium_option_type = 'height'
                                            assign premium_option_label = 'cart_drawer.premium.height' | t
                                          elsif option_name_downcase contains 'schoenmaat' or option_name_downcase contains 'schuhgröße' or option_name_downcase contains 'schuhgroesse' or option_name_downcase contains 'shoe size' or option_name_downcase contains 'maat' or option_name_downcase contains 'size'
                                            assign premium_option_type = 'size'
                                            assign premium_option_label = 'cart_drawer.premium.shoe_size' | t
                                          endif
                                        -%}

                                        {%- if premium_option_type == 'color' and premium_color_shown == false -%}
                                          {%- assign premium_color_shown = true -%}
                                        {%- elsif premium_option_type == 'height' and premium_height_shown == false -%}
                                          {%- assign premium_height_shown = true -%}
                                        {%- elsif premium_option_type == 'size' and premium_size_shown == false -%}
                                          {%- assign premium_size_shown = true -%}
                                        {%- else -%}
                                          {%- assign premium_option_type = blank -%}
                                        {%- endif -%}

                                        {%- if premium_option_type != blank -%}
                                          <div class="product-option product-option--{{ premium_option_type }}">
                                            <dt>{{ premium_option_label }}:</dt>
                                            <dd>{{ option.value }}</dd>
                                          </div>
                                        {%- endif -%}
                                      {%- endfor -%}
                                    {%- endcapture -%}
                                    {%- assign premium_variant_options = premium_variant_options | strip -%}
                                    {%- if premium_variant_options != blank -%}
                                      {% assign has_props = true %}
                                      <dl>{{ premium_variant_options }}</dl>
                                    {%- endif -%}
                                  </div>
                                  <cart-remove-button
                                    class='cart-drawer-item__cart-remove-button'
                                    id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                                    data-index="{{ item.index | plus: 1 }}"
                                  >
                                    <button
                                      type="button"
                                      class="button button--tertiary"
                                      aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"
                                    >
                                      {% render 'icon-remove' %}
                                    </button>
                                  </cart-remove-button>
                                </div>

                                <div class='cart-drawer-item__quantity-and-prices{% if block.settings.prices_position == 'left' %} cart-drawer-item__quantity-and-prices--reverse{% endif %}{% if has_props != false %} cart-drawer-item__quantity-and-prices--has-props{% endif %}'>
                                  <div class="cart-item__quantity">
                                    <div class="cart-item__quantity-wrapper">
                                      <quantity-input 
                                        class="quantity cart-quantity color-{{ block.settings.quantity_container_color_scheme }}{% if block.settings.quantity_round_btns %} cart-quantity--round-btns{% endif %}{% if block.settings.quantity_outline_btns %} cart-quantity--outline-btns{% endif %}"
                                        style='
                                          --font-size:{{ block.settings.quantity_font_size | divided_by: 10.0 }}rem;
                                          --border-width:0.{{ block.settings.quantity_border_width }}rem;
                                          --border-color:{{ block.settings.quantity_border_color }};
                                          --corner-radius:{{ block.settings.quantity_corner_radius | divided_by: 10.0 }}rem;
                                          --container-padding:{{ block.settings.quantity_container_padding }}em;
                                          --input-padding:{{ block.settings.quantity_input_padding }}em;
                                          --separator-opacity:{{ block.settings.quantity_separators_opacity | divided_by: 100.0 }};
                                          --padding:{{ block.settings.quantity_padding }}em;
                                          --icon-size:{{ block.settings.quantity_btns_icon_size | divided_by: 100.0 }}em;
                                        '
                                      >
                                        <button class="quantity__button quantity__button--minus no-js-hidden color-{{ block.settings.quantity_btns_color_scheme }}" name="minus" type="button">
                                          <span class="visually-hidden">
                                            {{-
                                              'products.product.quantity.decrease'
                                              | t: product: item.product.title
                                              | escape
                                            -}}
                                          </span>
                                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" fill='currentColor'>
                                            <path d="M432 256c0 17.7-14.3 32-32 32L48 288c-17.7 0-32-14.3-32-32s14.3-32 32-32l352 0c17.7 0 32 14.3 32 32z"/>
                                          </svg>
                                        </button>
                                        <input
                                          class="quantity__input"
                                          type="number"
                                          data-quantity-variant-id="{{ item.variant.id }}"
                                          name="updates[]"
                                          value="{{ item.quantity }}"
                                          {% # theme-check-disable %}
                                          data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                          min="{{ item.variant.quantity_rule.min }}"
                                          {% if item.variant.quantity_rule.max != null %}
                                            max="{{ item.variant.quantity_rule.max }}"
                                          {% endif %}
                                          step="{{ item.variant.quantity_rule.increment }}"
                                          {% # theme-check-enable %}
                                          aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                          id="Drawer-quantity-{{ item.index | plus: 1 }}"
                                          data-index="{{ item.index | plus: 1 }}"
                                        >
                                        <button class="quantity__button quantity__button--plus no-js-hidden color-{{ block.settings.quantity_btns_color_scheme }}" name="plus" type="button">
                                          <span class="visually-hidden">
                                            {{-
                                              'products.product.quantity.increase'
                                              | t: product: item.product.title
                                              | escape
                                            -}}
                                          </span>
                                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" fill='currentColor'>
                                            <path d="M256 80c0-17.7-14.3-32-32-32s-32 14.3-32 32V224H48c-17.7 0-32 14.3-32 32s14.3 32 32 32H192V432c0 17.7 14.3 32 32 32s32-14.3 32-32V288H400c17.7 0 32-14.3 32-32s-14.3-32-32-32H256V80z"/>
                                          </svg>
                                        </button>
                                      </quantity-input>
                                    </div>
        
                                    <div
                                      id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}"
                                      class="cart-item__error"
                                      role="alert"
                                    >
                                      <small class="cart-item__error-text"></small>
                                      <svg
                                        aria-hidden="true"
                                        focusable="false"
                                        class="icon icon-error"
                                        viewBox="0 0 13 13"
                                      >
                                        <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
                                        <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
                                        <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
                                        <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
                                      </svg>
                                    </div>
                                  </div>
                                  
                                  <div class="cart-item__totals {{ block.settings.prices_position }}" role="cell">
                                    <div class="cart-item__price-wrapper">
                                      {% if display_compare %}
                                        {% liquid
                                          assign item_saving = compare_price | minus: item.final_line_price
                                          assign total_compare_price = total_compare_price | plus: compare_price
                                        %}
                                        <div class="cart-item__discounted-prices">
                                          <span class="visually-hidden">{{ 'products.product.price.regular_price' | t }}</span>
                                          <s class="cart-item__old-price price--end compare-price color-foreground-{{ block.settings.compare_price_color }}">
                                            {{ compare_price | money }}
                                          </s>
                                          <span class="visually-hidden">{{ 'products.product.price.sale_price' | t }}</span>
                                          <span class="price--end regular-price accent-color-{{ block.settings.price_color }}">
                                            {% if block.settings.free_prices_text != blank and item.final_line_price == 0 %}
                                              {{ block.settings.free_prices_text }}
                                            {% else %}
                                              {{ item.final_line_price | money }}
                                            {% endif %}
                                          </span>
                                        </div>
                                        {% if block.settings.enable_savings %}
                                          <span class='cart-drawer-item__saving text-color-{{ block.settings.savings_color }}'>
                                            {% capture saved_money_span  %}{{ item_saving | money_without_trailing_zeros }}{% endcapture %}
                                            {{ block.settings.savings_text | replace: '[amount]', saved_money_span }}
                                          </span>
                                        {% endif %}
                                      {% else %}
                                        {% liquid
                                          assign total_compare_price = total_compare_price | plus: item.original_line_price
                                        %}
                                        <span class="price--end regular-price accent-color-{{ block.settings.price_color }}">
                                          {% if block.settings.free_prices_text != blank and item.original_line_price == 0 %}
                                            {{ block.settings.free_prices_text }}
                                          {% else %}
                                            {{ item.original_line_price | money }}
                                          {% endif %}
                                        </span>
                                      {% endif %}
        
                                      {%- if item.variant.available and item.unit_price_measurement -%}
                                        <div class="unit-price caption">
                                          <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                                          {{ item.variant.unit_price | money }}
                                          <span aria-hidden="true">/</span>
                                          <span class="visually-hidden"
                                            >&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span
                                          >
                                          {%- if item.variant.unit_price_measurement.reference_value != 1 -%}
                                            {{- item.variant.unit_price_measurement.reference_value -}}
                                          {%- endif -%}
                                          {{ item.variant.unit_price_measurement.reference_unit }}
                                        </div>
                                      {%- endif -%}
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </li>
                            {% endunless %}
                          {%- endfor -%}
                        </ul>
                      </div>
                    {%- endif -%}
                    <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
                    <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
                      {{ 'accessibility.loading' | t }}
                    </p>
                  </div>
                  <div id="CartDrawer-CartErrors" role="alert"></div>
                </form>

                {% if cart_has_lift and lift_collection != blank %}
                  {% assign premium_upsell_count = 0 %}
                  {% capture premium_upsell_cards %}
                    {% for upsell_product in lift_collection.products %}
                      {% capture upsell_product_token %}|{{ upsell_product.id }}|{% endcapture %}
                      {% unless cart_product_ids contains upsell_product_token %}
                        {% if upsell_product.available %}
                          {% assign upsell_variant = upsell_product.selected_or_first_available_variant %}
                          <article
                            class="cart-drawer-premium-upsell__card"
                            data-product-id="{{ upsell_product.id }}"
                            data-product-handle="{{ upsell_product.handle }}"
                          >
                            <a class="cart-drawer-premium-upsell__media" href="{{ upsell_product.url }}" tabindex="-1" aria-hidden="true">
                              {% if upsell_product.featured_image != blank %}
                                <img
                                  src="{{ upsell_product.featured_image | image_url: width: 240 }}"
                                  alt="{{ upsell_product.featured_image.alt | default: upsell_product.title | escape }}"
                                  width="120"
                                  height="120"
                                  loading="lazy"
                                >
                              {% endif %}
                            </a>
                            <div class="cart-drawer-premium-upsell__content">
                              <div class="cart-drawer-premium-upsell__topline">
                                <a href="{{ upsell_product.url }}" class="cart-drawer-premium-upsell__title">
                                  {{ upsell_product.title | escape }}
                                </a>
                                <span class="cart-drawer-premium-upsell__price">{{ upsell_product.price | money }}</span>
                              </div>

                              <div class="cart-drawer-premium-upsell__options">
                                {% assign upsell_color_shown = false %}
                                {% assign upsell_height_shown = false %}
                                {% assign upsell_size_shown = false %}
                                {% for option in upsell_product.options_with_values %}
                                  {% liquid
                                    assign upsell_option_name = option.name | downcase | strip
                                    assign upsell_option_type = 'other'
                                    assign upsell_option_label = blank
                                    assign show_upsell_option = false
                                    assign option_index = option.position | minus: 1
                                    assign selected_option_value = upsell_variant.options[option_index]

                                    if upsell_option_name contains 'kleur' or upsell_option_name contains 'farbe' or upsell_option_name contains 'color'
                                      assign upsell_option_type = 'color'
                                      assign upsell_option_label = 'cart_drawer.premium.color' | t
                                    elsif upsell_option_name contains 'hoogte' or upsell_option_name contains 'lengte toename' or upsell_option_name contains 'zusätzliche höhe' or upsell_option_name contains 'zusatzliche hohe' or upsell_option_name contains 'zusaetzliche hoehe' or upsell_option_name contains 'zunahme' or upsell_option_name contains 'height'
                                      assign upsell_option_type = 'height'
                                      assign upsell_option_label = 'cart_drawer.premium.height' | t
                                    elsif upsell_option_name contains 'schoenmaat' or upsell_option_name contains 'schuhgröße' or upsell_option_name contains 'schuhgroesse' or upsell_option_name contains 'shoe size' or upsell_option_name contains 'maat' or upsell_option_name contains 'size'
                                      assign upsell_option_type = 'size'
                                      assign upsell_option_label = 'cart_drawer.premium.shoe_size' | t
                                    endif

                                    if upsell_option_type == 'color' and upsell_color_shown == false
                                      assign upsell_color_shown = true
                                      assign show_upsell_option = true
                                    elsif upsell_option_type == 'height' and upsell_height_shown == false
                                      assign upsell_height_shown = true
                                      assign show_upsell_option = true
                                    elsif upsell_option_type == 'size' and upsell_size_shown == false
                                      assign upsell_size_shown = true
                                      assign show_upsell_option = true
                                    endif

                                    assign hide_upsell_option = false
                                    if show_upsell_option == false
                                      assign hide_upsell_option = true
                                    elsif upsell_option_type == 'color' and option.values.size == 1
                                      assign hide_upsell_option = true
                                    endif
                                  %}

                                  {% if hide_upsell_option %}
                                    <select
                                      hidden
                                      data-option-position="{{ option.position }}"
                                      data-option-type="{{ upsell_option_type }}"
                                      aria-hidden="true"
                                      tabindex="-1"
                                    >
                                      {% for value in option.values %}
                                        <option value="{{ value | escape }}"{% if value == selected_option_value %} selected{% endif %}>
                                          {{ value }}
                                        </option>
                                      {% endfor %}
                                    </select>
                                  {% else %}
                                    <label class="cart-drawer-premium-upsell__option cart-drawer-premium-upsell__option--{{ upsell_option_type }}">
                                      <span>{{ upsell_option_label }}</span>
                                      <select
                                        data-option-position="{{ option.position }}"
                                        data-option-type="{{ upsell_option_type }}"
                                        aria-label="{{ 'cart_drawer.premium.option_for_product' | t: option: upsell_option_label, product: upsell_product.title | escape }}"
                                        required
                                      >
                                        {% for value in option.values %}
                                          <option value="{{ value | escape }}"{% if value == selected_option_value %} selected{% endif %}>
                                            {{ value }}
                                          </option>
                                        {% endfor %}
                                      </select>
                                    </label>
                                  {% endif %}
                                {% endfor %}
                              </div>

                              <script type="application/json" data-upsell-variants>
                                [
                                  {% for variant in upsell_product.variants %}
                                    {
                                      "id": {{ variant.id | json }},
                                      "available": {{ variant.available | json }},
                                      "options": {{ variant.options | json }}
                                    }{% unless forloop.last %},{% endunless %}
                                  {% endfor %}
                                ]
                              </script>

                              <button class="cart-drawer-premium-upsell__button" type="button" data-upsell-add>
                                <span data-upsell-button-label>{{ 'cart_drawer.premium.add_half_price' | t }}</span>
                                <span class="loading-overlay__spinner hidden" aria-hidden="true">
                                  <svg class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                                    <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                                  </svg>
                                </span>
                              </button>
                              <p class="cart-drawer-premium-upsell__error" data-upsell-error role="alert" hidden></p>
                            </div>
                          </article>
                          {% assign premium_upsell_count = premium_upsell_count | plus: 1 %}
                          {% if premium_upsell_count >= 3 %}{% break %}{% endif %}
                        {% endif %}
                      {% endunless %}
                    {% endfor %}
                  {% endcapture %}

                  {% if premium_upsell_count > 0 %}
                    <cart-drawer-premium-upsells
                      class="cart-drawer-premium-upsell"
                      data-collection-handle="{{ lift_collection_handle }}"
                      data-preferred-size="{{ preferred_upsell_size | escape }}"
                      data-preferred-height="{{ preferred_upsell_height | escape }}"
                      data-text-add="{{ 'cart_drawer.premium.add_half_price' | t | escape }}"
                      data-text-adding="{{ 'cart_drawer.premium.adding' | t | escape }}"
                      data-text-added="{{ 'cart_drawer.premium.added' | t | escape }}"
                      data-text-unavailable="{{ 'cart_drawer.premium.unavailable' | t | escape }}"
                      data-text-error="{{ 'cart_drawer.premium.error' | t | escape }}"
                      data-text-expand="{{ 'cart_drawer.premium.other_models' | t | escape }}"
                      data-text-collapse="{{ 'cart_drawer.premium.fewer_models' | t | escape }}"
                    >
                      <div class="cart-drawer-premium-upsell__heading">
                        <span class="cart-drawer-premium-upsell__eyebrow">{{ 'cart_drawer.premium.complete_order' | t }}</span>
                        <h3>{{ 'cart_drawer.premium.second_pair_half_price' | t }}</h3>
                        <p>{{ 'cart_drawer.premium.choose_height_size' | t }}</p>
                      </div>
                      <div class="cart-drawer-premium-upsell__list" id="CartDrawer-PremiumUpsellList-{{ section.id }}" data-upsell-list>
                        {{ premium_upsell_cards }}
                      </div>
                      {% if premium_upsell_count > 1 %}
                        <button
                          class="cart-drawer-premium-upsell__toggle"
                          type="button"
                          aria-controls="CartDrawer-PremiumUpsellList-{{ section.id }}"
                          aria-expanded="false"
                          data-upsell-toggle
                        >
                          <span data-upsell-toggle-label>{{ 'cart_drawer.premium.other_models' | t }}</span>
                          <svg class="cart-drawer-premium-upsell__toggle-icon" aria-hidden="true" viewBox="0 0 12 8" fill="none">
                            <path d="M1 1.5 6 6.5l5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </button>
                      {% endif %}
                    </cart-drawer-premium-upsells>
                  {% endif %}
                {% endif %}
              </cart-drawer-items>
            {% when 'product_upsells' %}
              {% if block.settings.position == 'body' %}
                {% liquid
                  if block.settings.display == 'globally'
                    assign display = true
                  else 
                    assign display = false
                    assign handles_array = block.settings.display_product_handles | replace: ' ', '' | split: ','
                    if handles_array contains product.handle
                      assign display = true
                    endif
                  endif
                %}
                {% if display %}
                  {% render 'upsell-block', block: block, type: 'cart-drawer' %}
                {% endif %}
              {% endif %}
            {% when 'gift' %}
              {% if block.settings.position == 'body' %}
                {% liquid
                  if block.settings.display == 'globally'
                    assign display = true
                  else 
                    assign display = false
                    assign handles_array = block.settings.display_product_handles | replace: ' ', '' | split: ','
                    if handles_array contains product.handle
                      assign display = true
                    endif
                  endif
                %}
                {% if display %}
                  {% render 'cart-gift', block: block, items_count: non_upsell_count %}
                {% endif %}
              {% endif %}
            {%- when 'text_with_icon' -%}
              {% if block.settings.position == 'body' %}
